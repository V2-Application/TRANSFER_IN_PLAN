@{
    ViewData["Title"] = "Week Calendar Management";
}

@model IEnumerable<WeekCalendar>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Week Calendar</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Week
    </a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="weekCalendarTable">
                <thead class="table-light">
                    <tr>
                        <th>Week ID</th>
                        <th>Week Seq</th>
                        <th>FY Week</th>
                        <th>FY Year</th>
                        <th>Cal Year</th>
                        <th>Year Week</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.WeekId</td>
                            <td>@item.WeekSeq</td>
                            <td>@item.FyWeek</td>
                            <td>@item.FyYear</td>
                            <td>@item.CalYear</td>
                            <td>@item.YearWeek</td>
                            <td>@item.WkStDt?.ToString("yyyy-MM-dd")</td>
                            <td>@item.WkEndDt?.ToString("yyyy-MM-dd")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.WeekId" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.WeekId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#weekCalendarTable').DataTable({
                pageLength: 25,
                order: [[0, 'asc']]
            });
        });
    </script>
}
