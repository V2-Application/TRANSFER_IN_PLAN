@{ ViewData["Title"] = "Week Calendar Management"; }
@model IEnumerable<WeekCalendar>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Week Calendar</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Week
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="weekCalendarTable">
                <thead class="table-light">
                    <tr>
                        <th>Week ID</th>
                        <th>Week Seq</th>
                        <th>FY Week</th>
                        <th>FY Year</th>
                        <th>Cal Year</th>
                        <th>Year Week</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.WeekId</td>
                            <td>@item.WeekSeq</td>
                            <td>@item.FyWeek</td>
                            <td>@item.FyYear</td>
                            <td>@item.CalYear</td>
                            <td>@item.YearWeek</td>
                            <td>@item.WkStDt?.ToString("yyyy-MM-dd")</td>
                            <td>@item.WkEndDt?.ToString("yyyy-MM-dd")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.WeekId" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.WeekId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if (!$.fn.DataTable.isDataTable('#weekCalendarTable')) {
                $('#weekCalendarTable').DataTable({
                    pageLength: 25,
                    order: [[0, 'asc']],
                    language: {
                        search: "Search:",
                        lengthMenu: "Show _MENU_ entries",
                        info: "Showing _START_ to _END_ of _TOTAL_ entries",
                        emptyTable: "No week calendar data available"
                    }
                });
            }
        });
    </script>
}
