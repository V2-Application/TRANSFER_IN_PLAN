@{ ViewData["Title"] = "Delete DC Stock - Size"; }
@model TRANSFER_IN_PLAN.Models.SubDcStkSz
<h3 class="mb-3 text-danger"><i class="bi bi-trash me-2"></i>Delete DC Stock - Size</h3>
<div class="card shadow-sm border-0" style="max-width:500px;"><div class="card-body">
    <p>Are you sure you want to delete this record?</p>
    <dl class="row small mb-3"><dt class="col-5">RDC Code</dt><dd class="col-7">@Model.RdcCd</dd><dt class="col-5">Category</dt><dd class="col-7">@Model.MajCat</dd><dt class="col-5">Size</dt><dd class="col-7">@Model.SubValue</dd><dt class="col-5">DC Stock</dt><dd class="col-7">@Model.DcStkQ.ToString("N4")</dd><dt class="col-5">GRT Stock</dt><dd class="col-7">@Model.GrtStkQ.ToString("N4")</dd><dt class="col-5">W GRT Stock</dt><dd class="col-7">@Model.WGrtStkQ.ToString("N4")</dd></dl>
    <form asp-action="Delete" method="post"><input type="hidden" asp-for="Id" /><button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button> <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a></form>
</div></div>
