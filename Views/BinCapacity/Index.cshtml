@{ ViewData["Title"] = "Bin Capacity Management";
    ViewBag.Kpi2Label = "Categories"; ViewBag.Kpi2Value = ViewBag.TotalCategories; ViewBag.Kpi2Color = "#27ae60";
    ViewBag.Kpi3Label = "Avg Bin Cap"; ViewBag.Kpi3Value = ((decimal)(ViewBag.AvgBinCap ?? 0m)).ToString("N1"); ViewBag.Kpi3Color = "#8e44ad";
    ViewBag.Kpi4Label = "Avg DC Team"; ViewBag.Kpi4Value = ((decimal)(ViewBag.AvgDcTeam ?? 0m)).ToString("N1"); ViewBag.Kpi4Color = "#e67e22";
}
@model IEnumerable<BinCapacity>
@using System.Text.Json

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-box-seam me-2"></i>Bin Capacity</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Bin Capacity
    </a>
</div>

<partial name="_RefTableAnalytics" />

<div class="row g-2 mb-3">
    <div class="col-12 col-md-6">
        <div class="card shadow-sm border-0" style="height:220px;">
            <div class="card-header bg-white border-0 py-2"><h6 class="fw-bold mb-0 small"><i class="bi bi-bar-chart me-1 text-primary"></i>Bin Capacity by Category</h6></div>
            <div class="card-body pt-0"><canvas id="binChart" style="height:170px;"></canvas></div>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="card shadow-sm border-0" style="height:220px;">
            <div class="card-header bg-white border-0 py-2"><h6 class="fw-bold mb-0 small"><i class="bi bi-people me-1" style="color:#e67e22;"></i>DC Team Capacity by Category</h6></div>
            <div class="card-body pt-0"><canvas id="dcTeamChart" style="height:170px;"></canvas></div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.ErrorMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0" id="binCapacityTable">
                <thead class="table-dark">
                    <tr>
                        <th>Major Category</th>
                        <th class="text-end">Bin Cap DC Team</th>
                        <th class="text-end">Bin Capacity</th>
                        <th class="text-center">Actions</th>
                    </tr>
                    <tr class="filter-row">
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MajCat</td>
                            <td class="text-end">@item.BinCapDcTeam?.ToString("F2")</td>
                            <td class="text-end">@item.BinCap?.ToString("F2")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .filter-row th { background: #f8f9fa; padding: 4px 6px; }
    #binCapacityTable_wrapper .dt-layout-row:first-child { padding: 12px 12px 4px; }
    #binCapacityTable_wrapper .dt-layout-row:last-child  { padding: 4px 12px 12px; }
</style>
<script>
$(document).ready(function () {
    if ($.fn.DataTable.isDataTable('#binCapacityTable')) {
        $('#binCapacityTable').DataTable().destroy();
    }
    var table = $('#binCapacityTable').DataTable({
        pageLength: 25,
        lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'All']],
        order: [[0, 'asc']],
        autoWidth: false,
        language: {
            search: '<i class="bi bi-search"></i>',
            searchPlaceholder: 'Global search...',
            lengthMenu: 'Show _MENU_ rows',
            info: 'Showing _START_–_END_ of _TOTAL_ records',
            infoEmpty: 'No records',
            zeroRecords: 'No matching records found',
            paginate: { first: '«', last: '»', next: '›', previous: '‹' }
        },
        columnDefs: [{ orderable: false, targets: -1 }]
    });

    table.columns().every(function (i) {
        var col = this;
        var input = $($('.filter-row th')[i]).find('input');
        if (input.length) {
            input.on('keyup change clear', function () {
                if (col.search() !== this.value) col.search(this.value).draw();
            });
        }
    });
});
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
    var labels = @Html.Raw(JsonSerializer.Serialize(ViewBag.ChartLabels as List<string> ?? new List<string>()));
    var binCap = @Html.Raw(JsonSerializer.Serialize(ViewBag.ChartBinCap as List<decimal> ?? new List<decimal>()));
    var dcTeam = @Html.Raw(JsonSerializer.Serialize(ViewBag.ChartDcTeam as List<decimal> ?? new List<decimal>()));
    var opts = {responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{x:{ticks:{font:{size:10},maxRotation:45}},y:{beginAtZero:true,ticks:{font:{size:10}}}}};
    new Chart(document.getElementById('binChart'),{type:'bar',data:{labels:labels,datasets:[{label:'Bin Cap',data:binCap,backgroundColor:'rgba(41,128,185,0.75)',borderRadius:4}]},options:opts});
    new Chart(document.getElementById('dcTeamChart'),{type:'bar',data:{labels:labels,datasets:[{label:'DC Team',data:dcTeam,backgroundColor:'rgba(230,126,34,0.75)',borderRadius:4}]},options:opts});
})();
</script>
}
