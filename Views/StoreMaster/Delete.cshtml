@{
    ViewData["Title"] = "Delete Store Master";
}

@model StoreMaster

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">Confirm Delete</h5>
            </div>
            <div class="card-body">
                <p>Are you sure you want to delete this store?</p>
                <div class="mb-3">
                    <strong>Store Code:</strong> @Model.StCd
                </div>
                <div class="mb-3">
                    <strong>Store Name:</strong> @Model.StNm
                </div>
                <div class="mb-3">
                    <strong>RDC:</strong> @Model.RdcCd - @Model.RdcNm
                </div>

                <form asp-action="DeleteConfirmed" method="post" class="d-inline">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
