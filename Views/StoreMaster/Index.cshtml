@{ ViewData["Title"] = "Store Master Management"; }
@model IEnumerable<StoreMaster>
@using System.Text.Json

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-shop me-2"></i>Store Master</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Store
    </a>
</div>

@* ===== STORE ANALYTICS ===== *@
<div class="row g-2 mb-3">
    <div class="col-6 col-sm-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #2980b9 !important;">
            <div class="fw-bold fs-4" style="color:#2980b9;">@ViewBag.TotalStores</div>
            <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;font-weight:700;">Total Stores</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #27ae60 !important;">
            <div class="fw-bold fs-4 text-success">@ViewBag.NewCount</div>
            <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;font-weight:700;">NEW Stores</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #7f8c8d !important;">
            <div class="fw-bold fs-4 text-secondary">@ViewBag.OldCount</div>
            <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;font-weight:700;">OLD Stores</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #3498db !important;">
            <div class="fw-bold fs-4 text-info">@ViewBag.UpcCount</div>
            <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;font-weight:700;">UPC Stores</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #8e44ad !important;">
            <div class="fw-bold fs-4" style="color:#8e44ad;">@ViewBag.RdcCount</div>
            <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;font-weight:700;">RDCs</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-lg-2">
        <div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #e67e22 !important;">
            <div class="fw-bold fs-4" style="color:#e67e22;">@ViewBag.StateCount</div>
            <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;font-weight:700;">States</div>
        </div>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col-12 col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 py-2"><h6 class="fw-bold mb-0 small"><i class="bi bi-pie-chart me-1 text-primary"></i>Stores by Status</h6></div>
            <div class="card-body pt-0 d-flex align-items-center justify-content-center" style="height:220px;"><canvas id="statusChart"></canvas></div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 py-2"><h6 class="fw-bold mb-0 small"><i class="bi bi-building me-1" style="color:#8e44ad;"></i>Stores by RDC</h6></div>
            <div class="card-body pt-0" style="height:220px;"><canvas id="rdcChart"></canvas></div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 py-2"><h6 class="fw-bold mb-0 small"><i class="bi bi-geo-alt me-1 text-danger"></i>Stores by State (Top 15)</h6></div>
            <div class="card-body pt-0" style="height:220px;"><canvas id="stateChart"></canvas></div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.ErrorMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0" id="storeMasterTable">
                <thead class="table-dark">
                    <tr>
                        <th>Store Code</th>
                        <th>Store Name</th>
                        <th>RDC Code</th>
                        <th>RDC Name</th>
                        <th>Hub Code</th>
                        <th>Status</th>
                        <th>Area</th>
                        <th>State</th>
                        <th class="text-center">Actions</th>
                    </tr>
                    <tr class="filter-row">
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th>
                            <select class="form-select form-select-sm">
                                <option value="">All</option>
                                <option value="NEW">NEW</option>
                                <option value="OLD">OLD</option>
                                <option value="UPC">UPC</option>
                            </select>
                        </th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filter..."></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StCd</td>
                            <td>@item.StNm</td>
                            <td>@item.RdcCd</td>
                            <td>@item.RdcNm</td>
                            <td>@item.HubCd</td>
                            <td>
                                @switch (item.Status?.ToUpper())
                                {
                                    case "NEW":
                                        <span class="badge bg-success"><i class="bi bi-star-fill me-1"></i>NEW</span>
                                        break;
                                    case "OLD":
                                        <span class="badge bg-secondary"><i class="bi bi-archive me-1"></i>OLD</span>
                                        break;
                                    case "UPC":
                                        <span class="badge bg-info text-dark"><i class="bi bi-clock-history me-1"></i>UPC</span>
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">@(item.Status ?? "NA")</span>
                                        break;
                                }
                            </td>
                            <td>@item.Area</td>
                            <td>@item.State</td>
                            <td class="text-center text-nowrap">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .filter-row th { background: #f8f9fa; padding: 4px 6px; }
    .filter-row input, .filter-row select { min-width: 60px; }
    #storeMasterTable_wrapper .dt-layout-row:first-child { padding: 12px 12px 4px; }
    #storeMasterTable_wrapper .dt-layout-row:last-child  { padding: 4px 12px 12px; }
</style>
<script>
$(document).ready(function () {
    if ($.fn.DataTable.isDataTable('#storeMasterTable')) {
        $('#storeMasterTable').DataTable().destroy();
    }
    var table = $('#storeMasterTable').DataTable({
        pageLength: 25,
        lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'All']],
        order: [[0, 'asc']],
        autoWidth: false,
        language: {
            search: '<i class="bi bi-search"></i>',
            searchPlaceholder: 'Global search...',
            lengthMenu: 'Show _MENU_ rows',
            info: 'Showing _START_–_END_ of _TOTAL_ records',
            infoEmpty: 'No records',
            zeroRecords: 'No matching records found',
            paginate: { first: '«', last: '»', next: '›', previous: '‹' }
        },
        columnDefs: [{ orderable: false, targets: -1 }]
    });

    // Per-column filter (inputs + select for Status)
    table.columns().every(function (i) {
        var col = this;
        var cell = $($('.filter-row th')[i]);
        var input = cell.find('input');
        var sel   = cell.find('select');
        if (input.length) {
            input.on('keyup change clear', function () {
                if (col.search() !== this.value) col.search(this.value).draw();
            });
        }
        if (sel.length) {
            sel.on('change', function () {
                if (col.search() !== this.value) col.search(this.value).draw();
            });
        }
    });
});
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
    var statusLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.StatusLabels as List<string> ?? new List<string>()));
    var statusCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.StatusCounts as List<int> ?? new List<int>()));
    var rdcLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.RdcLabels as List<string> ?? new List<string>()));
    var rdcCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.RdcStoreCounts as List<int> ?? new List<int>()));
    var stateLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.StateLabels as List<string> ?? new List<string>()));
    var stateCounts = @Html.Raw(JsonSerializer.Serialize(ViewBag.StateStoreCounts as List<int> ?? new List<int>()));

    var statusColors = statusLabels.map(function(s){ return s==='NEW'?'#27ae60':s==='OLD'?'#95a5a6':s==='UPC'?'#3498db':'#bdc3c7'; });

    // 1. Status Doughnut
    new Chart(document.getElementById('statusChart'),{
        type:'doughnut',
        data:{ labels:statusLabels, datasets:[{ data:statusCounts, backgroundColor:statusColors, borderWidth:2, borderColor:'#fff' }] },
        options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ position:'bottom', labels:{ font:{size:11}, padding:12, usePointStyle:true } } }, cutout:'55%' }
    });

    // 2. RDC Bar
    new Chart(document.getElementById('rdcChart'),{
        type:'bar',
        data:{ labels:rdcLabels, datasets:[{ label:'Stores', data:rdcCounts, backgroundColor:'rgba(142,68,173,0.75)', borderRadius:4 }] },
        options:{ responsive:true, maintainAspectRatio:false, indexAxis:'y', plugins:{ legend:{display:false} }, scales:{ x:{beginAtZero:true, ticks:{font:{size:10}}}, y:{ticks:{font:{size:10}}} } }
    });

    // 3. State Bar
    new Chart(document.getElementById('stateChart'),{
        type:'bar',
        data:{ labels:stateLabels, datasets:[{ label:'Stores', data:stateCounts, backgroundColor:'rgba(231,76,60,0.7)', borderRadius:4 }] },
        options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false} }, scales:{ x:{ticks:{font:{size:9}, maxRotation:45}}, y:{beginAtZero:true, ticks:{font:{size:10}}} } }
    });
})();
</script>
}
