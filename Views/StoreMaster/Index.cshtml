@{ ViewData["Title"] = "Store Master Management"; }
@model IEnumerable<StoreMaster>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Store Master</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Store
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="storeMasterTable">
                <thead class="table-light">
                    <tr>
                        <th>Store Code</th>
                        <th>Store Name</th>
                        <th>RDC Code</th>
                        <th>RDC Name</th>
                        <th>Hub Code</th>
                        <th>Status</th>
                        <th>Area</th>
                        <th>State</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StCd</td>
                            <td>@item.StNm</td>
                            <td>@item.RdcCd</td>
                            <td>@item.RdcNm</td>
                            <td>@item.HubCd</td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                                }
                            </td>
                            <td>@item.Area</td>
                            <td>@item.State</td>
                            <td class="text-center">
                                @if (item.Status == "Active")
                                {
                                    <a asp-action="ToggleStatus" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning"
                                       title="Deactivate Store"
                                       onclick="return confirm('Deactivate store @item.StCd?')">
                                        <i class="bi bi-toggle-on"></i>
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="ToggleStatus" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-success"
                                       title="Activate Store"
                                       onclick="return confirm('Activate store @item.StCd?')">
                                        <i class="bi bi-toggle-off"></i>
                                    </a>
                                }
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if (!$.fn.DataTable.isDataTable('#storeMasterTable')) {
                $('#storeMasterTable').DataTable({
                    pageLength: 25,
                    order: [[0, 'asc']],
                    language: {
                        search: "Search:",
                        lengthMenu: "Show _MENU_ entries",
                        info: "Showing _START_ to _END_ of _TOTAL_ entries",
                        emptyTable: "No store master data available"
                    }
                });
            }
        });
    </script>
}
