@{
    ViewData["Title"] = "Edit Store Master";
}

@model StoreMaster

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Edit Store</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StCd" class="form-label">Store Code</label>
                            <input asp-for="StCd" class="form-control" />
                            <span asp-validation-for="StCd" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="StNm" class="form-label">Store Name</label>
                            <input asp-for="StNm" class="form-control" />
                            <span asp-validation-for="StNm" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="RdcCd" class="form-label">RDC Code</label>
                            <input asp-for="RdcCd" class="form-control" />
                            <span asp-validation-for="RdcCd" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="RdcNm" class="form-label">RDC Name</label>
                            <input asp-for="RdcNm" class="form-control" />
                            <span asp-validation-for="RdcNm" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="HubCd" class="form-label">Hub Code</label>
                            <input asp-for="HubCd" class="form-control" />
                            <span asp-validation-for="HubCd" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="HubNm" class="form-label">Hub Name</label>
                            <input asp-for="HubNm" class="form-control" />
                            <span asp-validation-for="HubNm" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="NEW">NEW</option>
                                <option value="OLD">OLD</option>
                                <option value="UPC">UPC</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Area" class="form-label">Area</label>
                            <input asp-for="Area" class="form-control" />
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="State" class="form-label">State</label>
                            <input asp-for="State" class="form-control" />
                            <span asp-validation-for="State" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="OpDate" class="form-label">Operation Date</label>
                            <input asp-for="OpDate" type="date" class="form-control" />
                            <span asp-validation-for="OpDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
