@{
    ViewData["Title"] = "Display Qty Management";
}

@model IEnumerable<DispQty>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Display Quantity Data</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Display Qty
    </a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-sm" id="dispQtyTable">
                <thead class="table-light">
                    <tr>
                        <th>Store Code</th>
                        <th>Major Category</th>
                        <th class="text-end">W1</th>
                        <th class="text-end">W2</th>
                        <th class="text-end">W3</th>
                        <th class="text-end">W4</th>
                        <th class="text-end">W5</th>
                        <th class="text-end">W6</th>
                        <th class="text-end">W7</th>
                        <th class="text-end">W8</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StCd</td>
                            <td>@item.MajCat</td>
                            <td class="text-end">@item.Wk1?.ToString("F2")</td>
                            <td class="text-end">@item.Wk2?.ToString("F2")</td>
                            <td class="text-end">@item.Wk3?.ToString("F2")</td>
                            <td class="text-end">@item.Wk4?.ToString("F2")</td>
                            <td class="text-end">@item.Wk5?.ToString("F2")</td>
                            <td class="text-end">@item.Wk6?.ToString("F2")</td>
                            <td class="text-end">@item.Wk7?.ToString("F2")</td>
                            <td class="text-end">@item.Wk8?.ToString("F2")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-stCd="@item.StCd" asp-route-majCat="@item.MajCat" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-stCd="@item.StCd" asp-route-majCat="@item.MajCat" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dispQtyTable').DataTable({
                pageLength: 25,
                scrollX: true,
                order: [[0, 'asc']]
            });
        });
    </script>
}
