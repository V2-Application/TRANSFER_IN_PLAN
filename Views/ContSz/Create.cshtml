@{ ViewData["Title"] = "Add Size Contribution"; }
@model TRANSFER_IN_PLAN.Models.ContSz
<h3 class="mb-3"><i class="bi bi-plus-circle me-2"></i>Add Size Contribution</h3>
<div class="card shadow-sm border-0" style="max-width:600px;"><div class="card-body">
    <form asp-action="Create" method="post">
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label fw-semibold">Store Code</label><input asp-for="StCd" class="form-control form-control-sm" required /></div>
            <div class="col-md-6"><label class="form-label fw-semibold">Category</label><input asp-for="MajCatCd" class="form-control form-control-sm" required /></div>
            <div class="col-md-6"><label class="form-label fw-semibold">Size</label><input asp-for="Sz" class="form-control form-control-sm" required /></div>
            <div class="col-md-6"><label class="form-label fw-semibold">CONT%</label><input asp-for="ContPct" class="form-control form-control-sm" type="number" step="0.0001" required /></div>
        </div>
        <div class="mt-3 d-flex gap-2"><button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-circle me-1"></i>Save</button><a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a></div>
    </form>
</div></div>
