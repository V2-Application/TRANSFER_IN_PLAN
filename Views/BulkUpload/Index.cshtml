@{
    ViewData["Title"] = "Bulk Upload";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3><i class="bi bi-cloud-upload me-2"></i>Bulk Upload</h3>
        <p class="text-muted mb-0">Upload Excel files to populate reference tables. Download a sample first to see the required format.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Upload Card -->
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-file-earmark-arrow-up me-2"></i>Upload Excel File</h5>
            </div>
            <div class="card-body">
                <form asp-action="Upload" asp-controller="BulkUpload" method="post" enctype="multipart/form-data" id="uploadForm">
                    @Html.AntiForgeryToken()

                    <!-- Table Selector -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Select Reference Table <span class="text-danger">*</span></label>
                        <select name="table" id="tableSelect" class="form-select form-select-lg search-select" required onchange="updateTableInfo(this.value)">
                            <option value="">-- Choose a table --</option>
                            <optgroup label="Master Tables">
                                <option value="WeekCalendar">Week Calendar</option>
                                <option value="StoreMaster">Store Master</option>
                                <option value="BinCapacity">Bin Capacity</option>
                                <option value="GrtContribution">GRT Contribution</option>
                                <option value="ProductHierarchy">Product Hierarchy</option>
                            </optgroup>
                            <optgroup label="Quantity Tables">
                                <option value="SaleQty">Sale Quantity</option>
                                <option value="DispQty">Display Quantity</option>
                                <option value="StoreStock">Store Stock</option>
                                <option value="DcStock">DC Stock</option>
                                <option value="DelPending">Delivery Pending</option>
                            </optgroup>
                            <optgroup label="Contribution Tables">
                                <option value="ContMacroMvgr">Macro MVGR Contribution</option>
                                <option value="ContSz">Size Contribution</option>
                                <option value="ContSeg">Segment Contribution</option>
                                <option value="ContVnd">Vendor Contribution</option>
                            </optgroup>
                            <optgroup label="Sub-Level Store Stock">
                                <option value="SubStStkMvgr">Store Stock MVGR</option>
                                <option value="SubStStkSz">Store Stock Size</option>
                                <option value="SubStStkSeg">Store Stock Segment</option>
                                <option value="SubStStkVnd">Store Stock Vendor</option>
                            </optgroup>
                            <optgroup label="Sub-Level DC Stock">
                                <option value="SubDcStkMvgr">DC Stock MVGR</option>
                                <option value="SubDcStkSz">DC Stock Size</option>
                                <option value="SubDcStkSeg">DC Stock Segment</option>
                                <option value="SubDcStkVnd">DC Stock Vendor</option>
                            </optgroup>
                        </select>
                    </div>

                    <!-- Table Info Banner -->
                    <div id="tableInfoBanner" class="alert alert-info d-none mb-3" role="alert">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-info-circle-fill me-2 mt-1"></i>
                            <div>
                                <strong id="tableInfoTitle"></strong>
                                <div id="tableInfoColumns" class="mt-1 small"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Upload Mode -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Upload Mode <span class="text-danger">*</span></label>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <div class="form-check border rounded p-3 h-100 mode-card" id="appendCard">
                                    <input class="form-check-input" type="radio" name="mode" id="modeAppend" value="Append" checked onchange="updateModeCard()">
                                    <label class="form-check-label w-100" for="modeAppend">
                                        <strong><i class="bi bi-plus-circle text-success me-1"></i>Append</strong>
                                        <p class="text-muted small mb-0 mt-1">Add new records to existing data. Existing records are kept.</p>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check border rounded p-3 h-100 mode-card" id="replaceCard">
                                    <input class="form-check-input" type="radio" name="mode" id="modeReplace" value="Replace" onchange="updateModeCard()">
                                    <label class="form-check-label w-100" for="modeReplace">
                                        <strong><i class="bi bi-arrow-repeat text-danger me-1"></i>Replace</strong>
                                        <p class="text-muted small mb-0 mt-1">Delete ALL existing records first, then insert from file.</p>
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div id="replaceWarning" class="alert alert-warning mt-2 d-none py-2">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Warning:</strong> Replace mode will permanently delete all existing records in the selected table before uploading.
                        </div>
                    </div>

                    <!-- File Upload -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Excel File <span class="text-danger">*</span></label>
                        <div class="upload-drop-zone border rounded p-4 text-center" id="dropZone">
                            <i class="bi bi-file-earmark-excel display-4 text-success"></i>
                            <p class="mt-2 mb-1 fw-semibold">Drag & drop your Excel file here</p>
                            <p class="text-muted small mb-3">or click to browse</p>
                            <input type="file" name="file" id="fileInput" class="form-control d-none" accept=".xlsx,.xls" required onchange="showFileName(this)">
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="document.getElementById('fileInput').click()">
                                <i class="bi bi-folder2-open me-1"></i>Browse File
                            </button>
                            <div id="selectedFile" class="mt-2 text-success d-none">
                                <i class="bi bi-file-earmark-check me-1"></i>
                                <span id="fileName"></span>
                            </div>
                        </div>
                        <div class="form-text">Supported formats: .xlsx, .xls | Row 1 must be the header row | Data starts from Row 2</div>
                    </div>

                    <!-- Submit -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="reset" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>Clear
                        </button>
                        <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                            <i class="bi bi-upload me-2"></i>Upload Now
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Panel: Tabbed Downloads -->
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white p-0">
                <ul class="nav nav-tabs card-header-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-semibold" id="dataTab" data-bs-toggle="tab" data-bs-target="#dataPane" type="button" role="tab">
                            <i class="bi bi-database-down me-1 text-primary"></i>Download Actual Data
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-semibold" id="sampleTab" data-bs-toggle="tab" data-bs-target="#samplePane" type="button" role="tab">
                            <i class="bi bi-file-earmark-excel me-1 text-success"></i>Sample Files
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body tab-content">
                <!-- Tab 1: Download Actual Data -->
                <div class="tab-pane fade show active" id="dataPane" role="tabpanel">
                    <p class="text-muted small mb-3">Download all rows from each reference table as CSV. Row counts refresh automatically.</p>
                    <div class="list-group list-group-flush" id="dataDownloadList">
                        @{
                            var tables = new[] {
                                ("WeekCalendar", "Week Calendar", "bi-calendar-week"),
                                ("StoreMaster",  "Store Master",  "bi-shop"),
                                ("BinCapacity",  "Bin Capacity",  "bi-box-seam"),
                                ("SaleQty",      "Sale Quantity", "bi-graph-up"),
                                ("DispQty",      "Display Qty",   "bi-display"),
                                ("StoreStock",   "Store Stock",   "bi-archive"),
                                ("DcStock",      "DC Stock",      "bi-building"),
                                ("DelPending",   "Delivery Pending","bi-truck"),
                                ("GrtContribution","GRT Contribution","bi-percent"),
                                ("ProductHierarchy","Product Hierarchy","bi-diagram-2"),
                                ("ContMacroMvgr","Macro MVGR Cont.","bi-pie-chart"),
                                ("ContSz","Size Cont.","bi-pie-chart"),
                                ("ContSeg","Segment Cont.","bi-pie-chart"),
                                ("ContVnd","Vendor Cont.","bi-pie-chart"),
                                ("SubStStkMvgr","St Stk MVGR","bi-boxes"),
                                ("SubStStkSz","St Stk Size","bi-boxes"),
                                ("SubStStkSeg","St Stk Seg","bi-boxes"),
                                ("SubStStkVnd","St Stk Vnd","bi-boxes"),
                                ("SubDcStkMvgr","DC Stk MVGR","bi-building"),
                                ("SubDcStkSz","DC Stk Size","bi-building"),
                                ("SubDcStkSeg","DC Stk Seg","bi-building"),
                                ("SubDcStkVnd","DC Stk Vnd","bi-building")
                            };
                            foreach (var (key, label, icon) in tables)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                                    <div>
                                        <i class="bi @icon text-primary me-2"></i>
                                        <span class="fw-semibold">@label</span>
                                        <span class="badge bg-light text-dark ms-2" id="count_@key">
                                            <span class="spinner-border spinner-border-sm" style="width:0.7rem;height:0.7rem;"></span>
                                        </span>
                                    </div>
                                    <a href="/BulkUpload/DownloadData?table=@key" class="btn btn-sm btn-outline-primary py-0 px-2" id="dlBtn_@key">
                                        <i class="bi bi-filetype-csv me-1"></i>CSV
                                    </a>
                                </div>
                            }
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <small class="text-muted" id="countStatus">Loading row counts...</small>
                        <button class="btn btn-sm btn-outline-secondary py-0" onclick="loadTableCounts()">
                            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                        </button>
                    </div>
                </div>

                <!-- Tab 2: Sample Files -->
                <div class="tab-pane fade" id="samplePane" role="tabpanel">
                    <p class="text-muted small mb-3">Download a sample Excel with the correct column headers and a sample data row for each reference table.</p>
                    <div class="list-group list-group-flush">
                        @{
                            var sampleTables = new[] {
                                ("WeekCalendar", "Week Calendar", "bi-calendar-week", "8 columns"),
                                ("StoreMaster",  "Store Master",  "bi-shop",          "18 columns"),
                                ("BinCapacity",  "Bin Capacity",  "bi-box-seam",      "3 columns"),
                                ("SaleQty",      "Sale Quantity", "bi-graph-up",      "51 columns (WK-1 to WK-48)"),
                                ("DispQty",      "Display Qty",   "bi-display",       "51 columns (WK-1 to WK-48)"),
                                ("StoreStock",   "Store Stock",   "bi-archive",       "4 columns"),
                                ("DcStock",      "DC Stock",      "bi-building",      "7 columns"),
                                ("DelPending",   "Delivery Pending","bi-truck",       "4 columns"),
                                ("GrtContribution","GRT Contribution","bi-percent",  "49 columns (SSN + WK-1 to WK-48)"),
                                ("ProductHierarchy","Product Hierarchy","bi-diagram-2","5 columns"),
                                ("ContMacroMvgr","Macro MVGR Cont.","bi-pie-chart","4 columns"),
                                ("ContSz","Size Cont.","bi-pie-chart","4 columns"),
                                ("ContSeg","Segment Cont.","bi-pie-chart","4 columns"),
                                ("ContVnd","Vendor Cont.","bi-pie-chart","4 columns"),
                                ("SubStStkMvgr","St Stk MVGR","bi-boxes","5 columns"),
                                ("SubStStkSz","St Stk Size","bi-boxes","5 columns"),
                                ("SubStStkSeg","St Stk Seg","bi-boxes","5 columns"),
                                ("SubStStkVnd","St Stk Vnd","bi-boxes","5 columns"),
                                ("SubDcStkMvgr","DC Stk MVGR","bi-building","7 columns"),
                                ("SubDcStkSz","DC Stk Size","bi-building","7 columns"),
                                ("SubDcStkSeg","DC Stk Seg","bi-building","7 columns"),
                                ("SubDcStkVnd","DC Stk Vnd","bi-building","7 columns")
                            };
                            foreach (var (key, label, icon, cols) in sampleTables)
                            {
                                <a href="/BulkUpload/DownloadSample?table=@key"
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                                    <div>
                                        <i class="bi @icon text-primary me-2"></i>
                                        <span class="fw-semibold">@label</span>
                                        <small class="text-muted ms-2">@cols</small>
                                    </div>
                                    <span class="badge bg-success rounded-pill">
                                        <i class="bi bi-download me-1"></i>Download
                                    </span>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Table Info Reference -->
<div class="card mt-4 shadow-sm">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-table me-2"></i>Column Reference Guide</h5>
    </div>
    <div class="card-body">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3" id="columnGuide">
            <div class="col">
                <div class="card border-primary h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-primary"><i class="bi bi-calendar-week me-1"></i>Week Calendar</h6>
                        <small class="text-muted">WeekId, WeekSeq, FyWeek, FyYear, CalYear, YearWeek, WkStDt, WkEndDt</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-success h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-success"><i class="bi bi-shop me-1"></i>Store Master</h6>
                        <small class="text-muted">StCd, StNm, RdcCd, RdcNm, HubCd, HubNm, Status, GridStSts, OpDate, Area, State, RefState, SaleGrp, RefStCd, RefStNm, RefGrpNew, RefGrpOld, Date</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-warning h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-warning"><i class="bi bi-box-seam me-1"></i>Bin Capacity</h6>
                        <small class="text-muted">MajCat, BinCapDcTeam, BinCap</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-info h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-info"><i class="bi bi-graph-up me-1"></i>Sale / Display Qty</h6>
                        <small class="text-muted">StCd, MajCat, WK-1 to WK-48, Col2</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-secondary h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-secondary"><i class="bi bi-archive me-1"></i>Store Stock</h6>
                        <small class="text-muted">StCd, MajCat, StkQty, Date</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-dark h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title"><i class="bi bi-building me-1"></i>DC Stock</h6>
                        <small class="text-muted">RdcCd, Rdc, MajCat, DcStkQ, GrtStkQ, WGrtStkQ, Date</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-danger h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-danger"><i class="bi bi-truck me-1"></i>Delivery Pending</h6>
                        <small class="text-muted">RdcCd, MajCat, DelPendQ, Date</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-primary h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-primary"><i class="bi bi-percent me-1"></i>GRT Contribution</h6>
                        <small class="text-muted">SSN, WK-1 to WK-48</small>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-success h-100">
                    <div class="card-body p-3">
                        <h6 class="card-title text-success"><i class="bi bi-diagram-2 me-1"></i>Product Hierarchy</h6>
                        <small class="text-muted">Seg, Div, SubDiv, MajCatNm, Ssn</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .upload-drop-zone {
        cursor: pointer;
        transition: all 0.2s ease;
        background: #f8f9fa;
    }
    .upload-drop-zone:hover, .upload-drop-zone.dragover {
        background: #e8f4fd;
        border-color: #0d6efd !important;
    }
    .mode-card { cursor: pointer; transition: all 0.2s; }
    .mode-card.active { border-color: #0d6efd !important; background: #f0f7ff; }
    #replaceCard.active { border-color: #dc3545 !important; background: #fff5f5; }
</style>
<script>
    const tableInfo = {
        'WeekCalendar': { title: 'Week Calendar (8 columns)', cols: 'WeekId | WeekSeq | FyWeek | FyYear | CalYear | YearWeek | WkStDt (yyyy-MM-dd) | WkEndDt (yyyy-MM-dd)' },
        'StoreMaster':  { title: 'Store Master (18 columns)', cols: 'StCd | StNm | RdcCd | RdcNm | HubCd | HubNm | Status | GridStSts | OpDate | Area | State | RefState | SaleGrp | RefStCd | RefStNm | RefGrpNew | RefGrpOld | Date' },
        'BinCapacity':  { title: 'Bin Capacity (3 columns)',  cols: 'MajCat | BinCapDcTeam | BinCap' },
        'SaleQty':      { title: 'Sale Quantity (51 columns)', cols: 'StCd | MajCat | WK-1 to WK-48 | Col2' },
        'DispQty':      { title: 'Display Quantity (51 columns)', cols: 'StCd | MajCat | WK-1 to WK-48 | Col2' },
        'StoreStock':   { title: 'Store Stock (4 columns)',   cols: 'StCd | MajCat | StkQty | Date (yyyy-MM-dd)' },
        'DcStock':      { title: 'DC Stock (7 columns)',      cols: 'RdcCd | Rdc | MajCat | DcStkQ | GrtStkQ | WGrtStkQ | Date (yyyy-MM-dd)' },
        'DelPending':   { title: 'Delivery Pending (4 columns)', cols: 'RdcCd | MajCat | DelPendQ | Date (yyyy-MM-dd)' },
        'GrtContribution': { title: 'GRT Contribution (49 columns)', cols: 'SSN | WK-1 to WK-48' },
        'ProductHierarchy': { title: 'Product Hierarchy (5 columns)', cols: 'Seg | Div | SubDiv | MajCatNm | Ssn' },
        'ContMacroMvgr': { title: 'Macro MVGR Contribution (4 columns)', cols: 'StCd | MajCatCd | DispMvgrMatrix | ContPct' },
        'ContSz': { title: 'Size Contribution (4 columns)', cols: 'StCd | MajCatCd | Sz | ContPct' },
        'ContSeg': { title: 'Segment Contribution (4 columns)', cols: 'StCd | MajCatCd | Seg | ContPct' },
        'ContVnd': { title: 'Vendor Contribution (4 columns)', cols: 'StCd | MajCatCd | MVndCd | ContPct' },
        'SubStStkMvgr': { title: 'Store Stock MVGR (5 cols)', cols: 'StCd | MajCat | SubValue | StkQty | Date' },
        'SubStStkSz': { title: 'Store Stock Size (5 cols)', cols: 'StCd | MajCat | SubValue | StkQty | Date' },
        'SubStStkSeg': { title: 'Store Stock Segment (5 cols)', cols: 'StCd | MajCat | SubValue | StkQty | Date' },
        'SubStStkVnd': { title: 'Store Stock Vendor (5 cols)', cols: 'StCd | MajCat | SubValue | StkQty | Date' },
        'SubDcStkMvgr': { title: 'DC Stock MVGR (7 cols)', cols: 'RdcCd | MajCat | SubValue | DcStkQ | GrtStkQ | WGrtStkQ | Date' },
        'SubDcStkSz': { title: 'DC Stock Size (7 cols)', cols: 'RdcCd | MajCat | SubValue | DcStkQ | GrtStkQ | WGrtStkQ | Date' },
        'SubDcStkSeg': { title: 'DC Stock Segment (7 cols)', cols: 'RdcCd | MajCat | SubValue | DcStkQ | GrtStkQ | WGrtStkQ | Date' },
        'SubDcStkVnd': { title: 'DC Stock Vendor (7 cols)', cols: 'RdcCd | MajCat | SubValue | DcStkQ | GrtStkQ | WGrtStkQ | Date' }
    };

    function updateTableInfo(val) {
        const banner = document.getElementById('tableInfoBanner');
        if (!val || !tableInfo[val]) { banner.classList.add('d-none'); return; }
        banner.classList.remove('d-none');
        document.getElementById('tableInfoTitle').textContent = tableInfo[val].title;
        document.getElementById('tableInfoColumns').textContent = tableInfo[val].cols;
    }

    function updateModeCard() {
        const appendChecked = document.getElementById('modeAppend').checked;
        document.getElementById('appendCard').classList.toggle('active', appendChecked);
        document.getElementById('replaceCard').classList.toggle('active', !appendChecked);
        document.getElementById('replaceWarning').classList.toggle('d-none', appendChecked);
    }

    function showFileName(input) {
        if (input.files && input.files[0]) {
            document.getElementById('fileName').textContent = input.files[0].name + ' (' + (input.files[0].size / 1024).toFixed(1) + ' KB)';
            document.getElementById('selectedFile').classList.remove('d-none');
        }
    }

    // Drop zone
    const dropZone = document.getElementById('dropZone');
    dropZone.addEventListener('click', () => document.getElementById('fileInput').click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
    dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        const dt = e.dataTransfer;
        if (dt.files.length) {
            document.getElementById('fileInput').files = dt.files;
            showFileName(document.getElementById('fileInput'));
        }
    });

    // Confirm replace
    document.getElementById('uploadForm').addEventListener('submit', function(e) {
        const mode = document.querySelector('input[name="mode"]:checked')?.value;
        const table = document.getElementById('tableSelect').value;
        if (!table) { e.preventDefault(); alert('Please select a reference table.'); return; }
        if (!document.getElementById('fileInput').files.length) { e.preventDefault(); alert('Please select an Excel file.'); return; }
        if (mode === 'Replace') {
            if (!confirm('WARNING: Replace mode will DELETE ALL existing records in ' + table + ' before uploading.\n\nAre you sure you want to continue?')) {
                e.preventDefault(); return;
            }
        }
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('submitBtn').innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Uploading...';
    });

    // Init
    updateModeCard();

    // Load table row counts
    function loadTableCounts() {
        document.getElementById('countStatus').textContent = 'Loading row counts...';
        fetch('/BulkUpload/TableCounts')
            .then(r => r.json())
            .then(data => {
                let total = 0;
                for (const [key, count] of Object.entries(data)) {
                    const el = document.getElementById('count_' + key);
                    if (el) {
                        el.innerHTML = Number(count).toLocaleString() + ' rows';
                        el.className = count > 0
                            ? 'badge bg-primary bg-opacity-10 text-primary ms-2'
                            : 'badge bg-light text-muted ms-2';
                    }
                    // Disable download if 0 rows
                    const btn = document.getElementById('dlBtn_' + key);
                    if (btn) {
                        if (count === 0) {
                            btn.classList.add('disabled');
                            btn.setAttribute('tabindex', '-1');
                        } else {
                            btn.classList.remove('disabled');
                            btn.removeAttribute('tabindex');
                        }
                    }
                    total += count;
                }
                document.getElementById('countStatus').textContent = 'Total: ' + total.toLocaleString() + ' rows across all tables';
            })
            .catch(() => {
                document.getElementById('countStatus').textContent = 'Failed to load counts';
            });
    }
    loadTableCounts();
</script>
}
