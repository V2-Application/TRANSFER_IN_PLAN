@{ ViewData["Title"] = "Delete Article Auto Sale"; }
@model TRANSFER_IN_PLAN.Models.ArsStArtAutoSale
<h4 class="mb-3 text-danger"><i class="bi bi-trash me-2"></i>Delete Article Auto Sale Record</h4>
<div class="card shadow-sm border-0" style="max-width:600px;"><div class="card-body">
<p>Are you sure you want to delete this record?</p>
<dl class="row small">
    <dt class="col-4">Store</dt><dd class="col-8">@Model.St</dd>
    <dt class="col-4">GEN-ART</dt><dd class="col-8">@Model.GenArt</dd>
    <dt class="col-4">Color</dt><dd class="col-8">@Model.Clr</dd>
    <dt class="col-4">CM Auto Sale</dt><dd class="col-8">@Model.CmAutoSaleQ</dd>
    <dt class="col-4">NM Auto Sale</dt><dd class="col-8">@Model.NmAutoSaleQ</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
</div></div>
