@{ ViewData["Title"] = "Add MJ Auto Sale"; }
@model TRANSFER_IN_PLAN.Models.ArsStMjAutoSale
<h4 class="mb-3"><i class="bi bi-plus-circle me-2"></i>Add MJ Auto Sale Record</h4>
<div class="card shadow-sm border-0" style="max-width:700px;"><div class="card-body">
<form asp-action="Create" method="post">
    <div class="row g-3">
        <div class="col-md-6"><label class="form-label fw-semibold">Store Code</label><input asp-for="St" class="form-control" required /></div>
        <div class="col-md-6"><label class="form-label fw-semibold">Major Category</label><input asp-for="Mj" class="form-control" required /></div>
        <div class="col-md-6"><label class="form-label fw-semibold">CM Rem Days</label><input asp-for="CmRemDays" class="form-control" type="number" step="0.0001" /></div>
        <div class="col-md-6"><label class="form-label fw-semibold">NM Days</label><input asp-for="NmDays" class="form-control" type="number" step="0.0001" /></div>
        <div class="col-md-6"><label class="form-label fw-semibold">CM Auto Sale Q</label><input asp-for="CmAutoSaleQ" class="form-control" type="number" step="0.0001" /></div>
        <div class="col-md-6"><label class="form-label fw-semibold">NM Auto Sale Q</label><input asp-for="NmAutoSaleQ" class="form-control" type="number" step="0.0001" /></div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Save</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>
</div></div>
