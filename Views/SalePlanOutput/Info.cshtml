@{ ViewData["Title"] = "Sale Plan — Algorithm Reference"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-0"><i class="bi bi-info-circle me-2" style="color:#7c3aed;"></i>Sale Plan — Algorithm Reference</h3>
        <small class="text-muted">Complete logic for every metric and reference column</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back to Output</a>
</div>

<!-- Nav Tabs -->
<ul class="nav nav-tabs mb-3" role="tablist" style="font-size:0.82rem;">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabOverview">Overview</a></li>
