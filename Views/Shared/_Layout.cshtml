<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Transfer In Plan</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="apple-touch-icon" href="~/favicon.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ── Mobile Top Navbar (visible only on xs/sm) ──────────────── -->
<nav class="d-flex d-md-none align-items-center justify-content-between px-3 py-2 mobile-topbar">
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-light" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar">
            <i class="bi bi-list fs-5"></i>
        </button>
        <span class="text-white fw-bold small"><img src="~/favicon.png" alt="V2" style="height:22px;margin-right:6px;vertical-align:middle;">Transfer In Plan</span>
    </div>
    <span class="text-white-50 small">@ViewData["Title"]</span>
</nav>

<!-- ── Offcanvas Sidebar for Mobile ───────────────────────────── -->
<div class="offcanvas offcanvas-start sidebar-offcanvas" tabindex="-1" id="mobileSidebar">
    <div class="offcanvas-header border-bottom border-white border-opacity-10">
        <div>
            <h6 class="text-white fw-bold mb-0"><img src="~/favicon.png" alt="V2" style="height:22px;margin-right:6px;vertical-align:middle;">Transfer In Plan</h6>
            <small class="text-white-50">Management System</small>
        </div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-0 pt-2">
        <ul class="nav flex-column px-2">
            <!-- ═══ PLANNING ═══ -->
            <li class="nav-item">
                <a class="nav-link dropdown-toggle fw-bold" href="#mPlanningMenu" data-bs-toggle="collapse" role="button">
                    <i class="bi bi-kanban" style="color:#4F46E5;"></i> Planning
                </a>
                <ul class="collapse show list-unstyled ms-2" id="mPlanningMenu">
                    <li><a class="nav-link" asp-controller="Home" asp-action="Index" data-bs-dismiss="offcanvas"><i class="bi bi-speedometer2 me-1"></i>Operations Dashboard</a></li>
                    <li><a class="nav-link" asp-controller="PlanDashboard" asp-action="Index" data-bs-dismiss="offcanvas"><i class="bi bi-diagram-3 me-1" style="color:#8B5CF6;"></i>Pipeline Dashboard</a></li>
                    <li>
                        <a class="nav-link dropdown-toggle" href="#mRefTablesMenu" data-bs-toggle="collapse" role="button"><i class="bi bi-table me-1"></i>Reference Tables</a>
                        <ul class="collapse list-unstyled ms-3" id="mRefTablesMenu">
                            <li><a class="nav-link" asp-controller="WeekCalendar" asp-action="Index" data-bs-dismiss="offcanvas">Week Calendar</a></li>
                            <li><a class="nav-link" asp-controller="StoreMaster" asp-action="Index" data-bs-dismiss="offcanvas">Store Master</a></li>
                            <li><a class="nav-link" asp-controller="BinCapacity" asp-action="Index" data-bs-dismiss="offcanvas">Bin Capacity</a></li>
                            <li><a class="nav-link" asp-controller="SaleQty" asp-action="Index" data-bs-dismiss="offcanvas">Sale Quantity</a></li>
                            <li><a class="nav-link" asp-controller="DispQty" asp-action="Index" data-bs-dismiss="offcanvas">Display Qty</a></li>
                            <li><a class="nav-link" asp-controller="StoreStock" asp-action="Index" data-bs-dismiss="offcanvas">Store Stock</a></li>
                            <li><a class="nav-link" asp-controller="DcStock" asp-action="Index" data-bs-dismiss="offcanvas">DC Stock</a></li>
                            <li><a class="nav-link" asp-controller="DelPending" asp-action="Index" data-bs-dismiss="offcanvas">Del Pending</a></li>
                            <li><a class="nav-link" asp-controller="GrtContribution" asp-action="Index" data-bs-dismiss="offcanvas">GRT Contribution</a></li>
                            <li><a class="nav-link" asp-controller="ProductHierarchy" asp-action="Index" data-bs-dismiss="offcanvas">Product Hierarchy</a></li>
                        </ul>
                    </li>
                    <li>
                        <a class="nav-link dropdown-toggle" href="#mContMenu" data-bs-toggle="collapse" role="button"><i class="bi bi-pie-chart me-1"></i>Contribution</a>
                        <ul class="collapse list-unstyled ms-3" id="mContMenu">
                            <li><a class="nav-link" asp-controller="ContMacroMvgr" asp-action="Index" data-bs-dismiss="offcanvas">Macro MVGR</a></li>
                            <li><a class="nav-link" asp-controller="ContSz" asp-action="Index" data-bs-dismiss="offcanvas">Size</a></li>
                            <li><a class="nav-link" asp-controller="ContSeg" asp-action="Index" data-bs-dismiss="offcanvas">Segment</a></li>
                            <li><a class="nav-link" asp-controller="ContVnd" asp-action="Index" data-bs-dismiss="offcanvas">Vendor</a></li>
                            <li class="border-top border-white border-opacity-10 mt-1 pt-1 small text-white-50 px-3">Sub Store Stock</li>
                            <li><a class="nav-link" asp-controller="SubStStkMvgr" asp-action="Index" data-bs-dismiss="offcanvas">St Stk MVGR</a></li>
                            <li><a class="nav-link" asp-controller="SubStStkSz" asp-action="Index" data-bs-dismiss="offcanvas">St Stk Size</a></li>
                            <li><a class="nav-link" asp-controller="SubStStkSeg" asp-action="Index" data-bs-dismiss="offcanvas">St Stk Segment</a></li>
                            <li><a class="nav-link" asp-controller="SubStStkVnd" asp-action="Index" data-bs-dismiss="offcanvas">St Stk Vendor</a></li>
                            <li class="small text-white-50 px-3">Sub DC Stock</li>
                            <li><a class="nav-link" asp-controller="SubDcStkMvgr" asp-action="Index" data-bs-dismiss="offcanvas">DC Stk MVGR</a></li>
                            <li><a class="nav-link" asp-controller="SubDcStkSz" asp-action="Index" data-bs-dismiss="offcanvas">DC Stk Size</a></li>
                            <li><a class="nav-link" asp-controller="SubDcStkSeg" asp-action="Index" data-bs-dismiss="offcanvas">DC Stk Segment</a></li>
                            <li><a class="nav-link" asp-controller="SubDcStkVnd" asp-action="Index" data-bs-dismiss="offcanvas">DC Stk Vendor</a></li>
                        </ul>
                    </li>
                    <li><a class="nav-link" asp-controller="BulkUpload" asp-action="Index" data-bs-dismiss="offcanvas"><i class="bi bi-upload me-1"></i>Bulk Upload</a></li>
                    <li>
                        <a class="nav-link dropdown-toggle" href="#mPlanMgmtMenu" data-bs-toggle="collapse" role="button"><i class="bi bi-lightning me-1"></i>Plan Management</a>
