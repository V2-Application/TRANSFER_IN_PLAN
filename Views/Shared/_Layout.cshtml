    var path = window.location.pathname.toLowerCase();
    var refTables = ['weekcalendar','storemaster','bincapacity','saleqty','dispqty','storestock','dcstock','delpending','grtcontribution','producthierarchy'];
    var contPages = ['contmacromvgr','contsz','contseg','contvnd','subststkmvgr','subststksz','subststkseg','subststkvnd','subdcstkmvgr','subdcstksz','subdcstkseg','subdcstkvnd'];
    var planPages = ['plan/execute','plan/output','purchaseplan/execute','purchaseplan/output','sublevel/execute','sublevel/trfoutput','sublevel/ppoutput'];
    var isRef = refTables.some(function(t){ return path.indexOf('/'+t) !== -1; });
    var isCont = contPages.some(function(t){ return path.indexOf('/'+t) !== -1; });
    var isPlan = planPages.some(function(t){ return path.toLowerCase().indexOf('/'+t.toLowerCase()) !== -1; });
    var isRfc = rfcPages.some(function(t){ return path.toLowerCase().indexOf('/'+t.toLowerCase()) !== -1; });
    // Desktop sidebar
    if(isRef){ var el=document.getElementById('refTablesMenu'); if(el) el.classList.add('show'); }
    if(isCont){ var el=document.getElementById('contMenu'); if(el) el.classList.add('show'); }
    if(isPlan){ var el=document.getElementById('planMenu'); if(el) el.classList.add('show'); }
    // Mobile sidebar
    if(isRef){ var el=document.getElementById('mRefTablesMenu'); if(el) el.classList.add('show'); }
    if(isCont){ var el=document.getElementById('mContMenu'); if(el) el.classList.add('show'); }
    if(isPlan){ var el=document.getElementById('mPlanMenu'); if(el) el.classList.add('show'); }
    // Mark active link - match current path or any sub-path (e.g. /SaleQty/Create matches /SaleQty)
    document.querySelectorAll('.sidebar .nav-link, .sidebar-offcanvas .nav-link').forEach(function(link){
        var href = link.getAttribute('href');
        if(!href || href === '#' || href.indexOf('#') !== -1) return;
        var hrefLow = href.toLowerCase().replace(/\/$/,'');
        if(path === hrefLow || (hrefLow !== '/' && path.indexOf(hrefLow) === 0)) link.classList.add('active');
    });
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
