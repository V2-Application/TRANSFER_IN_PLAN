                            <li><a class="nav-link" asp-controller="Plan" asp-action="Execute" data-bs-dismiss="offcanvas">Execute Plan</a></li>
                            <li><a class="nav-link" asp-controller="Plan" asp-action="Output" data-bs-dismiss="offcanvas">View Output</a></li>
                            <li><a class="nav-link" asp-controller="PurchasePlan" asp-action="Execute" data-bs-dismiss="offcanvas">Purchase Plan</a></li>
                            <li><a class="nav-link" asp-controller="PurchasePlan" asp-action="Output" data-bs-dismiss="offcanvas">Purchase Output</a></li>
                            <li class="border-top border-white border-opacity-10 mt-1 pt-1"><a class="nav-link" asp-controller="SubLevel" asp-action="Execute" data-bs-dismiss="offcanvas">Sub-Level Plans</a></li>
                        </ul>
                    </li>
                </ul>
            </li>
            <!-- ═══ ALLOCATION ═══ -->
            <li class="nav-item border-top border-white border-opacity-10 mt-1 pt-1">
                <a class="nav-link dropdown-toggle fw-bold" href="#mAllocMenu" data-bs-toggle="collapse" role="button">
                    <i class="bi bi-boxes" style="color:#E67E22;"></i> Allocation
                </a>
                <ul class="collapse list-unstyled ms-2" id="mAllocMenu">
                    <li><a class="nav-link" asp-controller="ArsAllocation" asp-action="Execute" data-bs-dismiss="offcanvas"><i class="bi bi-play-circle me-1 text-success"></i>Execute Allocation</a></li>
                    <li><a class="nav-link" asp-controller="ArsAllocation" asp-action="Output" data-bs-dismiss="offcanvas"><i class="bi bi-table me-1"></i>Allocation Output</a></li>
                    <li><a class="nav-link" asp-controller="ArsBulkUpload" asp-action="Index" data-bs-dismiss="offcanvas"><i class="bi bi-upload me-1"></i>Bulk Upload</a></li>
                    <li class="border-top border-white border-opacity-10 mt-1 pt-1"><a class="nav-link" asp-controller="ArsDisplayMaster" asp-action="Index" data-bs-dismiss="offcanvas">Display Master</a></li>
                    <li><a class="nav-link" asp-controller="ArsAutoSale" asp-action="Index" data-bs-dismiss="offcanvas">MJ Auto Sale</a></li>
                    <li><a class="nav-link" asp-controller="ArsArtAutoSale" asp-action="Index" data-bs-dismiss="offcanvas">Article Auto Sale</a></li>
                    <li><a class="nav-link" asp-controller="ArsHoldDays" asp-action="Index" data-bs-dismiss="offcanvas">Hold Days Master</a></li>
                    <li><a class="nav-link" asp-controller="ArsStMaster" asp-action="Index" data-bs-dismiss="offcanvas">Store Master</a></li>
                    <li class="border-top border-white border-opacity-10 mt-1 pt-1"><a class="nav-link" asp-controller="ArsStockData" asp-action="Index" data-bs-dismiss="offcanvas"><i class="bi bi-boxes me-1"></i>Store Stock (SAP)</a></li>
                    <li><a class="nav-link" asp-controller="ArsMsaStock" asp-action="Index" data-bs-dismiss="offcanvas"><i class="bi bi-box-seam me-1"></i>MSA Stock (SAP)</a></li>
                </ul>
            </li>
            <!-- ═══ SALE BUDGET ═══ -->
            <li class="nav-item border-top border-white border-opacity-10 mt-1 pt-1">
                <a class="nav-link dropdown-toggle" href="#mBudgetMenu" data-bs-toggle="collapse" role="button">
                    <i class="bi bi-coin" style="color:#8B5CF6;"></i> Sale Budget Plan
                </a>
                <ul class="collapse list-unstyled ms-3" id="mBudgetMenu">
                    <li><a class="nav-link" asp-controller="SaleBudget" asp-action="Execute" data-bs-dismiss="offcanvas">Execute Budget</a></li>
                    <li><a class="nav-link" asp-controller="SaleBudget" asp-action="Output" data-bs-dismiss="offcanvas">Budget Output</a></li>
                    <li class="border-top border-white border-opacity-10 mt-1 pt-1"><a class="nav-link" asp-controller="FixtureDensity" asp-action="Execute" data-bs-dismiss="offcanvas"><i class="bi bi-grid-3x3-gap me-1" style="color:#E67E22;"></i>Fixture & Density</a></li>
                    <li><a class="nav-link" asp-controller="WeeklyDisagg" asp-action="Execute" data-bs-dismiss="offcanvas"><i class="bi bi-calendar3 me-1 text-info"></i>Weekly Disagg</a></li>
                </ul>
            </li>
            <!-- ═══ INFO & ADMIN ═══ -->
            <li class="nav-item border-top border-white border-opacity-10 mt-1 pt-1">
                <a class="nav-link" asp-controller="Info" asp-action="Index" data-bs-dismiss="offcanvas">
                    <i class="bi bi-info-circle"></i> App Info & Formulas
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="PlanInfo" asp-action="Index" data-bs-dismiss="offcanvas">
                    <i class="bi bi-book" style="color:#8B5CF6;"></i> Pipeline Info
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="AdminConsole" asp-action="Index" data-bs-dismiss="offcanvas">
                    <i class="bi bi-terminal"></i> Admin Console
                </a>
            </li>
        </ul>
    </div>
</div>

<!-- ── Desktop Layout ─────────────────────────────────────────── -->
<div class="d-flex">

    <!-- Desktop Sidebar (hidden below md) -->
    <nav class="sidebar d-none d-md-block" id="desktopSidebar">
        <div class="sidebar-header">
