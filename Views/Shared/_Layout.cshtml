                        <ul class="collapse list-unstyled ms-3" id="contMenu">
                            <li><a class="nav-link" asp-controller="ContMacroMvgr" asp-action="Index">Macro MVGR</a></li>
                            <li><a class="nav-link" asp-controller="ContSz" asp-action="Index">Size</a></li>
                            <li><a class="nav-link" asp-controller="ContSeg" asp-action="Index">Segment</a></li>
                            <li><a class="nav-link" asp-controller="ContVnd" asp-action="Index">Vendor</a></li>
                            <li class="border-top border-white border-opacity-10 mt-1 pt-1 small text-white-50 px-3">Sub Store Stock</li>
                            <li><a class="nav-link" asp-controller="SubStStkMvgr" asp-action="Index">St Stk MVGR</a></li>
                            <li><a class="nav-link" asp-controller="SubStStkSz" asp-action="Index">St Stk Size</a></li>
                            <li><a class="nav-link" asp-controller="SubStStkSeg" asp-action="Index">St Stk Segment</a></li>
                            <li><a class="nav-link" asp-controller="SubStStkVnd" asp-action="Index">St Stk Vendor</a></li>
