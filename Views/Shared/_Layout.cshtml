<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Transfer In Plan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ── Mobile Top Navbar (visible only on xs/sm) ──────────────── -->
<nav class="d-flex d-md-none align-items-center justify-content-between px-3 py-2 mobile-topbar">
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-light" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar">
            <i class="bi bi-list fs-5"></i>
        </button>
        <span class="text-white fw-bold small"><i class="bi bi-diagram-3 me-1"></i>Transfer In Plan</span>
    </div>
    <span class="text-white-50 small">@ViewData["Title"]</span>
</nav>

<!-- ── Offcanvas Sidebar for Mobile ───────────────────────────── -->
<div class="offcanvas offcanvas-start sidebar-offcanvas" tabindex="-1" id="mobileSidebar">
    <div class="offcanvas-header border-bottom border-white border-opacity-10">
        <div>
            <h6 class="text-white fw-bold mb-0"><i class="bi bi-diagram-3 me-2"></i>Transfer In Plan</h6>
            <small class="text-white-50">Management System</small>
        </div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-0 pt-2">
        <ul class="nav flex-column px-2">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index" data-bs-dismiss="offcanvas">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link dropdown-toggle" href="#mRefTablesMenu" data-bs-toggle="collapse" role="button">
                    <i class="bi bi-table"></i> Reference Tables
                </a>
                <ul class="collapse list-unstyled ms-3" id="mRefTablesMenu">
                    <li><a class="nav-link" asp-controller="WeekCalendar" asp-action="Index" data-bs-dismiss="offcanvas">Week Calendar</a></li>
                    <li><a class="nav-link" asp-controller="StoreMaster" asp-action="Index" data-bs-dismiss="offcanvas">Store Master</a></li>
                    <li><a class="nav-link" asp-controller="BinCapacity" asp-action="Index" data-bs-dismiss="offcanvas">Bin Capacity</a></li>
                    <li><a class="nav-link" asp-controller="SaleQty" asp-action="Index" data-bs-dismiss="offcanvas">Sale Quantity</a></li>
                    <li><a class="nav-link" asp-controller="DispQty" asp-action="Index" data-bs-dismiss="offcanvas">Display Qty</a></li>
                    <li><a class="nav-link" asp-controller="StoreStock" asp-action="Index" data-bs-dismiss="offcanvas">Store Stock</a></li>
                    <li><a class="nav-link" asp-controller="DcStock" asp-action="Index" data-bs-dismiss="offcanvas">DC Stock</a></li>
                    <li><a class="nav-link" asp-controller="DelPending" asp-action="Index" data-bs-dismiss="offcanvas">Del Pending</a></li>
                </ul>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="BulkUpload" asp-action="Index" data-bs-dismiss="offcanvas">
                    <i class="bi bi-upload"></i> Bulk Upload
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link dropdown-toggle" href="#mPlanMenu" data-bs-toggle="collapse" role="button">
                    <i class="bi bi-lightning"></i> Plan Management
                </a>
                <ul class="collapse list-unstyled ms-3" id="mPlanMenu">
                    <li><a class="nav-link" asp-controller="Plan" asp-action="Execute" data-bs-dismiss="offcanvas">Execute Plan</a></li>
                    <li><a class="nav-link" asp-controller="Plan" asp-action="Output" data-bs-dismiss="offcanvas">View Output</a></li>
                    <li><a class="nav-link" asp-controller="PurchasePlan" asp-action="Execute" data-bs-dismiss="offcanvas">Purchase Plan</a></li>
                    <li><a class="nav-link" asp-controller="PurchasePlan" asp-action="Output" data-bs-dismiss="offcanvas">Purchase Output</a></li>
                </ul>
            </li>
        </ul>
    </div>
</div>

<!-- ── Desktop Layout ─────────────────────────────────────────── -->
<div class="d-flex">

    <!-- Desktop Sidebar (hidden below md) -->
    <nav class="sidebar d-none d-md-block" id="desktopSidebar">
        <div class="sidebar-header">
            <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Transfer In Plan</h5>
            <small class="text-muted">Management System</small>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link dropdown-toggle" href="#refTablesMenu" data-bs-toggle="collapse" role="button">
                    <i class="bi bi-table"></i> Reference Tables
                </a>
                <ul class="collapse list-unstyled ms-3" id="refTablesMenu">
                    <li><a class="nav-link" asp-controller="WeekCalendar" asp-action="Index">Week Calendar</a></li>
                    <li><a class="nav-link" asp-controller="StoreMaster" asp-action="Index">Store Master</a></li>
                    <li><a class="nav-link" asp-controller="BinCapacity" asp-action="Index">Bin Capacity</a></li>
                    <li><a class="nav-link" asp-controller="SaleQty" asp-action="Index">Sale Quantity</a></li>
                    <li><a class="nav-link" asp-controller="DispQty" asp-action="Index">Display Qty</a></li>
                    <li><a class="nav-link" asp-controller="StoreStock" asp-action="Index">Store Stock</a></li>
                    <li><a class="nav-link" asp-controller="DcStock" asp-action="Index">DC Stock</a></li>
                    <li><a class="nav-link" asp-controller="DelPending" asp-action="Index">Del Pending</a></li>
                </ul>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="BulkUpload" asp-action="Index">
                    <i class="bi bi-upload"></i> Bulk Upload
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link dropdown-toggle" href="#planMenu" data-bs-toggle="collapse" role="button">
                    <i class="bi bi-lightning"></i> Plan Management
                </a>
                <ul class="collapse list-unstyled ms-3" id="planMenu">
                    <li><a class="nav-link" asp-controller="Plan" asp-action="Execute">Execute Plan</a></li>
                    <li><a class="nav-link" asp-controller="Plan" asp-action="Output">View Output</a></li>
                    <li><a class="nav-link" asp-controller="PurchasePlan" asp-action="Execute">Purchase Plan</a></li>
                    <li><a class="nav-link" asp-controller="PurchasePlan" asp-action="Output">Purchase Output</a></li>
                </ul>
            </li>
        </ul>
    </nav>

    <!-- Content Wrapper -->
    <div class="content-wrapper flex-grow-1 min-w-0" id="mainContent">
        <header class="top-header d-none d-md-flex align-items-center justify-content-between">
            <h4 class="page-title mb-0">@ViewData["Title"]</h4>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-success"><i class="bi bi-circle-fill me-1" style="font-size:8px;"></i>Online</span>
                <span class="text-muted small d-none d-lg-inline">Transfer In Plan System</span>
            </div>
        </header>
        <main class="main-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
