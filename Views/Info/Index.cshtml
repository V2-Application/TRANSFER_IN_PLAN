<!-- ║  TAB 1: APPLICATION WORKFLOW                                     ║ -->
<!-- ╚══════════════════════════════════════════════════════════════════╝ -->
<div class="tab-pane fade show active" id="tabWorkflow">

    <!-- What This Application Does -->
    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-bullseye me-2"></i>What This Application Does</h5></div>
        <div class="card-body small">
            <p>This is a <strong>retail supply chain planning system</strong> that answers two fundamental questions every week for every store and every product category:</p>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="card info-card trf h-100"><div class="card-body">
                        <h6 class="text-success fw-bold"><i class="bi bi-arrow-left-right me-2"></i>Transfer In Plan (TRF)</h6>
                        <p class="mb-1"><strong>"How much stock should each store receive from the DC this week?"</strong></p>
                        <ul class="mb-0">
                            <li>Granularity: <code>Store + Category + Week</code></li>
                            <li>Key Output: <strong>TRF_IN_STK_Q</strong> (Transfer In Quantity)</li>
                            <li>Considers: Current stock, shrinkage, weekly sale forecast, display needs, MBQ</li>
                        </ul>
                    </div></div>
                </div>
                <div class="col-md-6">
                    <div class="card info-card pp h-100"><div class="card-body">
                        <h6 style="color:#8e44ad;" class="fw-bold"><i class="bi bi-bag-check me-2"></i>Purchase Plan (PP)</h6>
                        <p class="mb-1"><strong>"How much stock should each DC purchase from vendors this week?"</strong></p>
                        <ul class="mb-0">
                            <li>Granularity: <code>RDC + Category + Week</code></li>
                            <li>Key Output: <strong>BGT_PUR_Q_INIT</strong> (Purchase Quantity)</li>
                            <li>Considers: Aggregated store transfers, DC stock, GRT consumption, delivery pending</li>
                        </ul>
                    </div></div>
                </div>
            </div>
            <div class="alert alert-info py-2 mb-0"><i class="bi bi-layers me-1"></i><strong>Sub-Level Plans</strong> further break these down by 4 dimensions: Macro MVGR, Size, Segment, Vendor — using the same algorithms with contribution percentages and level-specific stock.</div>
        </div>
    </div>

    <!-- End-to-End Workflow -->
    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-signpost-split me-2"></i>End-to-End Workflow (Step-by-Step)</h5></div>
        <div class="card-body small">
            <div class="row">
                <div class="col-md-6">
                    <div class="flow-step">
                        <h6><span class="step-num">1</span> Upload Reference Data</h6>
                        <p class="text-muted mb-1">Via <strong>Bulk Upload</strong> (Excel/CSV) or individual <strong>CRUD</strong> pages.</p>
                        <code>WEEK_CALENDAR, MASTER_ST_MASTER, MASTER_BIN_CAPACITY, QTY_SALE_QTY, QTY_DISP_QTY, STORE_STOCK, DC_STOCK, DEL_PENDING, MASTER_GRT_CONTRIBUTION, MASTER_PRODUCT_HIERARCHY</code>
                    </div>
                    <div class="flow-step">
                        <h6><span class="step-num">2</span> Execute Transfer In Plan</h6>
                        <p class="text-muted mb-1">Runs <code>SP_GENERATE_TRF_IN_PLAN</code> for selected store/week range. Or <strong>Full Run</strong> (background) for all 657 stores.</p>
                        <span class="badge bg-success mini-badge">Output: TRF_IN_PLAN table</span>
                    </div>
                    <div class="flow-step">
                        <h6><span class="step-num">3</span> Execute Purchase Plan</h6>
                        <p class="text-muted mb-1">Runs <code>SP_GENERATE_PURCHASE_PLAN</code>. <strong>Reads TRF_IN_PLAN output</strong> — aggregates store-level TRF_IN by RDC to get DC transfer-out quantities.</p>
                        <span class="badge bg-success mini-badge">Output: PURCHASE_PLAN table</span>
                    </div>
                    <div class="flow-step">
                        <h6><span class="step-num">4</span> Review Output & Export</h6>
                        <p class="text-muted mb-0">View paginated output, apply filters (RDC, Category, Week), export CSV or Pivot CSV.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="flow-step" style="border-left-color:#e67e22;">
                        <h6><span class="step-num" style="background:#e67e22;">5</span> Upload Sub-Level Data</h6>
                        <p class="text-muted mb-1">Upload contribution tables (MVGR, Size, Segment, Vendor) + sub-level stock tables (4 store + 4 DC).</p>
                        <code>ST_MAJ_CAT_MACRO_MVGR_PLAN, ST_MAJ_CAT_SZ_PLAN, ST_MAJ_CAT_SEG_PLAN, ST_MAJ_CAT_VND_PLAN, SUB_ST_STK_*, SUB_DC_STK_*</code>
                    </div>
                    <div class="flow-step" style="border-left-color:#e67e22;">
                        <h6><span class="step-num" style="background:#e67e22;">6</span> Execute Sub-Level Plans</h6>
                        <p class="text-muted mb-1">Per-level or <strong>Full Run</strong> (background, all 4 levels). TRF runs first per level, then PP reads TRF output.</p>
                        <span class="badge bg-success mini-badge">Output: SUB_LEVEL_TRF_PLAN + SUB_LEVEL_PP_PLAN</span>
                    </div>
                    <div class="flow-step" style="border-left-color:#e67e22;">
                        <h6><span class="step-num" style="background:#e67e22;">7</span> Review Sub-Level Output</h6>
                        <p class="text-muted mb-0">Per-level output pages with filters, pagination, CSV + Pivot CSV export.</p>
                    </div>
                    <div class="flow-step" style="border-left-color:#3498db;">
                        <h6><span class="step-num" style="background:#3498db;">8</span> Dashboard Monitoring</h6>
                        <p class="text-muted mb-0">KPIs, charts, alerts, inventory health, short/excess analysis. Auto-refreshed with multi-select drill-down filters.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Flow Diagram -->
    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-arrow-repeat me-2"></i>Data Flow — How Plans Are Connected</h5></div>
        <div class="card-body small">
            <div class="row text-center align-items-center">
                <div class="col-md-2">
                    <div class="card bg-light p-2 mb-2"><strong>Reference Data</strong><br><small>10 tables</small></div>
                    <div class="card bg-light p-2"><strong>Contribution Data</strong><br><small>4 tables + 8 stock</small></div>
                </div>
                <div class="col-md-1 data-flow-arrow">&rarr;</div>
                <div class="col-md-2">
                    <div class="card p-2 mb-2" style="border:2px solid #27ae60;"><strong class="text-success">TRF SP</strong><br><small>Per Store+Cat+Week</small></div>
                    <div class="card p-2" style="border:2px solid #e67e22;"><strong style="color:#e67e22;">Sub TRF SP</strong><br><small>Per Store+Cat+SubVal+Week</small></div>
                </div>
                <div class="col-md-1 data-flow-arrow">&rarr;</div>
                <div class="col-md-2">
                    <div class="card p-2 mb-2" style="border:2px solid #27ae60;background:#d4edda;"><strong>TRF_IN_PLAN</strong><br><small>Store transfers</small></div>
                    <div class="card p-2" style="border:2px solid #e67e22;background:#ffeaa7;"><strong>SUB_LEVEL_TRF_PLAN</strong><br><small>Sub-level transfers</small></div>
                </div>
                <div class="col-md-1 data-flow-arrow">&rarr;</div>
                <div class="col-md-2">
                    <div class="card p-2 mb-2" style="border:2px solid #8e44ad;"><strong style="color:#8e44ad;">PP SP</strong><br><small>Reads TRF output</small></div>
                    <div class="card p-2" style="border:2px solid #e67e22;"><strong style="color:#e67e22;">Sub PP SP</strong><br><small>Reads Sub TRF output</small></div>
                </div>
                <div class="col-md-1 data-flow-arrow">&rarr;</div>
            </div>
            <div class="alert alert-warning py-2 mt-3 mb-0"><i class="bi bi-exclamation-triangle me-1"></i><strong>Critical Dependency:</strong> Purchase Plan READS from TRF_IN_PLAN output. You must execute Transfer In Plan BEFORE Purchase Plan. Same for sub-level: Sub TRF must run before Sub PP per level.</div>
        </div>
    </div>

    <!-- Execution Modes -->
    <div class="card shadow-sm">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-lightning me-2"></i>Execution Modes</h5></div>
        <div class="card-body p-0 small">
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-dark"><tr><th>Mode</th><th>Page</th><th>Stored Procedure</th><th>Type</th><th>Description</th></tr></thead>
                    <tbody>
                        <tr><td class="fw-bold">Single Store TRF</td><td>Execute Plan</td><td><code>SP_GENERATE_TRF_IN_PLAN</code></td><td>Sync</td><td>TRF for 1 store + week range. ~10s per store.</td></tr>
                        <tr><td class="fw-bold">Full Run (All Stores)</td><td>Execute Plan</td><td><code>SP_RUN_ALL_PLANS</code></td><td><span class="badge bg-primary">Background</span></td><td>Truncates TRF+PP, bulk runs all ~657 stores. ~1-2 min. PlanJobService singleton.</td></tr>
                        <tr><td class="fw-bold">Purchase Plan</td><td>Purchase Plan</td><td><code>SP_GENERATE_PURCHASE_PLAN</code></td><td>Sync</td><td>PP for week range + optional RDC/MajCat filter. Reads TRF_IN_PLAN.</td></tr>
                        <tr><td class="fw-bold">Sub-Level (Per Level)</td><td>Sub-Level Plans</td><td><code>SP_GENERATE_SUB_LEVEL_TRF</code> + <code>PP</code></td><td>Sync</td><td>TRF+PP for selected level(s). Form submit.</td></tr>
                        <tr><td class="fw-bold">Sub-Level Full Run</td><td>Sub-Level Plans</td><td>Same SPs x 4 levels</td><td><span class="badge bg-primary">Background</span></td><td>All 4 levels sequentially. SubLevelJobService singleton. Live progress tracking.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

