                        <tr class="table-light"><td colspan="4" class="fw-bold">DC Stock Tables (4 — one per level)</td></tr>
                        <tr><td>MVGR</td><td><code>SUB_DC_STK_MVGR</code></td><td>DC stock at MVGR level</td><td>RDC_CD, MAJ_CAT, SUB_VALUE, DC_STK_Q, GRT_STK_Q, W_GRT_STK_Q, DATE</td></tr>
                        <tr><td>Size</td><td><code>SUB_DC_STK_SZ</code></td><td>DC stock at Size level</td><td>Same columns</td></tr>
                        <tr><td>Segment</td><td><code>SUB_DC_STK_SEG</code></td><td>DC stock at Segment level</td><td>Same columns</td></tr>
