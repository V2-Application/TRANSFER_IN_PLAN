                        <tr><td>MVGR</td><td><code>SUB_ST_STK_MVGR</code></td><td>Store stock at MVGR level</td><td>ST_CD, MAJ_CAT, SUB_VALUE, STK_QTY, DATE</td></tr>
                        <tr><td>Size</td><td><code>SUB_ST_STK_SZ</code></td><td>Store stock at Size level</td><td>ST_CD, MAJ_CAT, SUB_VALUE, STK_QTY, DATE</td></tr>
