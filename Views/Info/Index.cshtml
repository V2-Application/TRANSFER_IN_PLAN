                        <tr><td>10</td><th>SZ</th><td>Size (reserved)</td><td><span class="badge badge-input">Input</span></td></tr>
                        <tr class="key-formula"><td>11</td><th>ART_CLASS</th><td><strong>7-rule classification</strong>: MIX-ART (rules 1-4) → L-ART (rule 5) → OLD-ART (rule 6) → NEW-L (rule 7 + post-tag)</td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr class="key-formula"><td>12</td><th>TTL_ST_STK_Q</th><td><strong>SUM(0001+0002+0004+0006+HUB_INTRA+HUB_PRD+INTRA+PRD)</strong></td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>13-20</td><th>STK_0001..STK_PRD</th><td>Pivoted stock by LGORT from ET_STOCK_DATA</td><td><span class="badge badge-input">Input</span></td></tr>
                        <tr><td>21</td><th>MSA_QTY</th><td>SUM(VEMNG) from ET_MSA_STOCK (aggregated to 10-digit)</td><td><span class="badge badge-input">Input</span></td></tr>
                        <tr class="key-formula"><td>22</td><th>TTL_ALC_DAYS</th><td><strong>SALE_COVER + PRD_DAYS + INTRA_DAYS</strong></td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>23</td><th>HOLD_DAYS</th><td>From ARS_HOLD_DAYS_MASTER</td><td><span class="badge badge-input">Input</span></td></tr>
                        <tr><td>24</td><th>CM_PD_SALE_Q</th><td>CM_AUTO_SALE_Q / CM_REM_DAYS (MJ-level per-day)</td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>25</td><th>NM_PD_SALE_Q</th><td>NM_AUTO_SALE_Q / NM_DAYS (MJ-level per-day)</td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>26</td><th>ART_AUTO_SALE_PD</th><td>CM/NM crossover at article level over allocation period</td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>27</td><th>ACC_DENSITY</th><td>Per-article density from ARS_ST_MJ_DISPLAY_MASTER</td><td><span class="badge badge-input">Input</span></td></tr>
                        <tr><td>28</td><th>ST_MJ_DISP_Q</th><td>Category display quantity from ARS_ST_MJ_DISPLAY_MASTER</td><td><span class="badge badge-input">Input</span></td></tr>
                        <tr class="key-formula"><td>29</td><th>ST_MJ_MBQ</th><td><strong>ST_MJ_DISP_Q + MJ_sale_over_period</strong></td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr class="key-formula"><td>30</td><th>ART_MBQ</th><td><strong>ACC_DENSITY + ART_SALE_PD × TTL_ALC_DAYS</strong></td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr class="key-formula"><td>31</td><th>ART_HOLD_MBQ</th><td><strong>ACC_DENSITY + ART_SALE_PD × (TTL_ALC_DAYS + HOLD_DAYS)</strong></td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>32</td><th>VAR_ART_MBQ</th><td>Variant-level MBQ (reserved)</td><td><span class="badge badge-static">Reserved</span></td></tr>
                        <tr><td>33</td><th>VAR_ART_HOLD_MBQ</th><td>Variant-level hold MBQ (reserved)</td><td><span class="badge badge-static">Reserved</span></td></tr>
                        <tr class="key-formula"><td>34</td><th>ST_MJ_REQ</th><td><strong>MAX(ST_MJ_MBQ - SUM(TTL_STK per ST+MJ), 0)</strong> — MJ-level cap</td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr class="key-formula"><td>35</td><th>ST_ART_REQ</th><td><strong>MAX(ART_MBQ - TTL_ST_STK_Q, 0)</strong></td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>36</td><th>ST_ART_HOLD_REQ</th><td>MAX(ART_HOLD_MBQ - TTL_ST_STK_Q, 0)</td><td><span class="badge badge-derived">Derived</span></td></tr>
                        <tr><td>37</td><th>ST_VAR_ART_REQ</th><td>Variant-level requirement (reserved)</td><td><span class="badge badge-static">Reserved</span></td></tr>
                        <tr><td>38</td><th>ST_VAR_ART_HOLD_REQ</th><td>Variant-level hold requirement (reserved)</td><td><span class="badge badge-static">Reserved</span></td></tr>
                        <tr class="key-formula"><td>39</td><th>ART_ALC_Q</th><td><strong>LEAST(WANT_Q, MJ_REMAINING)</strong> — window-function, MJ-budget safe</td><td><span class="badge badge-chain">Allocation</span></td></tr>
                        <tr class="key-formula"><td>40</td><th>ART_HOLD_Q</th><td><strong>LEAST(MSA - ALC_Q, HOLD_REQ - ALC_Q)</strong></td><td><span class="badge badge-chain">Allocation</span></td></tr>
                        <tr><td>41</td><th>REM_MSA</th><td>MSA_QTY - ART_ALC_Q - ART_HOLD_Q</td><td><span class="badge badge-chain">Allocation</span></td></tr>
                        <tr><td>42</td><th>CREATED_DT</th><td>CURRENT_TIMESTAMP() at run time</td><td><span class="badge badge-static">Static</span></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
