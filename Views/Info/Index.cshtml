    <div class="card shadow-sm">
        <div class="card-header bg-success bg-opacity-10"><h5 class="card-title mb-0 text-success"><i class="bi bi-diagram-2 me-2"></i>Transfer In — Week Chaining Logic</h5></div>
        <div class="card-body small">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="fw-bold">Week 1 (Opening Week)</h6>
                    <ol>
                        <li><strong>OP_STK</strong> = Store Stock</li>
                        <li><strong>Shrinkage</strong> = ROUND(OP_STK * 0.08) * SSN_FACTOR</li>
                        <li><strong>NET_CF</strong> = MAX(OP_STK - Shrinkage, 0)</li>
                        <li><strong>TRF_IN</strong> = MAX(MBQ + SALE - NET_CF, 0)</li>
                        <li><strong>CL_STK</strong> = closing stock logic</li>
                    </ol>
                </div>
                <div class="col-md-6">
                    <h6 class="fw-bold">Week 2+ (Chaining)</h6>
                    <ol>
                        <li><strong>OP_STK</strong> = Previous Week CL_STK</li>
                        <li><strong>Shrinkage</strong> = ROUND(OP_STK * 0.08) * SSN_FACTOR</li>
                        <li><strong>NET_CF</strong> = MAX(OP_STK - Shrinkage, 0)</li>
                        <li><strong>TRF_IN</strong> = MAX(MBQ + SALE - NET_CF, 0)</li>
                        <li><strong>CL_STK</strong> = closing stock logic</li>
                    </ol>
                </div>
            </div>
            <div class="alert alert-info py-2 mt-2 mb-0"><i class="bi bi-info-circle me-1"></i><strong>Key:</strong> Each week's closing stock becomes the next week's opening stock. The chain runs sequentially from first to last week in the selected range.</div>
        </div>
    </div>
</div>

