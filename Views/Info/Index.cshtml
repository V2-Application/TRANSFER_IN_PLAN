                        </tr>
                        <tr>
                            <th>TRF_IN_STK_Q</th>
                            <td colspan="2">
                                IF MBQ=0 AND SALE=0 THEN 0<br>
                                ELSE IF MBQ + SALE - NET_CF &gt; 0 THEN MBQ + SALE - NET_CF<br>
                                ELSE 0
                            </td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
