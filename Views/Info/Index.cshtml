                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════ TAB: TRANSFER IN PLAN FORMULAS ═══════════════ -->
<div class="tab-pane fade" id="tabTrfIn">
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-success bg-opacity-10"><h5 class="card-title mb-0 text-success"><i class="bi bi-arrow-left-right me-2"></i>Transfer In Plan — Formula Reference</h5></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0 small formula-table">
                    <thead class="table-dark">
                        <tr><th>Column</th><th>As-Is Formula</th><th>To-Be Formula</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th>BGT_TTL_CF_OP_STK_Q</th>
                            <td>STORE_STOCK (Opening Stock)</td>
                            <td>Same — Week 1: Store Stock; Week 2+: Previous week CL_STK</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>NT_ACT_Q (Shrinkage)</th>
                            <td>ROUND(OP_STK * 0.08, 0) * SSN_FACTOR</td>
                            <td>Same — SSN_FACTOR = 1.0 if SSN IN ('S','PS'), else 0.5</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>NET_BGT_CF_STK_Q</th>
                            <td>OP_STK - Shrinkage (if &gt; 0, else 0)</td>
                            <td>Same</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>CM_BGT_SALE_Q</th>
                            <td>Current Week Sale from SALE_QTY</td>
                            <td>Same</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>CM1_BGT_SALE_Q</th>
                            <td>Next Week Sale from SALE_QTY</td>
                            <td>Same</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>CM2_BGT_SALE_Q</th>
                            <td>Week+2 Sale from SALE_QTY</td>
                            <td>Same</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>BGT_ST_CL_MBQ</th>
                            <td>MBQ from Bin Capacity (Store MBQ)</td>
                            <td>Same</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>BGT_DISP_CL_Q</th>
                            <td>DISP_QTY from Display Quantity table</td>
                            <td>Same</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>BGT_DISP_CL_OPT</th>
                            <td>DISP_QTY * 1000 / BIN_CAP</td>
                            <td>Same</td>
                            <td><span class="badge badge-unchanged">Unchanged</span></td>
                        </tr>
                        <tr>
                            <th>BGT_DISP_CL_OPT_MBQ</th>
                            <td>MBQ * 1000 / BGT_DISP_CL_OPT</td>
