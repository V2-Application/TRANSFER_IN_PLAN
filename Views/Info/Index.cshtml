                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold">Frontend</h6>
                    <ul class="mb-0">
                        <li>Bootstrap 5.3 + Bootstrap Icons</li>
                        <li>Chart.js 4.4 (dashboard charts)</li>
