@{
    ViewData["Title"] = "Execute Purchase Plan Generation";
}

@model PurchasePlanExecutionParams

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Execute SP_GENERATE_PURCHASE_PLAN</h5>
            </div>
            <div class="card-body">
                <form asp-action="Execute" method="post" id="executionForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartWeekId" class="form-label">Start Week ID</label>
                            <select asp-for="StartWeekId" class="form-select search-select" asp-items="@(new SelectList(ViewBag.WeekCalendars, "WeekId", "YearWeek"))" required>
                                <option value="">-- Select Start Week --</option>
                            </select>
                            <span asp-validation-for="StartWeekId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="EndWeekId" class="form-label">End Week ID</label>
                            <select asp-for="EndWeekId" class="form-select search-select" asp-items="@(new SelectList(ViewBag.WeekCalendars, "WeekId", "YearWeek"))" required>
                                <option value="">-- Select End Week --</option>
                            </select>
                            <span asp-validation-for="EndWeekId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="RdcCode" class="form-label">RDC Code (Optional)</label>
                            <select asp-for="RdcCode" class="form-select search-select">
                                <option value="">-- All RDCs --</option>
                                @foreach (var r in (ViewBag.RdcCodes as IEnumerable<string> ?? new List<string>())) { <option value="@r">@r</option> }
                            </select>
                            <span asp-validation-for="RdcCode" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="MajCat" class="form-label">Major Category (Optional)</label>
                            <select asp-for="MajCat" class="form-select search-select">
                                <option value="">-- All Categories --</option>
                                @foreach (var c in (ViewBag.MajCats as IEnumerable<string> ?? new List<string>())) { <option value="@c">@c</option> }
                            </select>
                            <span asp-validation-for="MajCat" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Leave RDC Code and Major Category blank to process all data. This will execute the stored procedure with the specified parameters.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success btn-lg" id="executeBtn">
                            <i class="bi bi-play-circle"></i> Execute Purchase Plan Generation
                        </button>
                        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Cancel</a>
                    </div>

                    <div id="loadingSpinner" class="mt-3" style="display: none;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Executing...</span>
                        </div>
                        <span class="ms-2">Processing purchase plan generation, please wait...</span>
                    </div>
                </form>

                @if (ViewBag.RowsInserted != null)
                {
                    <div class="alert alert-success mt-3">
                        <h5>Execution Completed Successfully!</h5>
                        <p><strong>Rows Inserted:</strong> @ViewBag.RowsInserted</p>
                        <p><strong>Execution Time:</strong> @ViewBag.SuccessMessage</p>
                    </div>
                }

                <hr class="my-2">
                <form asp-action="ResetPp" method="post" class="d-inline" onsubmit="return confirm('This will DELETE all Purchase Plan data (PURCHASE_PLAN). Continue?');">
                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Reset Purchase Plan</button>
                    <small class="text-muted ms-2">Clears all PURCHASE_PLAN rows</small>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('executionForm').addEventListener('submit', function () {
            document.getElementById('loadingSpinner').style.display = 'block';
            document.getElementById('executeBtn').disabled = true;
        });
    </script>
}
