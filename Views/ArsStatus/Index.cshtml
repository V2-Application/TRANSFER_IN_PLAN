@{ ViewData["Title"] = "ARS Allocation (Plan 8)"; }

<div class="mb-4">
    <h3 class="mb-1"><i class="bi bi-robot me-2 text-dark"></i>Article Allocation — ARS (Plan 8)</h3>
    <small class="text-muted">Auto Replenishment System — Article-level allocation to stores via Azure API</small>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <!-- ARS Status -->
        <div class="card shadow-sm border-0 mb-3" style="border-left:4px solid #1E293B !important;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-cloud-check me-2"></i>ARS API Status</h6>
                <button class="btn btn-sm btn-outline-primary" onclick="checkHealth()"><i class="bi bi-arrow-repeat me-1"></i>Check</button>
            </div>
            <div class="card-body small">
                <div class="d-flex justify-content-between mb-2">
                    <span>API Endpoint</span>
                    <code>ars-v2retail-api.azurewebsites.net</code>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Status</span>
                    <span id="arsStatus"><span class="badge bg-secondary">Not checked</span></span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Docs</span>
                    <a href="https://ars-v2retail-api.azurewebsites.net/docs" target="_blank" class="text-primary">Swagger UI <i class="bi bi-box-arrow-up-right"></i></a>
                </div>
            </div>
        </div>

        <!-- ARS Architecture -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>ARS 5-Engine Pipeline</h6></div>
            <div class="card-body small">
                <div class="flow-step mb-3" style="border-left:3px solid var(--primary); padding-left:16px;">
                    <h6 class="mb-1"><span class="badge bg-primary me-1">1</span> Budget Cascade</h6>
                    <p class="text-muted mb-0">Reads <code>co_budget_store_major_category</code> from Supabase → calculates MBQ per store x MAJCAT</p>
                </div>
                <div class="flow-step mb-3" style="border-left:3px solid #E67E22; padding-left:16px;">
                    <h6 class="mb-1"><span class="badge me-1" style="background:#E67E22;">2</span> Article Scoring</h6>
                    <p class="text-muted mb-0">Scores every DC article against every store using 14 weighted factors</p>
                </div>
                <div class="flow-step mb-3" style="border-left:3px solid #059669; padding-left:16px;">
                    <h6 class="mb-1"><span class="badge bg-success me-1">3</span> Greedy Filler</h6>
                    <p class="text-muted mb-0">Fills option slots with highest-scoring articles, equitable distribution</p>
                </div>
                <div class="flow-step mb-3" style="border-left:3px solid #8B5CF6; padding-left:16px;">
                    <h6 class="mb-1"><span class="badge me-1" style="background:#8B5CF6;">4</span> Size Allocator</h6>
                    <p class="text-muted mb-0">Breaks options into size-level quantities</p>
                </div>
                <div class="flow-step" style="border-left:3px solid #DC2626; padding-left:16px;">
                    <h6 class="mb-1"><span class="badge bg-danger me-1">5</span> DO Generator</h6>
                    <p class="text-muted mb-0">Compiles delivery orders → SAP</p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <!-- Performance -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>ARS Performance</h6></div>
            <div class="card-body small">
                <div class="d-flex justify-content-between mb-1"><span>Store-Article Pairs</span><strong>~1M</strong></div>
                <div class="d-flex justify-content-between mb-1"><span>Option Slots Filled</span><strong>31K+</strong></div>
                <div class="d-flex justify-content-between mb-1"><span>Variant Allocations</span><strong>145K+</strong></div>
                <div class="d-flex justify-content-between mb-1"><span>Execution Time</span><strong>&lt;6 minutes</strong></div>
                <div class="d-flex justify-content-between"><span>vs Excel (20 machines)</span><strong class="text-success">88% faster</strong></div>
            </div>
        </div>

        <!-- Tech Stack -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-stack me-2"></i>Tech Stack</h6></div>
            <div class="card-body small">
                <ul class="mb-0">
                    <li>Python FastAPI on Azure App Service</li>
                    <li>Azure SQL + Supabase (387K budget rows)</li>
                    <li>Snowflake (scoring visualization)</li>
                    <li>JWT Auth with RBAC + RLS</li>
                </ul>
            </div>
        </div>

        <!-- Full Pipeline -->
        <div class="card shadow-sm border-0">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-signpost-split me-2"></i>Full Pipeline</h6></div>
            <div class="card-body small text-center">
                <span class="badge" style="background:#8B5CF6;">1: Sale Budget</span><br><i class="bi bi-arrow-down"></i><br>
                <span class="badge" style="background:#E67E22;">2: Fixture</span><br><i class="bi bi-arrow-down"></i><br>
                <span class="badge bg-info">3: Weekly Disagg</span><br><i class="bi bi-arrow-down"></i><br>
                <span class="badge bg-success">4: TRF</span> → <span class="badge" style="background:#8e44ad;color:#fff;">5: PP</span><br><i class="bi bi-arrow-down"></i><br>
                <span class="badge bg-secondary">6-7: Sub-Level</span><br><i class="bi bi-arrow-down"></i><br>
                <span class="badge bg-dark fw-bold">8: ARS (YOU ARE HERE)</span><br><i class="bi bi-arrow-down text-success"></i><br>
                <span class="badge bg-success">Delivery Orders → SAP → Stores</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function checkHealth() {
    document.getElementById('arsStatus').innerHTML = '<span class="spinner-border spinner-border-sm"></span> Checking...';
    fetch('@Url.Action("CheckHealth")').then(r => r.json()).then(d => {
        document.getElementById('arsStatus').innerHTML = d.online
            ? '<span class="badge bg-success">Online (' + d.statusCode + ')</span>'
            : '<span class="badge bg-danger">Offline</span>' + (d.error ? ' <small class="text-muted">' + d.error + '</small>' : '');
    });
}
checkHealth();
</script>
}
