@{
    ViewData["Title"] = "Delete DC Stock";
}

@model DcStock

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">Confirm Delete</h5>
            </div>
            <div class="card-body">
                <p>Are you sure you want to delete this DC stock entry?</p>
                <div class="mb-3">
                    <strong>RDC Code:</strong> @Model.RdcCd
                </div>
                <div class="mb-3">
                    <strong>RDC Name:</strong> @Model.Rdc
                </div>
                <div class="mb-3">
                    <strong>Major Category:</strong> @Model.MajCat
                </div>

                <form asp-action="DeleteConfirmed" method="post" class="d-inline">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
