@{
    ViewData["Title"] = "Create DC Stock";
}

@model DcStock

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Add New DC Stock</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="RdcCd" class="form-label">RDC Code</label>
                            <input asp-for="RdcCd" class="form-control" />
                            <span asp-validation-for="RdcCd" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Rdc" class="form-label">RDC Name</label>
                            <input asp-for="Rdc" class="form-control" />
                            <span asp-validation-for="Rdc" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MajCat" class="form-label">Major Category</label>
                        <input asp-for="MajCat" class="form-control" />
                        <span asp-validation-for="MajCat" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="DcStkQ" class="form-label">DC Stock Qty</label>
                            <input asp-for="DcStkQ" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="DcStkQ" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="GrtStkQ" class="form-label">GRT Stock Qty</label>
                            <input asp-for="GrtStkQ" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="GrtStkQ" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="WGrtStkQ" class="form-label">W GRT Stock Qty</label>
                            <input asp-for="WGrtStkQ" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="WGrtStkQ" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Date" class="form-label">Date</label>
                        <input asp-for="Date" type="date" class="form-control" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Create
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
