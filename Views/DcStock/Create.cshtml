@{ ViewData["Title"] = "Create DC Stock"; }
@model DcStock

<div class="row"><div class="col-md-10">
<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-2"><h5 class="card-title mb-0"><i class="bi bi-plus-circle me-2 text-success"></i>Add New DC Stock</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="RdcCd" class="form-label fw-semibold">RDC Code <span class="text-danger">*</span></label>
                    <select asp-for="RdcCd" class="form-select search-select" required>
                        <option value="">-- Select RDC --</option>
                        @foreach (var r in (ViewBag.RdcCodes as IEnumerable<dynamic> ?? new List<dynamic>())) { <option value="@r.RdcCd">@r.RdcCd - @r.RdcNm</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Rdc" class="form-label fw-semibold">RDC Name</label>
                    <input asp-for="Rdc" class="form-control" placeholder="RDC Name" />
                </div>
                <div class="col-md-4">
                    <label asp-for="MajCat" class="form-label fw-semibold">Major Category <span class="text-danger">*</span></label>
                    <select asp-for="MajCat" class="form-select search-select" required>
                        <option value="">-- Select Category --</option>
                        @foreach (var c in (ViewBag.MajCats as IEnumerable<string> ?? new List<string>())) { <option value="@c">@c</option> }
                    </select>
                </div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label asp-for="DcStkQ" class="form-label fw-semibold">DC Stock Qty</label>
                    <input asp-for="DcStkQ" type="number" step="0.0001" class="form-control" placeholder="0" />
                </div>
                <div class="col-md-3">
                    <label asp-for="GrtStkQ" class="form-label fw-semibold">GRT Stock Qty</label>
                    <input asp-for="GrtStkQ" type="number" step="0.0001" class="form-control" placeholder="0" />
                </div>
                <div class="col-md-3">
                    <label asp-for="WGrtStkQ" class="form-label fw-semibold">W GRT Stock Qty</label>
                    <input asp-for="WGrtStkQ" type="number" step="0.0001" class="form-control" placeholder="0" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Date" class="form-label fw-semibold">Date</label>
                    <input asp-for="Date" type="date" class="form-control" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Create</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div></div>
