@{ ViewData["Title"] = "ARS Store Master"; }
@model IEnumerable<TRANSFER_IN_PLAN.Models.ArsStMaster>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0"><i class="bi bi-shop me-2 text-primary"></i>ARS Store Master</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>Add</a>
        <a asp-action="ExportCsv" asp-route-st="@ViewBag.St" asp-route-taggedRdc="@ViewBag.TaggedRdc" asp-route-hubCd="@ViewBag.HubCd" class="btn btn-success btn-sm"><i class="bi bi-download me-1"></i>CSV</a>
    </div>
</div>

@{ ViewBag.Kpi2Label = "RDCs"; ViewBag.Kpi2Value = ViewBag.TotalRdcs; ViewBag.Kpi2Color = "#27ae60";
   ViewBag.Kpi3Label = "Hubs"; ViewBag.Kpi3Value = ViewBag.TotalHubs; ViewBag.Kpi3Color = "#8e44ad"; }
<partial name="_RefTableAnalytics" />

<div class="card shadow-sm border-0 mb-2"><div class="card-body py-2">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Store</label>
            <select name="st" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var s in (ViewBag.Stores as IEnumerable<string> ?? new List<string>())) { <option value="@s" selected="@(s == ViewBag.St?.ToString())">@s</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Tagged RDC</label>
            <select name="taggedRdc" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var r in (ViewBag.Rdcs as IEnumerable<string> ?? new List<string>())) { <option value="@r" selected="@(r == ViewBag.TaggedRdc?.ToString())">@r</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Hub</label>
            <select name="hubCd" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var h in (ViewBag.Hubs as IEnumerable<string> ?? new List<string>())) { <option value="@h" selected="@(h == ViewBag.HubCd?.ToString())">@h</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Page Size</label>
            <select name="pageSize" class="form-select form-select-sm">
                @foreach (var ps in new[] { 50, 100, 250, 500 }) { <option value="@ps" selected="@(ViewBag.PageSize?.ToString() == ps.ToString())">@ps</option> }
            </select></div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Clear</a>
        </div>
    </form>
</div></div>

@if (ViewBag.TotalCount != null) { <div class="alert alert-info py-1 small mb-2"><i class="bi bi-info-circle me-1"></i>Showing <strong>@Model.Count()</strong> of <strong>@(((int)ViewBag.TotalCount).ToString("N0"))</strong> (Page @ViewBag.Page)</div> }

<div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover table-bordered table-sm mb-0 small" id="dataTable">
        <thead class="table-dark"><tr>
            <th>ST_CD</th><th>ST_NM</th><th>HUB</th><th>RDC</th>
            <th class="text-end">DH24 DC→Hub</th><th class="text-end">DH24 Hub→St</th>
            <th class="text-end">DW01 DC→Hub</th><th class="text-end">DW01 Hub→St</th>
            <th>Status</th><th class="text-end">Sale Cover</th><th class="text-end">PRD Days</th>
            <th class="text-end" style="background:#1B5E20;">Intra Days</th>
            <th class="text-end" style="background:#1B5E20;">TTL ALC Days</th>
            <th class="text-center">Actions</th>
        </tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold text-primary">@item.StCd</td>
                    <td>@item.StNm</td>
                    <td>@item.HubCd</td>
                    <td><span class="badge @(item.TaggedRdc == "DW01" ? "bg-info" : "bg-warning text-dark")">@item.TaggedRdc</span></td>
                    <td class="text-end">@((item.Dh24DcToHubIntra ?? 0).ToString("N0"))</td>
                    <td class="text-end">@((item.Dh24HubToStIntra ?? 0).ToString("N0"))</td>
                    <td class="text-end">@((item.Dw01DcToHubIntra ?? 0).ToString("N0"))</td>
                    <td class="text-end">@((item.Dw01HubToStIntra ?? 0).ToString("N0"))</td>
                    <td>@item.StStat</td>
                    <td class="text-end">@((item.SaleCoverDays ?? 0).ToString("N0"))</td>
                    <td class="text-end">@((item.PrdDays ?? 0).ToString("N0"))</td>
                    <td class="text-end fw-bold" style="color:#1B5E20;">@item.IntraDays.ToString("N0")</td>
                    <td class="text-end fw-bold" style="color:#1B5E20;">@item.TtlAlcDays.ToString("N0")</td>
                    <td class="text-center text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning py-0"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger py-0"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="14" class="text-center text-muted py-3">No data.</td></tr> }
        </tbody>
    </table>
</div></div></div>

@if (ViewBag.TotalCount != null && ViewBag.PageSize != null) { var totalPages = (int)Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize); if (totalPages > 1) {
    <nav class="mt-2"><ul class="pagination pagination-sm justify-content-center flex-wrap">
        @for (int p = Math.Max(1, (int)ViewBag.Page - 4); p <= Math.Min(totalPages, (int)ViewBag.Page + 4); p++)
        { <li class="page-item @(p == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Index", new { st = ViewBag.St, taggedRdc = ViewBag.TaggedRdc, hubCd = ViewBag.HubCd, page = p, pageSize = ViewBag.PageSize })">@p</a></li> }
    </ul></nav> } }

@section Scripts { <script>$(function(){ if($('#dataTable tbody tr').length > 0 && !$('#dataTable tbody .text-muted').length){ $('#dataTable').DataTable({paging:false,ordering:true,searching:true,dom:'lrtip'}); } });</script> }
