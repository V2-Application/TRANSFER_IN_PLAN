@{ ViewData["Title"] = "Edit Store Master"; }
@model TRANSFER_IN_PLAN.Models.ArsStMaster
<h4 class="mb-3"><i class="bi bi-pencil me-2"></i>Edit Store Master Record</h4>
<div class="card shadow-sm border-0" style="max-width:800px;"><div class="card-body">
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="row g-3">
        <div class="col-md-4"><label class="form-label fw-semibold">Store Code</label><input asp-for="StCd" class="form-control" required /></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Store Name</label><input asp-for="StNm" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Tagged RDC</label><input asp-for="TaggedRdc" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Hub Code</label><input asp-for="HubCd" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Hub Name</label><input asp-for="HubNm" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Direct Hub</label><input asp-for="DirectHub" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label fw-semibold">DH24 DC→Hub</label><input asp-for="Dh24DcToHubIntra" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-3"><label class="form-label fw-semibold">DH24 Hub→St</label><input asp-for="Dh24HubToStIntra" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-3"><label class="form-label fw-semibold">DW01 DC→Hub</label><input asp-for="Dw01DcToHubIntra" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-3"><label class="form-label fw-semibold">DW01 Hub→St</label><input asp-for="Dw01HubToStIntra" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Opening Date</label><input asp-for="StOpDt" class="form-control" type="date" /></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Status</label><input asp-for="StStat" class="form-control" /></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Sale Cover Days</label><input asp-for="SaleCoverDays" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-2"><label class="form-label fw-semibold">PRD Days</label><input asp-for="PrdDays" class="form-control" type="number" step="0.01" /></div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Update</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>
</div></div>
