@{
    ViewData["Title"] = "Create Store Stock";
}

@model StoreStock

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Add New Store Stock</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="StCd" class="form-label">Store Code</label>
                        <input asp-for="StCd" class="form-control" />
                        <span asp-validation-for="StCd" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MajCat" class="form-label">Major Category</label>
                        <input asp-for="MajCat" class="form-control" />
                        <span asp-validation-for="MajCat" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="StkQty" class="form-label">Stock Quantity</label>
                        <input asp-for="StkQty" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="StkQty" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Date" class="form-label">Date</label>
                        <input asp-for="Date" type="date" class="form-control" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Create
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
