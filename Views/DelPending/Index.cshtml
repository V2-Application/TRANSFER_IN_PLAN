@{
    ViewData["Title"] = "Delivery Pending";
}

@model IEnumerable<DelPending>

<div class="mb-4">
    <h3>Delivery Pending Reference Table</h3>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Records</h5>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i> Add New Record
        </a>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm" id="delPendingTable">
                    <thead class="table-light">
                        <tr>
                            <th>RDC Code</th>
                            <th>Major Category</th>
                            <th class="text-end">Delivery Pending Qty</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RdcCd</td>
                                <td>@item.MajCat</td>
                                <td class="text-end">@item.DelPendQ?.ToString("F2")</td>
                                <td>@item.Date?.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No records found. <a asp-action="Create">Create the first record</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if ($('#delPendingTable tbody tr').length > 0) {
                $('#delPendingTable').DataTable({
                    pageLength: 25,
                    order: [[0, 'asc'], [1, 'asc']]
                });
            }
        });
    </script>
}
