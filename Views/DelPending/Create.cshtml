@{ ViewData["Title"] = "Create Delivery Pending Record"; }
@model DelPending

<div class="row"><div class="col-md-8">
<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-2"><h5 class="card-title mb-0"><i class="bi bi-plus-circle me-2 text-success"></i>Add New Delivery Pending Record</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="RdcCd" class="form-label fw-semibold">RDC Code <span class="text-danger">*</span></label>
                    <select asp-for="RdcCd" class="form-select search-select" required>
                        <option value="">-- Select RDC --</option>
                        @foreach (var r in (ViewBag.RdcCodes as IEnumerable<string> ?? new List<string>())) { <option value="@r">@r</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="MajCat" class="form-label fw-semibold">Major Category <span class="text-danger">*</span></label>
                    <select asp-for="MajCat" class="form-select search-select" required>
                        <option value="">-- Select Category --</option>
                        @foreach (var c in (ViewBag.MajCats as IEnumerable<string> ?? new List<string>())) { <option value="@c">@c</option> }
                    </select>
                </div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="DelPendQ" class="form-label fw-semibold">Delivery Pending Quantity</label>
                    <input asp-for="DelPendQ" type="number" step="0.0001" class="form-control" placeholder="0" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Date" class="form-label fw-semibold">Date</label>
                    <input asp-for="Date" type="date" class="form-control" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div></div>
