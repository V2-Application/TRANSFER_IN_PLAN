@{
    ViewData["Title"] = "Dashboard";
}
@model TRANSFER_IN_PLAN.Models.DashboardViewModel
@using System.Text.Json

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h5 class="mb-0 fw-bold text-primary">
        <i class="bi bi-speedometer2 me-2"></i>Analytics Dashboard
    </h5>
    <small class="text-muted">
        @if (Model.LastExecutionDate.HasValue)
        { <span><i class="bi bi-clock me-1"></i>Last Run: @Model.LastExecutionDate.Value.ToString("dd-MMM-yyyy HH:mm")</span> }
        else
        { <span class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>No plan executed yet</span> }
    </small>
</div>

@* ── KPI Row 1: Transfer In ──────────────────────────────────────────── *@
<div class="row g-2 g-md-3 mb-2 mb-md-3 kpi-row">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #e74c3c !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#fdecea;">
                    <i class="bi bi-shop text-danger"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">Total Stores</div>
                    <div class="fw-bold fs-4 text-dark">@Model.TotalStores.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #27ae60 !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#eafaf1;">
                    <i class="bi bi-tags text-success"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">Categories</div>
                    <div class="fw-bold fs-4 text-dark">@Model.TotalCategories.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #2980b9 !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#eaf4fb;">
                    <i class="bi bi-arrow-left-right text-primary"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">TrfIn Qty</div>
                    <div class="fw-bold fs-4 text-dark">@((Model.TotalTrfInQty/1000).ToString("N1"))K</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #8e44ad !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#f5eef8;">
                    <i class="bi bi-list-check" style="color:#8e44ad;"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">TrfIn Rows</div>
                    <div class="fw-bold fs-4 text-dark">@((Model.TotalPlanRows/1000).ToString("N0"))K</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── KPI Row 2: Purchase Plan ────────────────────────────────────────── *@
<div class="row g-2 g-md-3 mb-3 mb-md-4 kpi-row">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #f39c12 !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#fef9e7;">
                    <i class="bi bi-bag-check" style="color:#f39c12;"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">PP Purchase Qty</div>
                    <div class="fw-bold fs-4 text-dark">@((Model.TotalPurchaseQty/1000).ToString("N1"))K</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #c0392b !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#fdedec;">
                    <i class="bi bi-exclamation-triangle text-danger"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">DC Short Qty</div>
                    <div class="fw-bold fs-4 text-danger">@((Model.TotalDcStkShortQ/1000).ToString("N1"))K</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #16a085 !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#e8f8f5;">
                    <i class="bi bi-check-circle" style="color:#16a085;"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">DC Excess Qty</div>
                    <div class="fw-bold fs-4" style="color:#16a085;">@((Model.TotalDcStkExcessQ/1000).ToString("N1"))K</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm kpi-card h-100" style="border-left:4px solid #7f8c8d !important;">
            <div class="card-body d-flex align-items-center gap-2 gap-md-3 py-2 py-md-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:42px;height:42px;background:#f2f3f4;">
                    <i class="bi bi-bar-chart-fill text-secondary"></i>
                </div>
                <div class="min-w-0">
                    <div class="text-muted small text-uppercase fw-semibold text-truncate">PP Rows</div>
                    <div class="fw-bold fs-4 text-dark">@((Model.TotalPurchasePlanRows/1000).ToString("N0"))K</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Charts Row 1: TrfIn Category + Weekly ──────────────────────────── *@
<div class="row g-2 g-md-3 mb-2 mb-md-3">
    <div class="col-12 col-md-6 chart-col">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3 pb-1">
                <h6 class="fw-bold text-primary mb-0 fs-6"><i class="bi bi-bar-chart me-2"></i>Transfer In by Category (Top 15)</h6>
            </div>
            <div class="card-body pt-1 pb-3">
                <div class="chart-container"><canvas id="catChart"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 chart-col">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3 pb-1">
                <h6 class="fw-bold text-success mb-0 fs-6"><i class="bi bi-graph-up me-2"></i>Weekly Transfer In Trend</h6>
            </div>
            <div class="card-body pt-1 pb-3">
                <div class="chart-container"><canvas id="weeklyChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

@* ── Charts Row 2: PP Category + PP Weekly ──────────────────────────── *@
<div class="row g-2 g-md-3 mb-2 mb-md-3">
    <div class="col-12 col-md-6 chart-col">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3 pb-1">
                <h6 class="fw-bold mb-0 fs-6" style="color:#f39c12;"><i class="bi bi-bar-chart-steps me-2"></i>Purchase Plan – DC Short vs Excess</h6>
            </div>
            <div class="card-body pt-1 pb-3">
                <div class="chart-container"><canvas id="ppCatChart"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 chart-col">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3 pb-1">
                <h6 class="fw-bold text-info mb-0 fs-6"><i class="bi bi-graph-up-arrow me-2"></i>Purchase Plan Weekly Trend</h6>
            </div>
            <div class="card-body pt-1 pb-3">
                <div class="chart-container"><canvas id="ppWeeklyChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

@* ── Charts Row 3: RDC + Short vs Excess ────────────────────────────── *@
<div class="row g-2 g-md-3 mb-2 mb-md-3">
    <div class="col-12 col-md-6 chart-col">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3 pb-1">
                <h6 class="fw-bold mb-0 fs-6" style="color:#8e44ad;"><i class="bi bi-building me-2"></i>RDC-wise Transfer In (Top 15)</h6>
            </div>
            <div class="card-body pt-1 pb-3">
                <div class="chart-container"><canvas id="rdcChart"></canvas></div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 chart-col">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 pt-3 pb-1">
                <h6 class="fw-bold text-danger mb-0 fs-6"><i class="bi bi-arrow-left-right me-2"></i>Category Short vs Excess (TrfIn)</h6>
            </div>
            <div class="card-body pt-1 pb-3">
                <div class="chart-container"><canvas id="shortExcessChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

@* ── Tables Row 1: Short / Excess Stores ────────────────────────────── *@
<div class="row g-2 g-md-3 mb-2 mb-md-3">
    <div class="col-12 col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-danger text-white py-2">
                <h6 class="mb-0 fw-bold fs-6"><i class="bi bi-arrow-down-circle me-2"><div class="d-flex justify-content-between align-items-center">
                    </i>Top 10 Short Stores (Transfer In)</h6>
                    <a href="@Url.Action("ExportTrfInCsv", "Home")" class="btn btn-success btn-sm"><i class="bi bi-filetype-csv me-1"></i>Export CSV</a>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light"><tr><th>Store</th><th>Name</th><th class="d-none d-sm-table-cell">Category</th><th class="text-end">Qty</th></tr></thead>
                        <tbody>
                        @foreach (var s in Model.TopShortStores)
                        {
                            <tr>
                                <td class="fw-semibold text-primary small">@s.StCd</td>
                                <td class="small">@s.StNm</td>
                                <td class="d-none d-sm-table-cell"><span class="badge bg-secondary">@s.MajCat</span></td>
                                <td class="text-end"><span class="badge bg-danger">@s.Quantity.ToString("N2")</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header text-white py-2" style="background:#f39c12;">
                <h6 class="mb-0 fw-bold fs-6"><i class="bi bi-arrow-up-circle me-2"><div class="d-flex justify-content-between align-items-center">
                    </i>Top 10 Excess Stores (Transfer In)</h6>
                    <a href="@Url.Action("ExportTrfInCsv", "Home")" class="btn btn-success btn-sm"><i class="bi bi-filetype-csv me-1"></i>Export CSV</a>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light"><tr><th>Store</th><th>Name</th><th class="d-none d-sm-table-cell">Category</th><th class="text-end">Qty</th></tr></thead>
                        <tbody>
                        @foreach (var s in Model.TopExcessStores)
                        {
                            <tr>
                                <td class="fw-semibold text-primary small">@s.StCd</td>
                                <td class="small">@s.StNm</td>
                                <td class="d-none d-sm-table-cell"><span class="badge bg-secondary">@s.MajCat</span></td>
                                <td class="text-end"><span class="badge" style="background:#f39c12;">@s.Quantity.ToString("N2")</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Tables Row 2: DC Short / Excess from PurchasePlan ──────────────── *@
<div class="row g-2 g-md-3 mb-4">
    <div class="col-12 col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header text-white py-2" style="background:#c0392b;">
                <h6 class="mb-0 fw-bold fs-6"><i class="bi bi-database-x me-2"><div class="d-flex justify-content-between align-items-center">
                    </i>Top 10 DC Short (Purchase Plan)</h6>
                    <a href="@Url.Action("ExportPpCsv", "Home")" class="btn btn-success btn-sm"><i class="bi bi-filetype-csv me-1"></i>Export CSV</a>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light"><tr><th>RDC</th><th class="d-none d-sm-table-cell">RDC Name</th><th>Category</th><th class="text-end">Qty</th></tr></thead>
                        <tbody>
                        @foreach (var d in Model.TopDcShortCategories)
                        {
                            <tr>
                                <td class="fw-semibold text-danger small">@d.RdcCd</td>
                                <td class="small d-none d-sm-table-cell">@d.RdcNm</td>
                                <td><span class="badge bg-secondary">@d.MajCat</span></td>
                                <td class="text-end"><span class="badge bg-danger">@d.Quantity.ToString("N2")</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header text-white py-2" style="background:#16a085;">
                <h6 class="mb-0 fw-bold fs-6"><i class="bi bi-database-check me-2"><div class="d-flex justify-content-between align-items-center">
                    </i>Top 10 DC Excess (Purchase Plan)</h6>
                    <a href="@Url.Action("ExportPpCsv", "Home")" class="btn btn-success btn-sm"><i class="bi bi-filetype-csv me-1"></i>Export CSV</a>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light"><tr><th>RDC</th><th class="d-none d-sm-table-cell">RDC Name</th><th>Category</th><th class="text-end">Qty</th></tr></thead>
                        <tbody>
                        @foreach (var d in Model.TopDcExcessCategories)
                        {
                            <tr>
                                <td class="fw-semibold small" style="color:#16a085;">@d.RdcCd</td>
                                <td class="small d-none d-sm-table-cell">@d.RdcNm</td>
                                <td><span class="badge bg-secondary">@d.MajCat</span></td>
                                <td class="text-end"><span class="badge" style="background:#16a085;">@d.Quantity.ToString("N2")</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    Chart.defaults.font.family = "'Segoe UI', system-ui, sans-serif";
    Chart.defaults.font.size = 11;
    const isMobile = window.innerWidth < 768;
    const COLORS = ['#2980b9','#27ae60','#e74c3c','#f39c12','#8e44ad','#16a085',
                    '#c0392b','#2c3e50','#d35400','#1abc9c','#e67e22','#3498db',
                    '#9b59b6','#1e8bc3','#2ecc71'];

    const chartOpts = {
        responsive: true,
        maintainAspectRatio: true,
        plugins: { legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11 } } } },
        scales: { y: { beginAtZero: true, ticks: { font: { size: 10 } } },
                  x: { ticks: { font: { size: 10 }, maxRotation: 45 } } }
    };

    // 1. TrfIn by Category
    new Chart(document.getElementById('catChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(Model.CategorySummary.Select(c=>c.MajCat).ToList())),
            datasets: [{ label:'TrfIn Qty',
                data: @Html.Raw(JsonSerializer.Serialize(Model.CategorySummary.Select(c=>c.TotalTrfInQty).ToList())),
                backgroundColor: COLORS, borderRadius: 4 }]
        },
        options: { ...chartOpts, plugins: { legend: { display: false } } }
    });

    // 2. TrfIn Weekly
    new Chart(document.getElementById('weeklyChart'), {
        type: 'line',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(Model.WeeklySummary.Select(w=>"FY"+w.FyYear+"W"+w.FyWeek).ToList())),
            datasets: [{ label:'TrfIn Qty', fill:true,
                data: @Html.Raw(JsonSerializer.Serialize(Model.WeeklySummary.Select(w=>w.TotalTrfInQty).ToList())),
                borderColor:'#2980b9', backgroundColor:'rgba(41,128,185,0.1)', tension:0.35, pointRadius:2 }]
        },
        options: chartOpts
    });

    // 3. PP Category grouped bar
    new Chart(document.getElementById('ppCatChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(Model.PpCategorySummary.Select(c=>c.MajCat).ToList())),
            datasets: [
                { label:'DC Short',    data: @Html.Raw(JsonSerializer.Serialize(Model.PpCategorySummary.Select(c=>c.DcStkShortQ).ToList())),  backgroundColor:'rgba(192,57,43,0.8)',  borderRadius:3 },
                { label:'DC Excess',   data: @Html.Raw(JsonSerializer.Serialize(Model.PpCategorySummary.Select(c=>c.DcStkExcessQ).ToList())), backgroundColor:'rgba(22,160,133,0.8)', borderRadius:3 },
                { label:'Bgt Purchase',data: @Html.Raw(JsonSerializer.Serialize(Model.PpCategorySummary.Select(c=>c.BgtPurQ).ToList())),      backgroundColor:'rgba(243,156,18,0.6)',  borderRadius:3 }
            ]
        },
        options: chartOpts
    });

    // 4. PP Weekly multi-line
    new Chart(document.getElementById('ppWeeklyChart'), {
        type: 'line',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(Model.PpWeeklySummary.Select(w=>"FY"+w.FyYear+"W"+w.FyWeek).ToList())),
            datasets: [
                { label:'Bgt Purchase', fill:true,
                  data: @Html.Raw(JsonSerializer.Serialize(Model.PpWeeklySummary.Select(w=>w.BgtPurQ).ToList())),
                  borderColor:'#f39c12', backgroundColor:'rgba(243,156,18,0.1)', tension:0.35, pointRadius:2 },
                { label:'DC Short', fill:false,
                  data: @Html.Raw(JsonSerializer.Serialize(Model.PpWeeklySummary.Select(w=>w.DcStkShortQ).ToList())),
                  borderColor:'#e74c3c', backgroundColor:'transparent', tension:0.35, pointRadius:2, borderDash:[5,3] },
                { label:'DC Excess', fill:false,
                  data: @Html.Raw(JsonSerializer.Serialize(Model.PpWeeklySummary.Select(w=>w.DcStkExcessQ).ToList())),
                  borderColor:'#16a085', backgroundColor:'transparent', tension:0.35, pointRadius:2, borderDash:[5,3] }
            ]
        },
        options: chartOpts
    });

    // 5. RDC horizontal bar
    new Chart(document.getElementById('rdcChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(Model.RdcSummary.Select(r=>r.RdcCd+(r.RdcNm!=null?" - "+r.RdcNm.Substring(0,Math.Min(r.RdcNm.Length,10)):"")).ToList())),
            datasets: [{ label:'TrfIn Qty',
                data: @Html.Raw(JsonSerializer.Serialize(Model.RdcSummary.Select(r=>r.TotalTrfInQty).ToList())),
                backgroundColor:'rgba(142,68,173,0.75)', borderRadius:3 }]
        },
        options: { ...chartOpts, indexAxis:'y', plugins:{ legend:{ display:false } } }
    });

    // 6. Short vs Excess by category
    new Chart(document.getElementById('shortExcessChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(JsonSerializer.Serialize(Model.CategorySummary.Select(c=>c.MajCat).ToList())),
            datasets: [
                { label:'Short Qty',  data: @Html.Raw(JsonSerializer.Serialize(Model.CategorySummary.Select(c=>c.TotalShortQ).ToList())),  backgroundColor:'rgba(231,76,60,0.8)',  borderRadius:3 },
                { label:'Excess Qty', data: @Html.Raw(JsonSerializer.Serialize(Model.CategorySummary.Select(c=>c.TotalExcessQ).ToList())), backgroundColor:'rgba(243,156,18,0.8)', borderRadius:3 }
            ]
        },
        options: chartOpts
    });
})();
</script>
}
