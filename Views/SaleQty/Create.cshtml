@{
    ViewData["Title"] = "Create Sale Qty";
}

@model SaleQty

<div class="row">
    <div class="col-md-10">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Add New Sale Quantity</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StCd" class="form-label">Store Code</label>
                            <input asp-for="StCd" class="form-control" />
                            <span asp-validation-for="StCd" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MajCat" class="form-label">Major Category</label>
                            <input asp-for="MajCat" class="form-control" />
                            <span asp-validation-for="MajCat" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="table-responsive mb-3">
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <td><label asp-for="Wk1" class="form-label">Week 1</label><input asp-for="Wk1" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk2" class="form-label">Week 2</label><input asp-for="Wk2" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk3" class="form-label">Week 3</label><input asp-for="Wk3" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk4" class="form-label">Week 4</label><input asp-for="Wk4" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk5" class="form-label">Week 5</label><input asp-for="Wk5" type="number" step="0.01" class="form-control" /></td>
                                </tr>
                                <tr>
                                    <td><label asp-for="Wk6" class="form-label">Week 6</label><input asp-for="Wk6" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk7" class="form-label">Week 7</label><input asp-for="Wk7" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk8" class="form-label">Week 8</label><input asp-for="Wk8" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk9" class="form-label">Week 9</label><input asp-for="Wk9" type="number" step="0.01" class="form-control" /></td>
                                    <td><label asp-for="Wk10" class="form-label">Week 10</label><input asp-for="Wk10" type="number" step="0.01" class="form-control" /></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Create
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
