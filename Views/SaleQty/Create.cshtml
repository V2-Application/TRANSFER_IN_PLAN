@{ ViewData["Title"] = "Create Sale Qty"; }
@model SaleQty

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-2"><h5 class="card-title mb-0"><i class="bi bi-plus-circle me-2 text-success"></i>Add New Sale Quantity</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="StCd" class="form-label fw-semibold">Store Code <span class="text-danger">*</span></label>
                    <select asp-for="StCd" class="form-select form-select-sm search-select" required>
                        <option value="">-- Select Store --</option>
                        @foreach (var s in (ViewBag.StoreCodes as IEnumerable<string> ?? new List<string>())) { <option value="@s">@s</option> }
                    </select>
                    <span asp-validation-for="StCd" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MajCat" class="form-label fw-semibold">Major Category <span class="text-danger">*</span></label>
                    <select asp-for="MajCat" class="form-select form-select-sm search-select" required>
                        <option value="">-- Select Category --</option>
                        @foreach (var c in (ViewBag.MajCats as IEnumerable<string> ?? new List<string>())) { <option value="@c">@c</option> }
                    </select>
                    <span asp-validation-for="MajCat" class="text-danger small"></span>
                </div>
            </div>

            <h6 class="fw-bold text-muted mb-2"><i class="bi bi-calendar-week me-1"></i>Weekly Sale Quantities (WK 1 - 48)</h6>
            <div class="row g-2 mb-3">
                @for (int w = 1; w <= 48; w++)
                {
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                        <label class="form-label small text-muted mb-0">WK @w</label>
                        <input name="Wk@(w)" type="number" step="0.0001" class="form-control form-control-sm" value="@(ViewData.Model != null ? typeof(SaleQty).GetProperty("Wk"+w)?.GetValue(ViewData.Model) : "")" placeholder="0" />
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Create</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
