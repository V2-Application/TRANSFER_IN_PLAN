@{ ViewData["Title"] = "Store Calendar"; }
@model IEnumerable<TRANSFER_IN_PLAN.Models.StoreCalendar>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0"><i class="bi bi-calendar-check me-2" style="color:#059669;"></i>Store Calendar</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>Add</a>
        <a asp-action="ExportCsv" asp-route-st="@ViewBag.St" asp-route-fy="@ViewBag.Fy" asp-route-fyWeek="@ViewBag.FyWeek" class="btn btn-success btn-sm"><i class="bi bi-download me-1"></i>CSV</a>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col-6 col-sm-4"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #2980b9 !important;"><div class="fw-bold fs-5" style="color:#2980b9;">@(((int)(ViewBag.TotalRows ?? 0)).ToString("N0"))</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">Total Rows</div></div></div>
    <div class="col-6 col-sm-4"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #27ae60 !important;"><div class="fw-bold fs-5" style="color:#27ae60;">@ViewBag.TotalStores</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">Stores</div></div></div>
    <div class="col-6 col-sm-4"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #E67E22 !important;"><div class="fw-bold fs-5" style="color:#E67E22;">@(((int)(ViewBag.TotalCount ?? 0)).ToString("N0"))</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">Filtered</div></div></div>
</div>

<div class="card shadow-sm border-0 mb-2"><div class="card-body py-2">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Store</label>
            <select name="st" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var s in (ViewBag.Stores as List<string> ?? new())) { <option value="@s" selected="@(s == ViewBag.St?.ToString())">@s</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">FY</label>
            <select name="fy" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var f in (ViewBag.FyList as List<string> ?? new())) { <option value="@f" selected="@(f == ViewBag.Fy?.ToString())">@f</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">FY Week</label>
            <select name="fyWeek" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var w in (ViewBag.FyWeeks as List<string> ?? new())) { <option value="@w" selected="@(w == ViewBag.FyWeek?.ToString())">@w</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Page Size</label>
            <select name="pageSize" class="form-select form-select-sm">
                @foreach (var ps in new[] { 50, 100, 250, 500 }) { <option value="@ps" selected="@(ViewBag.PageSize?.ToString() == ps.ToString())">@ps</option> }
            </select></div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Clear</a>
        </div>
    </form>
</div></div>

@if (ViewBag.TotalCount != null) { <div class="alert alert-info py-1 small mb-2"><i class="bi bi-info-circle me-1"></i>Showing <strong>@Model.Count()</strong> of <strong>@(((int)ViewBag.TotalCount).ToString("N0"))</strong> (Page @ViewBag.Page)</div> }

<div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover table-bordered table-sm mb-0 small">
        <thead class="table-dark"><tr><th>ST_CD</th><th>BGT_MNTH_DATE</th><th>YEAR</th><th>FY</th><th>MONTH</th><th>YEAR_WEEK</th><th>FY_WEEK</th><th>FY_WK_ST</th><th>FY_WK_END</th><th>DAY</th><th>LY_SAME_DATE</th><th class="text-center">Actions</th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold text-primary">@item.StCd</td>
                    <td>@item.BgtMnthDate?.ToString("yyyy-MM-dd")</td>
                    <td>@item.Year</td><td>@item.Fy</td><td>@item.Month</td>
                    <td>@item.YearWeek</td><td>@item.FyWeek</td>
                    <td>@item.FyWeekStDt?.ToString("yyyy-MM-dd")</td>
                    <td>@item.FyWeekEndDt?.ToString("yyyy-MM-dd")</td>
                    <td>@item.Day</td>
                    <td>@item.LySameDate?.ToString("yyyy-MM-dd")</td>
                    <td class="text-center text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning py-0"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger py-0"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="12" class="text-center text-muted py-3">No data.</td></tr> }
        </tbody>
    </table>
</div></div></div>

@if (ViewBag.TotalCount != null && ViewBag.PageSize != null) { var totalPages = (int)Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize); if (totalPages > 1) {
    <nav class="mt-2"><ul class="pagination pagination-sm justify-content-center flex-wrap">
        @for (int p = Math.Max(1, (int)ViewBag.Page - 4); p <= Math.Min(totalPages, (int)ViewBag.Page + 4); p++)
        { <li class="page-item @(p == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Index", new { st = ViewBag.St, fy = ViewBag.Fy, fyWeek = ViewBag.FyWeek, page = p, pageSize = ViewBag.PageSize })">@p</a></li> }
    </ul></nav> } }
