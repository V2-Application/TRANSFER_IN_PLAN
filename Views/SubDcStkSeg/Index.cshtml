@{ ViewData["Title"] = "DC Stock - Segment"; }
@model IEnumerable<TRANSFER_IN_PLAN.Models.SubDcStkSeg>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0"><i class="bi bi-building me-2"></i>DC Stock - Segment</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>Add</a>
        <a asp-action="ExportCsv" asp-route-rdcCd="@ViewBag.RdcCd" asp-route-majCat="@ViewBag.MajCat" class="btn btn-success btn-sm"><i class="bi bi-download me-1"></i>CSV</a>
    </div>
</div>

@{ ViewBag.Kpi2Label = "RDCs"; ViewBag.Kpi2Value = ViewBag.TotalRdcs; ViewBag.Kpi2Color = "#27ae60";
   ViewBag.Kpi3Label = "Categories"; ViewBag.Kpi3Value = ViewBag.TotalCats; ViewBag.Kpi3Color = "#8e44ad"; }
<partial name="_RefTableAnalytics" />

@if (TempData["SuccessMessage"] != null) { <div class="alert alert-success alert-dismissible fade show py-2"><i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<div class="card shadow-sm border-0 mb-2"><div class="card-body py-2">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">RDC Code</label>
            <select name="rdcCd" class="form-select form-select-sm search-select"><option value="">-- All --</option>
                @foreach (var r in (ViewBag.RdcCodes as IEnumerable<string> ?? new List<string>())) { <option value="@r" selected="@(r == ViewBag.RdcCd?.ToString() ? "selected" : null)">@r</option> }
            </select></div>
        <div class="col-md-3"><label class="form-label small fw-semibold mb-0">Category</label>
            <select name="majCat" class="form-select form-select-sm search-select"><option value="">-- All --</option>
                @foreach (var c in (ViewBag.MajCats as IEnumerable<string> ?? new List<string>())) { <option value="@c" selected="@(c == ViewBag.MajCat?.ToString() ? "selected" : null)">@c</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Segment</label>
            <select name="subValue" class="form-select form-select-sm search-select"><option value="">-- All --</option>
                @foreach (var v in (ViewBag.SubValues as IEnumerable<string> ?? new List<string>())) { <option value="@v" selected="@(v == ViewBag.SubValue?.ToString() ? "selected" : null)">@v</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Page Size</label>
            <select name="pageSize" class="form-select form-select-sm">
                @foreach (var ps in new[] { 50, 100, 250, 500 }) { <option value="@ps" selected="@(ViewBag.PageSize?.ToString() == ps.ToString() ? "selected" : null)">@ps</option> }
            </select></div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Clear</a>
        </div>
    </form>
</div></div>

@if (ViewBag.TotalCount != null) { <div class="alert alert-info py-1 small mb-2"><i class="bi bi-info-circle me-1"></i>Showing <strong>@Model.Count()</strong> of <strong>@(((int)ViewBag.TotalCount).ToString("N0"))</strong> (Page @ViewBag.Page)</div> }

<div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover table-bordered table-sm mb-0 small" id="dataTable">
        <thead class="table-dark"><tr><th>RDC CD</th><th>MAJ CAT</th><th>Segment</th><th class="text-end">DC STK Q</th><th class="text-end">GRT STK Q</th><th class="text-end">W GRT STK Q</th><th>DATE</th><th class="text-center">Actions</th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold text-primary">@item.RdcCd</td><td>@item.MajCat</td><td class="fw-semibold">@item.SubValue</td>
                    <td class="text-end">@item.DcStkQ.ToString("N4")</td><td class="text-end">@item.GrtStkQ.ToString("N4")</td><td class="text-end">@item.WGrtStkQ.ToString("N4")</td>
                    <td>@(item.Date?.ToString("yyyy-MM-dd") ?? "NA")</td>
                    <td class="text-center text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning py-0"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger py-0"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="8" class="text-center text-muted py-3">No data.</td></tr> }
        </tbody>
    </table>
</div></div></div>

@if (ViewBag.TotalCount != null && ViewBag.PageSize != null) { var totalPages = (int)Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize); if (totalPages > 1) {
    <nav class="mt-2"><ul class="pagination pagination-sm justify-content-center flex-wrap">
        @for (int p = Math.Max(1, (int)ViewBag.Page - 4); p <= Math.Min(totalPages, (int)ViewBag.Page + 4); p++)
        { <li class="page-item @(p == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Index", new { rdcCd = ViewBag.RdcCd, majCat = ViewBag.MajCat, subValue = ViewBag.SubValue, page = p, pageSize = ViewBag.PageSize })">@p</a></li> }
    </ul></nav> } }

@section Scripts { <script>$(function(){ if($('#dataTable tbody tr').length > 0 && !$('#dataTable tbody .text-muted').length && !$.fn.DataTable.isDataTable('#dataTable')){ $('#dataTable').DataTable({paging:false,ordering:true,searching:true,dom:'lrtip'}); } });</script> }
