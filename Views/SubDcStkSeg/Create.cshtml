@{ ViewData["Title"] = "Add DC Stock - Segment"; }
@model TRANSFER_IN_PLAN.Models.SubDcStkSeg
<h3 class="mb-3"><i class="bi bi-plus-circle me-2"></i>Add DC Stock - Segment</h3>
<div class="card shadow-sm border-0" style="max-width:700px;"><div class="card-body">
    <form asp-action="Create" method="post">
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label fw-semibold">RDC Code</label><input asp-for="RdcCd" class="form-control form-control-sm" required /></div>
            <div class="col-md-4"><label class="form-label fw-semibold">Category</label><input asp-for="MajCat" class="form-control form-control-sm" required /></div>
            <div class="col-md-4"><label class="form-label fw-semibold">Segment</label><input asp-for="SubValue" class="form-control form-control-sm" required /></div>
            <div class="col-md-4"><label class="form-label fw-semibold">DC Stock Qty</label><input asp-for="DcStkQ" class="form-control form-control-sm" type="number" step="0.0001" required /></div>
            <div class="col-md-4"><label class="form-label fw-semibold">GRT Stock Qty</label><input asp-for="GrtStkQ" class="form-control form-control-sm" type="number" step="0.0001" /></div>
            <div class="col-md-4"><label class="form-label fw-semibold">W GRT Stock Qty</label><input asp-for="WGrtStkQ" class="form-control form-control-sm" type="number" step="0.0001" /></div>
            <div class="col-md-4"><label class="form-label fw-semibold">Date</label><input asp-for="Date" class="form-control form-control-sm" type="date" /></div>
        </div>
        <div class="mt-3 d-flex gap-2"><button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-circle me-1"></i>Save</button><a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a></div>
    </form>
</div></div>
