@model TRANSFER_IN_PLAN.Models.WeeklyDisaggViewModel
@{ ViewData["Title"] = "Weekly Disaggregation"; }

<div class="mb-4">
    <h3 class="mb-1"><i class="bi bi-calendar3 me-2 text-info"></i>Weekly Disaggregation</h3>
    <small class="text-muted">Split monthly budgets into 48 weekly columns → feeds into Transfer In Plan & Purchase Plan</small>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <!-- Input Status -->
        <div class="card shadow-sm border-0 mb-3" style="border-left:4px solid #0284C7 !important;">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-inbox me-2 text-info"></i>Input Data Status</h6></div>
            <div class="card-body p-0 small">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-dark"><tr><th>Source</th><th>Table</th><th class="text-end">Rows</th><th>Status</th></tr></thead>
                    <tbody>
                        <tr><td>Plan 1 Output</td><td><code>SALE_BUDGET_PLAN</code></td><td class="text-end">@Model.SaleBudgetRows.ToString("N0")</td><td>@(Model.SaleBudgetRows > 0 ? Html.Raw("<span class='badge bg-success'>Ready</span>") : Html.Raw("<span class='badge bg-danger'>Empty</span>"))</td></tr>
                        <tr><td>Plan 2 Output</td><td><code>FIXTURE_DENSITY_PLAN</code></td><td class="text-end">@Model.FixturePlanRows.ToString("N0")</td><td>@(Model.FixturePlanRows > 0 ? Html.Raw("<span class='badge bg-success'>Ready</span>") : Html.Raw("<span class='badge bg-danger'>Empty</span>"))</td></tr>
                        <tr><td>Reference</td><td><code>WEEK_CALENDAR</code></td><td class="text-end">@Model.WeekCalendarRows.ToString("N0")</td><td>@(Model.WeekCalendarRows > 0 ? Html.Raw("<span class='badge bg-success'>Ready</span>") : Html.Raw("<span class='badge bg-danger'>Empty</span>"))</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.SaleBudgetRows == 0 || Model.WeekCalendarRows == 0)
        {
            <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1"></i>Run <a href="@Url.Action("Execute", "SaleBudget")">Sale Budget Plan</a> and ensure <a href="@Url.Action("Index", "WeekCalendar")">Week Calendar</a> is uploaded before disaggregating.</div>
        }

        <!-- Execute -->
        <div class="card shadow-sm border-0 mb-3" style="border-left:4px solid #059669 !important;">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-play-fill me-2 text-success"></i>Run Disaggregation</h6></div>
            <div class="card-body small">
                <p class="text-muted mb-2">This will:</p>
                <ol class="text-muted mb-3">
                    <li><strong>SALE_BUDGET_PLAN</strong> (monthly BGT_SALE_QTY) → <strong>QTY_SALE_QTY</strong> (48 weekly columns)</li>
                    <li><strong>FIXTURE_DENSITY_PLAN</strong> (monthly BGT_DISP_QTY) → <strong>QTY_DISP_QTY</strong> (48 weekly columns)</li>
                </ol>
                <label class="form-label fw-bold">Distribution Method</label>
                <div class="form-check mb-1">
                    <input type="radio" class="form-check-input" name="disaggMethod" value="SEASONAL_CURVE" id="mSeasonal" checked />
                    <label class="form-check-label" for="mSeasonal"><strong>Seasonal Curve</strong> <small class="text-muted">(Wk1: 28%, Wk2: 26%, Wk3: 24%, Wk4: 22% — payday weighted)</small></label>
                </div>
                <div class="form-check mb-3">
                    <input type="radio" class="form-check-input" name="disaggMethod" value="EQUAL_SPLIT" id="mEqual" />
                    <label class="form-check-label" for="mEqual"><strong>Equal Split</strong> <small class="text-muted">(monthly qty ÷ weeks evenly)</small></label>
                </div>
                <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle-fill me-1"></i>This will <strong>TRUNCATE</strong> existing QTY_SALE_QTY and QTY_DISP_QTY tables and replace with budget-derived data.</div>
                <button class="btn btn-success w-100" id="btnRun" onclick="startDisagg()" @(Model.SaleBudgetRows == 0 || Model.WeekCalendarRows == 0 ? "disabled" : "")>
                    <i class="bi bi-calendar3 me-1"></i>Disaggregate Monthly → Weekly
                </button>
            </div>
        </div>

        <!-- Progress -->
        <div class="card shadow-sm border-0 d-none" id="progressCard">
            <div class="card-body small">
                <div class="d-flex justify-content-between mb-1"><strong id="pPhase"></strong><span class="text-muted" id="pElapsed"></span></div>
                <div class="progress mb-2" style="height:5px;"><div class="progress-bar bg-info" id="pBar" style="width:0%;"></div></div>
                <div id="pStatus" class="text-muted"></div>
                <div id="pError" class="alert alert-danger py-2 mt-2 d-none"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <!-- Current Output Status -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-table me-2"></i>Current Weekly Tables</h6></div>
            <div class="card-body small">
                <div class="d-flex justify-content-between mb-1"><span>QTY_SALE_QTY</span><strong>@Model.SaleQtyRows.ToString("N0") rows</strong></div>
                <div class="d-flex justify-content-between mb-2"><span>QTY_DISP_QTY</span><strong>@Model.DispQtyRows.ToString("N0") rows</strong></div>
                <div class="alert alert-info py-2 mb-0"><i class="bi bi-arrow-right me-1"></i>After disaggregation, run <a href="@Url.Action("Execute", "Plan")">Transfer In Plan</a> → <a href="@Url.Action("Execute", "PurchasePlan")">Purchase Plan</a></div>
            </div>
        </div>

        <!-- Recent Runs -->
        @if (Model.RecentRuns.Any())
        {
        <div class="card shadow-sm border-0">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Runs</h6></div>
            <div class="card-body p-0 small">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-dark"><tr><th>Run</th><th>Target</th><th class="text-end">Rows</th><th>Date</th></tr></thead>
                    <tbody>
                        @foreach (var r in Model.RecentRuns)
                        {
                            <tr><td><code>@r.RunId</code></td><td>@r.TargetTable</td><td class="text-end">@r.RowsWritten.ToString("N0")</td><td>@r.CreatedDt?.ToString("dd-MMM HH:mm")</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        }

        <!-- Pipeline -->
        <div class="card shadow-sm border-0 mt-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Pipeline Position</h6></div>
            <div class="card-body small text-center">
                <span class="badge" style="background:#8B5CF6;">Plan 1: Sale Budget</span>
                <span class="badge" style="background:#E67E22;">Plan 2: Fixture</span><br>
                <i class="bi bi-arrow-down text-info"></i><br>
                <span class="badge bg-info text-white fw-bold">Plan 3: Weekly Disagg (YOU ARE HERE)</span><br>
                <i class="bi bi-arrow-down text-success"></i><br>
                <span class="badge bg-success">Plan 4: TRF</span>
                <span class="badge" style="background:#8e44ad;color:#fff;">Plan 5: PP</span><br>
                <i class="bi bi-arrow-down"></i><br>
                <span class="badge bg-secondary">Plan 6-7: Sub-Level</span>
                <span class="badge bg-dark">Plan 8: ARS</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function startDisagg() {
    if (!confirm('This will REPLACE QTY_SALE_QTY and QTY_DISP_QTY. Continue?')) return;
    document.getElementById('btnRun').disabled = true;
    document.getElementById('progressCard').classList.remove('d-none');
    var fd = new FormData(); fd.append('method', document.querySelector('input[name=disaggMethod]:checked').value);
    fetch('@Url.Action("StartDisagg")', { method: 'POST', body: fd }).then(r => r.json()).then(d => { if (d.success) poll(); else { alert(d.message); document.getElementById('btnRun').disabled = false; } });
}
var pt;
function poll() {
    pt = setInterval(() => {
        fetch('@Url.Action("JobStatus")').then(r => r.json()).then(d => {
            document.getElementById('pPhase').textContent = d.phase;
            document.getElementById('pStatus').textContent = d.status;
            document.getElementById('pElapsed').textContent = d.elapsedSeconds + 's';
            var pct = d.phase === 'Loading' ? 15 : d.phase === 'Disaggregating' ? 50 : d.phase === 'Writing' ? 85 : d.phase === 'Done' ? 100 : 5;
            document.getElementById('pBar').style.width = pct + '%';
            if (d.error) { document.getElementById('pError').textContent = d.error; document.getElementById('pError').classList.remove('d-none'); }
            if (!d.isRunning) { clearInterval(pt); document.getElementById('btnRun').disabled = false; if (d.phase === 'Done') setTimeout(() => location.reload(), 1500); }
        });
    }, 3000);
}
</script>
}
