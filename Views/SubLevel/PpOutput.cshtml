@{ ViewData["Title"] = $"Purchase Plan — {ViewBag.LevelLabel} Level"; }
@model IEnumerable<TRANSFER_IN_PLAN.Models.SubLevelPpRow>

<div class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h3 class="mb-0"><i class="bi bi-layers me-2"></i>Purchase Plan — @ViewBag.LevelLabel Level</h3>
        <small class="text-muted">Sale Qty &amp; Display Qty split by @ViewBag.LevelLabel contribution (RDC-level avg)</small>
    </div>
    @if (ViewBag.TotalCount != null)
    {
        <div class="d-flex gap-2">
            <a href="@Url.Action("ExportPpCsv", new { level = ViewBag.Level, rdcCd = ViewBag.RdcCd, majCat = ViewBag.MajCat, fyYear = ViewBag.FyYear, fyWeek = ViewBag.FyWeek })" class="btn btn-success btn-sm"><i class="bi bi-filetype-csv me-1"></i>Export CSV</a>
            <a href="@Url.Action("ExportPpPivotCsv", new { level = ViewBag.Level, rdcCd = ViewBag.RdcCd, majCat = ViewBag.MajCat })" class="btn btn-primary btn-sm"><i class="bi bi-grid-3x3 me-1"></i>Pivot CSV</a>
        </div>
    }
</div>

<!-- Level Tabs -->
<ul class="nav nav-pills mb-3">
    @foreach (var lk in (string[])ViewBag.LevelKeys)
    {
        var lbl = lk switch { "mvgr" => "TRF MVGR", "sz" => "TRF Size", "seg" => "TRF Seg", "vnd" => "TRF Vnd", _ => lk };
        <li class="nav-item">
            <a class="nav-link btn-outline-secondary" href="@Url.Action("TrfOutput", new { level = lk })">@lbl</a>
        </li>
    }
    <li class="nav-item ms-2"><span class="nav-link disabled text-muted">|</span></li>
    @foreach (var lk in (string[])ViewBag.LevelKeys)
    {
        var lbl = lk switch { "mvgr" => "PP MVGR", "sz" => "PP Size", "seg" => "PP Seg", "vnd" => "PP Vnd", _ => lk };
        <li class="nav-item">
            <a class="nav-link @(lk == ViewBag.Level ? "active" : "")" href="@Url.Action("PpOutput", new { level = lk })">@lbl</a>
        </li>
    }
</ul>

<!-- Filters -->
<div class="card mb-3 shadow-sm border-0">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="level" value="@ViewBag.Level" />
            <div class="col-md-2"><label class="form-label small fw-semibold mb-0">FY Year</label><input type="number" name="fyYear" class="form-control form-control-sm" value="@ViewBag.FyYear" placeholder="e.g. 2026" /></div>
            <div class="col-md-2"><label class="form-label small fw-semibold mb-0">FY Week</label><input type="number" name="fyWeek" class="form-control form-control-sm" value="@ViewBag.FyWeek" placeholder="e.g. 1" /></div>
            <div class="col-md-2"><label class="form-label small fw-semibold mb-0">RDC Code</label>
                <select name="rdcCd" class="form-select form-select-sm search-select"><option value="">-- All --</option>
                    @foreach (var r in (ViewBag.RdcCodes as IEnumerable<string> ?? new List<string>())) { <option value="@r" selected="@(r == ViewBag.RdcCd?.ToString() ? "selected" : null)">@r</option> }
                </select></div>
            <div class="col-md-3"><label class="form-label small fw-semibold mb-0">Category</label>
                <select name="majCat" class="form-select form-select-sm search-select"><option value="">-- All --</option>
                    @foreach (var c in (ViewBag.Categories as IEnumerable<string> ?? new List<string>())) { <option value="@c" selected="@(c == ViewBag.MajCat?.ToString() ? "selected" : null)">@c</option> }
                </select></div>
            <div class="col-md-1"><label class="form-label small fw-semibold mb-0">Size</label>
                <select name="pageSize" class="form-select form-select-sm">
                    @foreach (var ps in new[] { 50, 100, 250, 500 }) { <option value="@ps" selected="@(ViewBag.PageSize?.ToString() == ps.ToString() ? "selected" : null)">@ps</option> }
                </select></div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
                <a href="@Url.Action("PpOutput", new { level = ViewBag.Level })" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Clear</a>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.NotGenerated == true)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>Sub-level data not generated yet. Go to <a href="@Url.Action("Execute")">Sub-Level Plans</a> and click <strong>Generate</strong> first.</div>
}
else if (ViewBag.TotalCount != null)
{
    <div class="alert alert-info py-1 small mb-2"><i class="bi bi-info-circle me-1"></i>Showing <strong>@Model.Count()</strong> of <strong>@(((int)ViewBag.TotalCount).ToString("N0"))</strong> records (Page @ViewBag.Page)</div>

    <div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive">
        <table class="table table-hover table-bordered table-sm mb-0 small" id="subTable">
            <thead class="table-dark">
                <tr>
                    <th>RDC CD</th><th>MAJ CAT</th><th>@ViewBag.SubColName</th><th class="text-end">CONT%</th>
                    <th>YEAR</th><th>WEEK</th>
                    <th class="text-end bg-success bg-opacity-25">DISP QTY</th>
                    <th class="text-end bg-success bg-opacity-25">CW SALE</th>
                    <th class="text-end bg-success bg-opacity-25">CW1 SALE</th>
                    <th class="text-end bg-success bg-opacity-25">CW2 SALE</th>
                    <th class="text-end bg-success bg-opacity-25">CW3 SALE</th>
                    <th class="text-end bg-success bg-opacity-25">CW4 SALE</th>
                    <th class="text-end">PUR QTY</th>
                    <th class="text-end">DC CL STK</th>
                    <th class="text-end">DC CL MBQ</th>
                    <th class="text-end">DC MBQ SALE</th>
                    <th class="text-end">DC EXCESS</th>
                    <th class="text-end">DC SHORT</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@r.RdcCd</td>
                        <td>@r.MajCat</td>
                        <td class="fw-semibold">@r.SubLevel</td>
                        <td class="text-end">@r.ContPct.ToString("N4")</td>
                        <td>@r.FyYear</td><td>@r.FyWeek</td>
                        <td class="text-end table-success">@r.BgtDispClQ.ToString("N4")</td>
                        <td class="text-end table-success">@r.CwBgtSaleQ.ToString("N4")</td>
                        <td class="text-end table-success">@r.Cw1BgtSaleQ.ToString("N4")</td>
                        <td class="text-end table-success">@r.Cw2BgtSaleQ.ToString("N4")</td>
                        <td class="text-end table-success">@r.Cw3BgtSaleQ.ToString("N4")</td>
                        <td class="text-end table-success">@r.Cw4BgtSaleQ.ToString("N4")</td>
                        <td class="text-end">@r.BgtPurQInit.ToString("N4")</td>
                        <td class="text-end">@r.BgtDcClStkQ.ToString("N4")</td>
                        <td class="text-end">@r.BgtDcClMbq.ToString("N4")</td>
                        <td class="text-end">@r.BgtDcMbqSale.ToString("N4")</td>
                        <td class="text-end">@r.DcStkExcessQ.ToString("N4")</td>
                        <td class="text-end">@r.DcStkShortQ.ToString("N4")</td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="18" class="text-center text-muted py-3">No data found for selected filters.</td></tr> }
            </tbody>
        </table>
    </div></div></div>

    @if (ViewBag.TotalCount != null && ViewBag.PageSize != null)
    {
        var totalPages = (int)Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize);
        if (totalPages > 1)
        {
            <nav class="mt-2"><ul class="pagination pagination-sm justify-content-center flex-wrap">
                @for (int p = Math.Max(1, (int)ViewBag.Page - 4); p <= Math.Min(totalPages, (int)ViewBag.Page + 4); p++)
                { <li class="page-item @(p == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("PpOutput", new { level = ViewBag.Level, rdcCd = ViewBag.RdcCd, majCat = ViewBag.MajCat, fyYear = ViewBag.FyYear, fyWeek = ViewBag.FyWeek, page = p, pageSize = ViewBag.PageSize })">@p</a></li> }
            </ul></nav>
        }
    }
}

@section Scripts {
<script>$(function(){ if($('#subTable tbody tr').length > 0 && !$('#subTable tbody .text-muted').length && !$.fn.DataTable.isDataTable('#subTable')){ $('#subTable').DataTable({paging:false,ordering:true,searching:true,dom:'lrtip'}); } });</script>
}
