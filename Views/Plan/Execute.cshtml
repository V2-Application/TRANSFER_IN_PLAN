@{
    ViewData["Title"] = "Execute Plan Generation";
}

@model SpExecutionParams

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Execute SP_GENERATE_TRF_IN_PLAN</h5>
            </div>
            <div class="card-body">
                <form asp-action="Execute" method="post" id="executionForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartWeekId" class="form-label">Start Week ID</label>
                            <select asp-for="StartWeekId" class="form-select" asp-items="@(new SelectList(ViewBag.WeekCalendars, "WeekId", "YearWeek"))" required>
                                <option value="">-- Select Start Week --</option>
                            </select>
                            <span asp-validation-for="StartWeekId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="EndWeekId" class="form-label">End Week ID</label>
                            <select asp-for="EndWeekId" class="form-select" asp-items="@(new SelectList(ViewBag.WeekCalendars, "WeekId", "YearWeek"))" required>
                                <option value="">-- Select End Week --</option>
                            </select>
                            <span asp-validation-for="EndWeekId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StoreCode" class="form-label">Store Code (Optional)</label>
                            <input asp-for="StoreCode" class="form-control" placeholder="Leave blank for all stores" />
                            <span asp-validation-for="StoreCode" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="MajCat" class="form-label">Major Category (Optional)</label>
                            <input asp-for="MajCat" class="form-control" placeholder="Leave blank for all categories" />
                            <span asp-validation-for="MajCat" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CoverDaysCm1" class="form-label">Cover Days CM1</label>
                            <input asp-for="CoverDaysCm1" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="CoverDaysCm1" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CoverDaysCm2" class="form-label">Cover Days CM2</label>
                            <input asp-for="CoverDaysCm2" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="CoverDaysCm2" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Leave Store Code and Major Category blank to process all data. This will execute the stored procedure with the specified parameters.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success btn-lg" id="executeBtn">
                            <i class="bi bi-play-circle"></i> Execute Plan Generation
                        </button>
                        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Cancel</a>
                    </div>

                    <div id="loadingSpinner" class="mt-3" style="display: none;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Executing...</span>
                        </div>
                        <span class="ms-2">Processing plan generation, please wait...</span>
                    </div>
                </form>

                @if (ViewBag.RowsInserted != null)
                {
                    <div class="alert alert-success mt-3">
                        <h5>Execution Completed Successfully!</h5>
                        <p><strong>Rows Inserted:</strong> @ViewBag.RowsInserted</p>
                        <p><strong>Execution Time:</strong> @ViewBag.SuccessMessage</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('executionForm').addEventListener('submit', function () {
            document.getElementById('loadingSpinner').style.display = 'block';
            document.getElementById('executeBtn').disabled = true;
        });
    </script>
}
