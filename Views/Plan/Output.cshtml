@{
    ViewData["Title"] = "Transfer In Plan Output";
}

@model IEnumerable<TRANSFER_IN_PLAN.Models.TrfInPlan>

<div class="mb-4">
    <h3 class="mb-0"><i class="bi bi-table me-2"></i>Transfer In Plan Output</h3>
</div>

<div class="card mb-4">
    <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-funnel me-2"></i>Filters</h5></div>
    <div class="card-body">
        <form method="get" id="filterForm" class="row g-3">
            <div class="col-md-2"><label class="form-label">FY Year</label><input type="number" name="fyYear" class="form-control form-control-sm" value="@ViewBag.FyYear" placeholder="e.g. 2026" /></div>
            <div class="col-md-2"><label class="form-label">FY Week</label><input type="number" name="fyWeek" class="form-control form-control-sm" value="@ViewBag.FyWeek" placeholder="e.g. 40" /></div>
            <div class="col-md-3">
                <label class="form-label">Category</label>
                @{ var selCats = (ViewBag.MajCat as string ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet(); }
                <select name="majCat" class="form-select form-select-sm multi-select">
                    <option value="">-- All --</option>
                    @foreach (var c in (ViewBag.Categories as IEnumerable<string> ?? new List<string>())) { <option value="@c" selected="@(selCats.Contains(c) ? "selected" : null)">@c</option> }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Store Code</label>
                @{ var selStores = (ViewBag.StCd as string ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet(); }
                <select name="stCd" class="form-select form-select-sm multi-select">
                    <option value="">-- All --</option>
                    @foreach (var s in (ViewBag.StoreCodes as IEnumerable<string> ?? new List<string>())) { <option value="@s" selected="@(selStores.Contains(s) ? "selected" : null)">@s</option> }
                </select>
            </div>
            <div class="col-md-3"><label class="form-label">Page Size</label>
                <select name="pageSize" class="form-select form-select-sm search-select">
                    @foreach (var ps in new[] { 50, 100, 250, 500 }) { <option value="@ps" selected="@((ViewBag.PageSize?.ToString() == ps.ToString()) ? "selected" : null)">@ps rows</option> }
                </select>
            </div>
            <div class="col-12 d-flex gap-2 align-items-end flex-wrap">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i> Filter</button>
                <a href="@Url.Action("Output")" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i> Clear</a>
                <a href="@Url.Action("ExportCsv", "Plan", new { fyYear = ViewBag.FyYear, fyWeek = ViewBag.FyWeek, majCat = ViewBag.MajCat, stCd = ViewBag.StCd })" class="btn btn-success btn-sm ms-auto">
                    <i class="bi bi-filetype-csv me-1"></i> Export CSV
                </a>
                <a href="@Url.Action("ExportPivotCsv", "Plan", new { fyYear = ViewBag.FyYear, fyWeek = ViewBag.FyWeek, majCat = ViewBag.MajCat, stCd = ViewBag.StCd })" class="btn btn-primary btn-sm">
                    <i class="bi bi-grid-3x3 me-1"></i> Pivot CSV
                </a>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.TotalCount != null)
{
    <div class="alert alert-info py-2"><i class="bi bi-info-circle me-1"></i>Showing <strong>@Model.Count()</strong> of <strong>@ViewBag.TotalCount</strong> records (Page @ViewBag.Page, @ViewBag.PageSize per page)</div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover table-bordered mb-0 small" id="planOutputTable">
                <thead class="table-dark">
                    <tr>
                        <th>ST CD</th>
                        <th>ST NM</th>
                        <th>RDC CD</th>
                        <th>RDC NM</th>
                        <th>HUB CD</th>
                        <th>HUB NM</th>
                        <th>AREA</th>
                        <th>MAJ CAT</th>
                        <th>SEG</th>
                        <th>DIV</th>
                        <th>SUB DIV</th>
                        <th>MAJ CAT NM</th>
                        <th>SSN</th>
                        <th>FY YEAR</th>
                        <th>FY WEEK</th>
                        <th>S GRT STK Q</th>
                        <th>W GRT STK Q</th>
                        <th>BGT DISP CL Q</th>
                        <th>BGT DISP CL OPT</th>
                        <th>CM1 SALE COVER DAY</th>
                        <th>CM2 SALE COVER DAY</th>
                        <th>COVER SALE QTY</th>
                        <th>BGT ST CL MBQ</th>
                        <th>BGT DISP CL OPT MBQ</th>
                        <th>BGT TTL CF OP STK Q</th>
                        <th>NT ACT Q</th>
                        <th>NET BGT CF STK Q</th>
                        <th>CM BGT SALE Q</th>
                        <th>CM1 BGT SALE Q</th>
                        <th>CM2 BGT SALE Q</th>
                        <th>TRF IN STK Q</th>
                        <th>TRF IN OPT CNT</th>
                        <th>TRF IN OPT MBQ</th>
                        <th>DC MBQ</th>
                        <th>BGT TTL CF CL STK Q</th>
                        <th>BGT NT ACT Q</th>
                        <th>NET ST CL STK Q</th>
                        <th>ST CL EXCESS Q</th>
                        <th>ST CL SHORT Q</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-primary">@item.StCd</td>
                            <td>@(item.StNm ?? "NA")</td>
                            <td>@(item.RdcCd ?? "NA")</td>
                            <td>@(item.RdcNm ?? "NA")</td>
                            <td>@(item.HubCd ?? "NA")</td>
                            <td>@(item.HubNm ?? "NA")</td>
                            <td>@(item.Area ?? "NA")</td>
                            <td>@item.MajCat</td>
                            <td>@(item.Seg ?? "NA")</td>
                            <td>@(item.Div ?? "NA")</td>
                            <td>@(item.SubDiv ?? "NA")</td>
                            <td>@(item.MajCatNm ?? "NA")</td>
                            <td>@(item.Ssn ?? "NA")</td>
                            <td>@item.FyYear</td>
                            <td>@item.FyWeek</td>
                            <td class="text-end">@((item.SGrtStkQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.WGrtStkQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.BgtDispClQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.BgtDispClOpt ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.Cm1SaleCoverDay ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.Cm2SaleCoverDay ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.CoverSaleQty ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.BgtStClMbq ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.BgtDispClOptMbq ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.BgtTtlCfOpStkQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.NtActQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.NetBgtCfStkQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.CmBgtSaleQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.Cm1BgtSaleQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.Cm2BgtSaleQ ?? 0).ToString("N4"))</td>
                            <td class="text-end fw-bold">@((item.TrfInStkQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.TrfInOptCnt ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.TrfInOptMbq ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.DcMbq ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.BgtTtlCfClStkQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.BgtNtActQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@((item.NetStClStkQ ?? 0).ToString("N4"))</td>
                            <td class="text-end">@if ((item.StClExcessQ ?? 0) > 0) { <span class="badge bg-warning text-dark">@item.StClExcessQ?.ToString("N4")</span> } else { @((item.StClExcessQ ?? 0).ToString("N4")) }</td>
                            <td class="text-end">@if ((item.StClShortQ ?? 0) > 0) { <span class="badge bg-danger">@item.StClShortQ?.ToString("N4")</span> } else { @((item.StClShortQ ?? 0).ToString("N4")) }</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalCount != null && ViewBag.PageSize != null && ViewBag.Page != null)
{
    var totalPages = (int)Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize);
    <nav class="mt-3"><ul class="pagination pagination-sm justify-content-center flex-wrap">
        @for (int p = Math.Max(1, (int)ViewBag.Page - 3); p <= Math.Min(totalPages, (int)ViewBag.Page + 3); p++)
        {
            <li class="page-item @(p == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Output", new { fyYear = ViewBag.FyYear, fyWeek = ViewBag.FyWeek, majCat = ViewBag.MajCat, stCd = ViewBag.StCd, page = p, pageSize = ViewBag.PageSize })">@p</a></li>
        }
    </ul></nav>
}

@section Scripts {
    <script>
        $(function () { if (!$.fn.DataTable.isDataTable('#planOutputTable')) { $('#planOutputTable').DataTable({ paging: false, ordering: true, searching: true, responsive: true, dom: 'lrtip' }); } });
    </script>
}
