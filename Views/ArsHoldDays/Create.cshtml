@{ ViewData["Title"] = "Add Hold Days"; }
@model TRANSFER_IN_PLAN.Models.ArsHoldDaysMaster
<h4 class="mb-3"><i class="bi bi-plus-circle me-2"></i>Add Hold Days Record</h4>
<div class="card shadow-sm border-0" style="max-width:600px;"><div class="card-body">
<form asp-action="Create" method="post">
    <div class="mb-3"><label class="form-label fw-semibold">Store Code</label><input asp-for="St" class="form-control" required /></div>
    <div class="mb-3"><label class="form-label fw-semibold">Major Category</label><input asp-for="Mj" class="form-control" required /></div>
    <div class="mb-3"><label class="form-label fw-semibold">Hold Days</label><input asp-for="HoldDays" class="form-control" type="number" step="0.0001" /></div>
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Save</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
</div></div>
