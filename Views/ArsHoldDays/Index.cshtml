@{ ViewData["Title"] = "ARS Hold Days Master"; }
@model IEnumerable<TRANSFER_IN_PLAN.Models.ArsHoldDaysMaster>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0"><i class="bi bi-clock-history me-2 text-warning"></i>ARS Hold Days Master</h3>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>Add</a>
        <a asp-action="ExportCsv" asp-route-st="@ViewBag.St" asp-route-mj="@ViewBag.Mj" class="btn btn-success btn-sm"><i class="bi bi-download me-1"></i>CSV</a>
    </div>
</div>

@{ ViewBag.Kpi2Label = "Stores"; ViewBag.Kpi2Value = ViewBag.TotalStores; ViewBag.Kpi2Color = "#27ae60";
   ViewBag.Kpi3Label = "Categories"; ViewBag.Kpi3Value = ViewBag.TotalCats; ViewBag.Kpi3Color = "#8e44ad"; }
<partial name="_RefTableAnalytics" />

<div class="card shadow-sm border-0 mb-2"><div class="card-body py-2">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-3"><label class="form-label small fw-semibold mb-0">Store</label>
            <select name="st" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var s in (ViewBag.Stores as IEnumerable<string> ?? new List<string>())) { <option value="@s" selected="@(s == ViewBag.St?.ToString())">@s</option> }
            </select></div>
        <div class="col-md-4"><label class="form-label small fw-semibold mb-0">Major Category</label>
            <select name="mj" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var c in (ViewBag.MajCats as IEnumerable<string> ?? new List<string>())) { <option value="@c" selected="@(c == ViewBag.Mj?.ToString())">@c</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Page Size</label>
            <select name="pageSize" class="form-select form-select-sm">
                @foreach (var ps in new[] { 50, 100, 250, 500 }) { <option value="@ps" selected="@(ViewBag.PageSize?.ToString() == ps.ToString())">@ps</option> }
            </select></div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Clear</a>
        </div>
    </form>
</div></div>

@if (ViewBag.TotalCount != null) { <div class="alert alert-info py-1 small mb-2"><i class="bi bi-info-circle me-1"></i>Showing <strong>@Model.Count()</strong> of <strong>@(((int)ViewBag.TotalCount).ToString("N0"))</strong> (Page @ViewBag.Page)</div> }

<div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover table-bordered table-sm mb-0 small" id="dataTable">
        <thead class="table-dark"><tr><th>ST</th><th>MJ</th><th class="text-end">HOLD_DAYS</th><th class="text-center">Actions</th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold text-primary">@item.St</td><td>@item.Mj</td>
                    <td class="text-end">@((item.HoldDays ?? 0).ToString("N2"))</td>
                    <td class="text-center text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning py-0"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger py-0"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any()) { <tr><td colspan="4" class="text-center text-muted py-3">No data.</td></tr> }
        </tbody>
    </table>
</div></div></div>

@if (ViewBag.TotalCount != null && ViewBag.PageSize != null) { var totalPages = (int)Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize); if (totalPages > 1) {
    <nav class="mt-2"><ul class="pagination pagination-sm justify-content-center flex-wrap">
        @for (int p = Math.Max(1, (int)ViewBag.Page - 4); p <= Math.Min(totalPages, (int)ViewBag.Page + 4); p++)
        { <li class="page-item @(p == (int)ViewBag.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Index", new { st = ViewBag.St, mj = ViewBag.Mj, page = p, pageSize = ViewBag.PageSize })">@p</a></li> }
    </ul></nav> } }

@section Scripts { <script>$(function(){ if($('#dataTable tbody tr').length > 0 && !$('#dataTable tbody .text-muted').length){ $('#dataTable').DataTable({paging:false,ordering:true,searching:true,dom:'lrtip'}); } });</script> }
