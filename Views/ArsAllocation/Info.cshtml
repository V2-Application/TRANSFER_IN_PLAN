<!-- ══════════════════════════════════════════════════════════════ -->
<!--  TAB 1: OVERVIEW                                              -->
<!-- ══════════════════════════════════════════════════════════════ -->
<div class="tab-pane fade show active" id="tabOverview">

    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-bullseye me-2"></i>What ARS Allocation Does</h5></div>
        <div class="card-body small">
            <p>The <strong>Article Replenishment System (ARS)</strong> determines which articles (OLD-L scope) to allocate to which stores, in what quantities, from the MSA warehouse.</p>
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="card info-card h-100"><div class="card-body">
                        <h6 class="fw-bold" style="color:#E67E22;"><i class="bi bi-question-circle me-2"></i>Core Question</h6>
                        <p class="mb-0">"For each store + article combination, <strong>how much stock should we allocate from MSA</strong> to maintain display and cover upcoming sales?"</p>
                    </div></div>
                </div>
                <div class="col-md-4">
                    <div class="card info-card algo h-100"><div class="card-body">
                        <h6 class="fw-bold" style="color:#8e44ad;"><i class="bi bi-diagram-3 me-2"></i>Scope</h6>
                        <ul class="mb-0">
                            <li><strong>Granularity:</strong> Store x Generic Article x Color</li>
                            <li><strong>Category:</strong> Major Category (MJ)</li>
                            <li><strong>Source:</strong> MSA Warehouse Stock</li>
                            <li><strong>Target:</strong> 600+ Stores</li>
                        </ul>
                    </div></div>
                </div>
                <div class="col-md-4">
                    <div class="card info-card ref h-100"><div class="card-body">
                        <h6 class="fw-bold" style="color:#3498db;"><i class="bi bi-gear me-2"></i>Engine</h6>
                        <ul class="mb-0">
                            <li><strong>SP:</strong> <code>SP_ARS_ALLOCATION_RUN</code></li>
                            <li><strong>Database:</strong> Snowflake (V2RETAIL.GOLD)</li>
                            <li><strong>Runtime:</strong> ~10 seconds</li>
                            <li><strong>Steps:</strong> 10 sequential stages</li>
                        </ul>
                    </div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- End-to-End Data Flow -->
    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-arrow-right me-2"></i>End-to-End Flow</h5></div>
        <div class="card-body small">
            <div class="row text-center align-items-center g-2">
                <div class="col"><div class="card border-primary p-2"><i class="bi bi-cloud-download text-primary fs-5"></i><br><strong>SAP Stock</strong><br><small class="text-muted">ET_STOCK_DATA<br>ET_MSA_STOCK</small></div></div>
                <div class="col-auto"><i class="bi bi-arrow-right fs-4 text-muted"></i></div>
                <div class="col"><div class="card border-warning p-2"><i class="bi bi-table fs-5" style="color:#E67E22;"></i><br><strong>Reference Data</strong><br><small class="text-muted">Display, Sale, Hold,<br>Store Master, Aging</small></div></div>
                <div class="col-auto"><i class="bi bi-arrow-right fs-4 text-muted"></i></div>
                <div class="col"><div class="card border-secondary p-2"><i class="bi bi-funnel fs-5" style="color:#8e44ad;"></i><br><strong>Classification</strong><br><small class="text-muted">7-Rule Engine<br>MIX / L / OLD / NEW-L</small></div></div>
                <div class="col-auto"><i class="bi bi-arrow-right fs-4 text-muted"></i></div>
                <div class="col"><div class="card border-success p-2"><i class="bi bi-calculator fs-5 text-success"></i><br><strong>Allocation</strong><br><small class="text-muted">Window-function<br>MJ-budget safe</small></div></div>
                <div class="col-auto"><i class="bi bi-arrow-right fs-4 text-muted"></i></div>
                <div class="col"><div class="card border-danger p-2"><i class="bi bi-file-earmark-spreadsheet fs-5 text-danger"></i><br><strong>Output</strong><br><small class="text-muted">ARS_ALLOCATION_OUTPUT<br>42 columns</small></div></div>
            </div>
        </div>
    </div>

    <!-- Classification Summary -->
    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-tags me-2"></i>Article Classifications at a Glance</h5></div>
        <div class="card-body small">
            <div class="row g-3">
                <div class="col-md-3"><div class="card rule-card mix"><strong class="text-danger">MIX-ART (X-ART)</strong><br>Aged, clearance, low-variant, or low-stock articles.<br><span class="badge badge-noalloc">Not Allocated</span></div></div>
                <div class="col-md-3"><div class="card rule-card lart"><strong class="text-success">L-ART</strong><br>Well-stocked articles (stock &ge; 60% density).<br><span class="badge badge-alloc">Allocated if REQ > 0</span></div></div>
                <div class="col-md-3"><div class="card rule-card old"><strong style="color:#f39c12;">OLD-ART</strong><br>Understocked but in-store articles.<br><span class="badge badge-alloc">Priority Allocation</span></div></div>
                <div class="col-md-3"><div class="card rule-card newl"><strong class="text-primary">NEW-L</strong><br>Not in store stock, or re-tagged MIX with remaining MSA.<br><span class="badge badge-tag">Tagged for future</span></div></div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════ -->
<!--  TAB 2: 7-RULE CLASSIFICATION                                 -->
<!-- ══════════════════════════════════════════════════════════════ -->
<div class="tab-pane fade" id="tabClassification">

    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-funnel me-2"></i>7-Rule Classification Engine</h5></div>
        <div class="card-body small">
            <p>Rules are evaluated <strong>top-to-bottom</strong>. <strong>First match wins</strong> &mdash; once an article matches a rule, it is classified and no further rules are checked.</p>

            <div class="rule-card mix">
                <div class="d-flex align-items-center mb-1">
                    <span class="badge badge-step me-2">Rule 1</span>
                    <strong>AGING &gt; 360 days &rarr; MIX-ART (X-ART)</strong>
                    <span class="badge badge-noalloc ms-auto">No Allocation</span>
                </div>
                <div class="algo-block mb-0 mt-2">
                    <span class="keyword">IF</span> ARS_ART_AGING.AGING_DAYS <span class="formula">&gt; 360</span><br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'MIX-ART'</span><br>
                    <span class="comment">// Article has been in stock too long &mdash; clearance candidate</span>
                </div>
            </div>

            <div class="rule-card mix">
                <div class="d-flex align-items-center mb-1">
                    <span class="badge badge-step me-2">Rule 2</span>
                    <strong>ART_TAG = 'C-ART' &rarr; MIX-ART (X-ART)</strong>
                    <span class="badge badge-noalloc ms-auto">No Allocation</span>
                </div>
                <div class="algo-block mb-0 mt-2">
                    <span class="keyword">IF</span> ARS_ST_ART_AUTO_SALE.ART_TAG = <span class="formula">'C-ART'</span><br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'MIX-ART'</span><br>
                    <span class="comment">// Explicitly tagged as clearance article</span>
                </div>
            </div>

            <div class="rule-card mix">
                <div class="d-flex align-items-center mb-1">
                    <span class="badge badge-step me-2">Rule 3</span>
                    <strong>MSA &ge; 50 AND SZ_COUNT &le; 2 &rarr; MIX-ART (X-ART)</strong>
                    <span class="badge badge-noalloc ms-auto">No Allocation</span>
                </div>
                <div class="algo-block mb-0 mt-2">
                    <span class="keyword">IF</span> MSA_QTY <span class="formula">&ge; 50</span> AND SZ_COUNT <span class="formula">&le; 2</span><br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'MIX-ART'</span><br>
                    <span class="comment">// High MSA quantity but too few color variants &mdash; likely dead stock</span><br>
                    <span class="comment">// SZ_COUNT = COUNT(DISTINCT CLR) WHERE (store_stock + msa_stock) &gt; 0</span>
                </div>
            </div>

            <div class="rule-card mix">
                <div class="d-flex align-items-center mb-1">
                    <span class="badge badge-step me-2">Rule 4</span>
                    <strong>Stock &lt; 60% Density AND MSA &lt; 50 &rarr; MIX-ART</strong>
                    <span class="badge badge-noalloc ms-auto">No Allocation</span>
                </div>
                <div class="algo-block mb-0 mt-2">
                    <span class="keyword">IF</span> TTL_ST_STK_Q <span class="formula">&lt; 0.6 &times; ACC_DENSITY</span> AND MSA_QTY <span class="formula">&lt; 50</span><br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'MIX-ART'</span><br>
                    <span class="comment">// Low store stock AND low MSA &mdash; insufficient to justify allocation</span>
                </div>
            </div>

            <div class="rule-card lart">
                <div class="d-flex align-items-center mb-1">
                    <span class="badge badge-step me-2">Rule 5</span>
                    <strong>Stock &ge; 60% Density &rarr; L-ART</strong>
                    <span class="badge badge-alloc ms-auto">Allocated if REQ &gt; 0</span>
                </div>
                <div class="algo-block mb-0 mt-2">
                    <span class="keyword">IF</span> TTL_ST_STK_Q <span class="formula">&ge; 0.6 &times; ACC_DENSITY</span><br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'L-ART'</span><br>
                    <span class="comment">// Well-stocked article &mdash; eligible for allocation if demand exists</span>
                </div>
            </div>

            <div class="rule-card old">
                <div class="d-flex align-items-center mb-1">
                    <span class="badge badge-step me-2">Rule 6</span>
                    <strong>Store Stock &gt; 0 &rarr; OLD-ART</strong>
                    <span class="badge badge-alloc ms-auto">Priority Allocation</span>
                </div>
                <div class="algo-block mb-0 mt-2">
                    <span class="keyword">IF</span> TTL_ST_STK_Q <span class="formula">&gt; 0</span><br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'OLD-ART'</span><br>
                    <span class="comment">// In store but understocked &mdash; priority replenishment candidate</span>
                </div>
            </div>

            <div class="rule-card newl">
                <div class="d-flex align-items-center mb-1">
                    <span class="badge badge-step me-2">Rule 7</span>
                    <strong>ELSE &rarr; NEW-L</strong>
                    <span class="badge badge-tag ms-auto">Tagged Only</span>
                </div>
                <div class="algo-block mb-0 mt-2">
                    <span class="keyword">ELSE</span><br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'NEW-L'</span><br>
                    <span class="comment">// Not in store stock at all &mdash; first-time allocation candidate</span>
                </div>
            </div>

            <div class="card border-info mt-3">
                <div class="card-body py-2">
                    <h6 class="fw-bold text-primary"><i class="bi bi-arrow-repeat me-2"></i>Post-Allocation Re-Tagging (Step 9)</h6>
                    <p class="mb-0">After the allocation step, MIX-ART articles with <code>REM_MSA &gt; 0</code> where the category (ST+MJ) still has unmet demand (<code>ST_MJ_MBQ &gt; total allocated</code>) are <strong>re-tagged as NEW-L</strong>. This identifies high-potential articles for future allocation waves.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════ -->
<!--  TAB 3: 10-STEP ALGORITHM                                     -->
<!-- ══════════════════════════════════════════════════════════════ -->
<div class="tab-pane fade" id="tabAlgorithm">

    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-cpu me-2"></i>10-Step Allocation Algorithm</h5></div>
        <div class="card-body small">
            <p>Executed by <code>SP_ARS_ALLOCATION_RUN(RUN_ID)</code> &mdash; a Snowflake JavaScript stored procedure running sequentially through 10 stages.</p>

            <!-- Step 1 -->
            <div class="flow-step">
                <h6><span class="step-num">1</span>Pivot Store Stock by LGORT</h6>
                <div class="algo-block">
                    <span class="comment">// Source: ET_STOCK_DATA (latest STOCK_DATE)</span><br>
                    <span class="comment">// Aggregate MATNR to 10-digit generic article: LEFT(LTRIM(MATNR,'0'), 10)</span><br>
                    <span class="keyword">PIVOT</span> LABST by LGORT &rarr; STK_0001, STK_0002, STK_0004, STK_0006,<br>
                    &nbsp;&nbsp;&nbsp;&nbsp;STK_HUB_INTRA, STK_HUB_PRD, STK_INTRA, STK_PRD<br>
                    <span class="formula">TTL_ST_STK_Q</span> = SUM(all LGORT stock columns)
                </div>
            </div>

            <!-- Step 2 -->
            <div class="flow-step">
                <h6><span class="step-num">2</span>Load MSA Stock</h6>
                <div class="algo-block">
                    <span class="comment">// Source: ET_MSA_STOCK (latest MSA_STOCK_DATE)</span><br>
                    <span class="comment">// Aggregate to 10-digit: LEFT(LTRIM(MATNR,'0'), 10)</span><br>
                    <span class="formula">MSA_QTY</span> = SUM(VEMNG) per KUNNR (store) + GEN_ART<br>
                    <span class="comment">// MSA &gt; 0 required for any allocation consideration</span>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="flow-step">
                <h6><span class="step-num">3</span>Compute SZ_COUNT (Color Variant Count)</h6>
                <div class="algo-block">
                    <span class="formula">SZ_COUNT</span> = COUNT(DISTINCT CLR) <span class="keyword">WHERE</span> (store_stock + msa_stock) &gt; 0<br>
                    <span class="comment">// Per GEN_ART &mdash; used in Rule 3 to reject low-diversity articles</span>
                </div>
            </div>

            <!-- Step 4 -->
            <div class="flow-step">
                <h6><span class="step-num">4</span>Calculate TTL_ALC_DAYS (Total Allocation Days)</h6>
                <div class="algo-block">
                    INTRA_DAYS = <span class="keyword">CASE WHEN</span> TAGGED_RDC = 'DW01'<br>
                    &nbsp;&nbsp;<span class="keyword">THEN</span> DW01_DC_TO_HUB_INTRA + DW01_HUB_TO_ST_INTRA<br>
                    &nbsp;&nbsp;<span class="keyword">ELSE</span> DH24_DC_TO_HUB_INTRA + DH24_HUB_TO_ST_INTRA<br>
                    <br>
                    <span class="formula">TTL_ALC_DAYS</span> = SALE_COVER_DAYS + PRD_DAYS + INTRA_DAYS<br>
                    <span class="comment">// Total days to cover: sales buffer + product hold + transit time</span>
                </div>
            </div>

            <!-- Step 5 -->
            <div class="flow-step">
                <h6><span class="step-num">5</span>Calculate MJ-Level Per-Day Sales</h6>
                <div class="algo-block">
                    CM_PD_SALE_Q = CM_AUTO_SALE_Q / CM_REM_DAYS <span class="comment">// Current Month per-day rate</span><br>
                    NM_PD_SALE_Q = NM_AUTO_SALE_Q / NM_DAYS <span class="comment">// New Month per-day rate</span><br>
                    <br>
                    <span class="comment">// CM/NM Sales Crossover Formula:</span><br>
                    <span class="formula">ST_MJ_ALC_SALE_Q_PD</span> =<br>
                    &nbsp;&nbsp;MIN(TTL_ALC_DAYS + HOLD_DAYS, CM_REM_DAYS) &times; CM_PD_SALE_Q<br>
                    &nbsp;&nbsp;+ MAX(TTL_ALC_DAYS + HOLD_DAYS - CM_REM_DAYS, 0) &times; NM_PD_SALE_Q<br>
                    <br>
                    <span class="formula">ST_MJ_MBQ</span> = ST_MJ_DISP_Q + ST_MJ_ALC_SALE_Q_PD<br>
                    <span class="comment">// Category MBQ = Display + Expected Sales over allocation period</span>
                </div>
            </div>

            <!-- Step 6 -->
            <div class="flow-step">
                <h6><span class="step-num">6</span>Calculate Article-Level Per-Day Sales</h6>
                <div class="algo-block">
                    <span class="formula">ART_AUTO_SALE_PD</span> = <span class="comment">(same crossover formula at article level)</span><br>
                    <span class="comment">// Uses ARS_ST_ART_AUTO_SALE (CM/NM per GEN_ART + CLR)</span><br>
                    <span class="comment">// Also carries ART_TAG ('C-ART' = clearance) for Rule 2</span>
                </div>
            </div>

            <!-- Step 7 -->
            <div class="flow-step">
                <h6><span class="step-num">7</span>Build PREPARED Table + Apply 7-Rule Classification</h6>
                <div class="algo-block">
                    <span class="formula">ART_MBQ</span> = ACC_DENSITY + ART_AUTO_SALE_PD &times; TTL_ALC_DAYS<br>
                    <span class="comment">// Quantity needed for display + sales during allocation period</span><br>
                    <br>
                    <span class="formula">ART_HOLD_MBQ</span> = ACC_DENSITY + ART_AUTO_SALE_PD &times; (TTL_ALC_DAYS + HOLD_DAYS)<br>
                    <span class="comment">// Quantity needed through replenishment hold period</span><br>
                    <br>
                    <span class="formula">ST_MJ_REQ</span> = MAX(ST_MJ_MBQ - SUM(TTL_ST_STK_Q per ST+MJ), 0)<br>
                    <span class="comment">// Category shortage = category demand minus current stock</span><br>
                    <br>
                    <span class="formula">ST_ART_REQ</span> = MAX(ART_MBQ - TTL_ST_STK_Q, 0)<br>
                    <span class="comment">// Article shortage</span><br>
                    <br>
                    <span class="formula">ST_ART_HOLD_REQ</span> = MAX(ART_HOLD_MBQ - TTL_ST_STK_Q, 0)<br>
                    <span class="comment">// Article shortage including hold period</span><br>
                    <br>
                    <span class="formula">ART_CLASS</span> = <span class="comment">(Apply 7-rule classification &mdash; see Classification tab)</span>
                </div>
            </div>

            <!-- Step 8 -->
            <div class="flow-step">
                <h6><span class="step-num">8</span>Allocate with Window-Function (MJ-Budget Safe)</h6>
                <div class="algo-block">
                    <span class="comment">// CANDIDATES: L-ART and OLD-ART only, where MSA_QTY &gt; 0 and ST_ART_REQ &gt; 0</span><br>
                    <span class="comment">// Processing order per store: highest ST_ART_REQ first (priority)</span><br>
                    <br>
                    WANT_Q = <span class="keyword">LEAST</span>(MSA_QTY, ST_ART_REQ)<br>
                    <span class="comment">// How much we ideally want to allocate</span><br>
                    <br>
                    PREV_CUM_WANT = SUM of prior articles' WANT_Q <span class="comment">// running total per ST+MJ</span><br>
                    <br>
                    MJ_REMAINING = <span class="keyword">MAX</span>(0, ST_MJ_REQ - PREV_CUM_WANT)<br>
                    <span class="comment">// Category budget left after earlier allocations</span><br>
                    <br>
                    <span class="formula">ART_ALC_Q</span> = <span class="keyword">LEAST</span>(WANT_Q, MJ_REMAINING)<br>
                    <span class="comment">// GUARANTEE: total allocation per ST+MJ &le; ST_MJ_REQ</span><br>
                    <br>
                    <span class="formula">ART_HOLD_Q</span> = <span class="keyword">LEAST</span>(MSA_QTY - ART_ALC_Q, ST_ART_HOLD_REQ - ART_ALC_Q)<br>
                    <span class="comment">// Hold quantity for future replenishment (if both conditions &gt; 0)</span><br>
                    <br>
                    <span class="formula">REM_MSA</span> = MSA_QTY - ART_ALC_Q - ART_HOLD_Q<br>
                    <span class="comment">// MSA remaining after allocation and hold</span>
                </div>
            </div>

            <!-- Step 9 -->
            <div class="flow-step">
                <h6><span class="step-num">9</span>Post-Allocation NEW-L Re-Tagging</h6>
                <div class="algo-block">
                    <span class="keyword">IF</span> ART_CLASS = 'MIX-ART' <span class="keyword">AND</span> REM_MSA &gt; 0<br>
                    &nbsp;&nbsp;<span class="keyword">AND</span> (ST_MJ_MBQ - SUM(ART_ALC_Q per ST+MJ)) &gt; 0<br>
                    <span class="keyword">THEN</span> ART_CLASS = <span class="formula">'NEW-L'</span><br>
                    <span class="comment">// Convert non-allocated MIX articles to NEW-L if MJ still has unmet demand</span>
                </div>
            </div>

            <!-- Step 10 -->
            <div class="flow-step">
                <h6><span class="step-num">10</span>Write Output + Update Run Log</h6>
                <div class="algo-block">
                    <span class="keyword">DELETE FROM</span> ARS_ALLOCATION_OUTPUT <span class="keyword">WHERE</span> RUN_ID = @@RunId<br>
                    <span class="keyword">INSERT INTO</span> ARS_ALLOCATION_OUTPUT <span class="comment">(all 42 columns from TMP_PREP)</span><br>
                    <span class="keyword">UPDATE</span> ARS_RUN_LOG <span class="comment">// summary statistics: counts per classification</span>
                </div>
            </div>
        </div>
    </div>
</div>

