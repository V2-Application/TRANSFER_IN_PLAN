<!--  TAB 7: PARAMETERS & THRESHOLDS                               -->
<!-- ══════════════════════════════════════════════════════════════ -->
<div class="tab-pane fade" id="tabParams">

    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-sliders me-2"></i>Business Parameters & Thresholds</h5></div>
        <div class="card-body small">

            <h6 class="fw-bold mt-2 mb-2"><i class="bi bi-funnel me-2"></i>Classification Thresholds</h6>
            <table class="table table-sm table-bordered">
                <thead class="table-light"><tr><th>Parameter</th><th>Value</th><th>Used In</th><th>Purpose</th></tr></thead>
                <tbody>
                    <tr><td><strong>Aging Limit</strong></td><td><code>&gt; 360 days</code></td><td>Rule 1</td><td>Articles older than 360 days are clearance candidates</td></tr>
                    <tr><td><strong>Clearance Tag</strong></td><td><code>ART_TAG = 'C-ART'</code></td><td>Rule 2</td><td>Explicitly tagged clearance articles</td></tr>
                    <tr><td><strong>MSA Threshold (Medium)</strong></td><td><code>&ge; 50</code></td><td>Rule 3</td><td>Combined with variant diversity check</td></tr>
                    <tr><td><strong>Variant Diversity Limit</strong></td><td><code>SZ_COUNT &le; 2</code></td><td>Rule 3</td><td>Too few color variants for meaningful allocation</td></tr>
                    <tr><td><strong>Stock Threshold</strong></td><td><code>TTL_ST_STK_Q &ge; 60% ACC_DENSITY</code></td><td>Rule 5</td><td>Well-stocked = stock is at least 60% of display density</td></tr>
                    <tr><td><strong>MSA Threshold (Low)</strong></td><td><code>&lt; 50</code></td><td>Rule 4</td><td>Combined with low stock for rejection</td></tr>
                </tbody>
            </table>

            <h6 class="fw-bold mt-3 mb-2"><i class="bi bi-clock me-2"></i>Time-Based Parameters (from ARS_ST_MASTER)</h6>
            <table class="table table-sm table-bordered">
                <thead class="table-light"><tr><th>Parameter</th><th>Source</th><th>Purpose</th></tr></thead>
                <tbody>
                    <tr><td><strong>SALE_COVER_DAYS</strong></td><td>ARS_ST_MASTER</td><td>Days of sales inventory to maintain in-store</td></tr>
                    <tr><td><strong>PRD_DAYS</strong></td><td>ARS_ST_MASTER</td><td>Product-specific processing/hold days</td></tr>
                    <tr><td><strong>INTRA_DAYS</strong></td><td>ARS_ST_MASTER (route-specific)</td><td>Transit time: DC &rarr; Hub &rarr; Store</td></tr>
                    <tr><td><strong>HOLD_DAYS</strong></td><td>ARS_HOLD_DAYS_MASTER</td><td>Days to hold after initial allocation before next replenishment</td></tr>
                </tbody>
            </table>

            <h6 class="fw-bold mt-3 mb-2"><i class="bi bi-gear me-2"></i>Allocation Controls</h6>
            <table class="table table-sm table-bordered">
                <thead class="table-light"><tr><th>Control</th><th>Mechanism</th><th>Guarantee</th></tr></thead>
                <tbody>
                    <tr><td><strong>MJ Budget Cap</strong></td><td>Window function with running cumulative sum</td><td>Total allocation per ST+MJ &le; ST_MJ_REQ</td></tr>
                    <tr><td><strong>MSA Cap</strong></td><td>LEAST(MSA_QTY, ST_ART_REQ)</td><td>Cannot allocate more than available MSA</td></tr>
                    <tr><td><strong>Priority Order</strong></td><td>ORDER BY ST_ART_REQ DESC</td><td>Most-needed articles get allocated first</td></tr>
                    <tr><td><strong>Hold Safety</strong></td><td>ART_HOLD_Q only if both (MSA - ALC) &gt; 0 AND (HOLD_REQ - ALC) &gt; 0</td><td>Hold quantity never exceeds remaining MSA or remaining need</td></tr>
                </tbody>
            </table>

            <h6 class="fw-bold mt-3 mb-2"><i class="bi bi-info-circle me-2"></i>Key Design Decisions</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card border-success">
                        <div class="card-body py-2">
                            <h6 class="fw-bold text-success"><i class="bi bi-check-circle me-1"></i>Window-Function Allocation</h6>
                            <p class="mb-0 small">Articles processed in priority order (highest REQ first) with running MJ-budget tracking. Prevents over-allocation per category.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-warning">
                        <div class="card-body py-2">
                            <h6 class="fw-bold" style="color:#E67E22;"><i class="bi bi-funnel me-1"></i>Cascading Classification</h6>
                            <p class="mb-0 small">Rules evaluated top-to-bottom, first match wins. Ensures clear priority: aged &gt; clearance &gt; low-variant &gt; low-stock &gt; well-stocked &gt; understocked &gt; new.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-primary">
                        <div class="card-body py-2">
                            <h6 class="fw-bold text-primary"><i class="bi bi-arrow-repeat me-1"></i>CM/NM Sales Crossover</h6>
                            <p class="mb-0 small">Blends two pricing periods to capture realistic demand during allocation. Covers both current-month discounts and new-month normal pricing.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-info">
                        <div class="card-body py-2">
                            <h6 class="fw-bold text-info"><i class="bi bi-tags me-1"></i>Post-Allocation NEW-L Tagging</h6>
                            <p class="mb-0 small">Identifies high-potential new articles (MIX-ART with available MSA where category demand remains). Enables future allocation waves.</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

