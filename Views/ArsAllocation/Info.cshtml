<!--  TAB 6: KEY FORMULAS                                           -->
<!-- ══════════════════════════════════════════════════════════════ -->
<div class="tab-pane fade" id="tabFormulas">

    <div class="card shadow-sm mb-3">
        <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-calculator me-2"></i>Key Formulas Reference</h5></div>
        <div class="card-body small">

            <table class="table table-sm table-bordered formula-table">
                <thead class="table-dark"><tr><th>Formula</th><th>Definition</th></tr></thead>
                <tbody>
                    <tr class="key-formula">
                        <th>TTL_ALC_DAYS</th>
                        <td>SALE_COVER_DAYS + PRD_DAYS + INTRA_DAYS<br><span class="comment">where INTRA_DAYS = route-specific (DW01 or DH24) DC-to-Hub + Hub-to-Store days</span></td>
                    </tr>
                    <tr>
                        <th>CM_PD_SALE_Q</th>
                        <td>CM_AUTO_SALE_Q / CM_REM_DAYS<br><span class="comment">Current Month per-day sale rate at MJ level</span></td>
                    </tr>
                    <tr>
                        <th>NM_PD_SALE_Q</th>
                        <td>NM_AUTO_SALE_Q / NM_DAYS<br><span class="comment">New Month per-day sale rate at MJ level</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>ST_MJ_ALC_SALE_Q_PD<br><small class="text-muted">(CM/NM Crossover)</small></th>
                        <td>MIN(TTL_ALC_DAYS + HOLD_DAYS, CM_REM_DAYS) &times; CM_PD_SALE_Q<br>+ MAX(TTL_ALC_DAYS + HOLD_DAYS - CM_REM_DAYS, 0) &times; NM_PD_SALE_Q<br><span class="comment">Blends current month and next month sales periods</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>ST_MJ_MBQ</th>
                        <td>ST_MJ_DISP_Q + ST_MJ_ALC_SALE_Q_PD<br><span class="comment">Category MBQ = display need + expected sales over allocation period</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>ART_MBQ</th>
                        <td>ACC_DENSITY + ART_AUTO_SALE_PD &times; TTL_ALC_DAYS<br><span class="comment">Article-level minimum stock = display density + sales during allocation window</span></td>
                    </tr>
                    <tr>
                        <th>ART_HOLD_MBQ</th>
                        <td>ACC_DENSITY + ART_AUTO_SALE_PD &times; (TTL_ALC_DAYS + HOLD_DAYS)<br><span class="comment">Extended MBQ including replenishment hold period</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>ST_MJ_REQ</th>
                        <td>MAX(ST_MJ_MBQ - SUM(TTL_ST_STK_Q per ST+MJ), 0)<br><span class="comment">Category-level shortage = total demand minus total stock</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>ST_ART_REQ</th>
                        <td>MAX(ART_MBQ - TTL_ST_STK_Q, 0)<br><span class="comment">Article-level shortage</span></td>
                    </tr>
                    <tr>
                        <th>ST_ART_HOLD_REQ</th>
                        <td>MAX(ART_HOLD_MBQ - TTL_ST_STK_Q, 0)</td>
                    </tr>
                    <tr class="key-formula">
                        <th>WANT_Q</th>
                        <td>LEAST(MSA_QTY, ST_ART_REQ)<br><span class="comment">How much we ideally want to allocate</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>ART_ALC_Q<br><small class="text-muted">(Final Allocation)</small></th>
                        <td>LEAST(WANT_Q, MJ_REMAINING)<br><span class="comment">where MJ_REMAINING = MAX(0, ST_MJ_REQ - cumulative_prior_allocations)<br>Window-function ensures total per ST+MJ never exceeds ST_MJ_REQ</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>ART_HOLD_Q</th>
                        <td>LEAST(MSA_QTY - ART_ALC_Q, ST_ART_HOLD_REQ - ART_ALC_Q)<br><span class="comment">Hold for future replenishment (only if both terms &gt; 0)</span></td>
                    </tr>
                    <tr class="key-formula">
                        <th>REM_MSA</th>
                        <td>MSA_QTY - ART_ALC_Q - ART_HOLD_Q<br><span class="comment">Remaining MSA after all dispositions</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

