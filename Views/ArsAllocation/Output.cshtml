@{ ViewData["Title"] = "Allocation Output";
   var rows = ViewBag.Rows as List<Dictionary<string, object?>> ?? new();

   // Column groups for validation-friendly layout — ALL 41 columns
   var identityCols = new[] { "RUN_ID", "ST", "ST_NM", "TAGGED_RDC", "HUB_CD", "MJ", "GEN_ART", "CLR", "SZ", "ART_CLASS" };
   var stockCols = new[] { "TTL_ST_STK_Q", "STK_0001", "STK_0002", "STK_0004", "STK_0006", "STK_HUB_INTRA", "STK_HUB_PRD", "STK_INTRA", "STK_PRD", "MSA_QTY" };
   var paramCols = new[] { "TTL_ALC_DAYS", "HOLD_DAYS", "CM_PD_SALE_Q", "NM_PD_SALE_Q", "ART_AUTO_SALE_PD" };
   var mbqCols = new[] { "ACC_DENSITY", "ST_MJ_DISP_Q", "ST_MJ_MBQ", "ART_MBQ", "ART_HOLD_MBQ", "VAR_ART_MBQ", "VAR_ART_HOLD_MBQ" };
   var reqCols = new[] { "ST_MJ_REQ", "ST_ART_REQ", "ST_ART_HOLD_REQ", "ST_VAR_ART_REQ", "ST_VAR_ART_HOLD_REQ" };
   var resultCols = new[] { "ART_ALC_Q", "ART_HOLD_Q", "REM_MSA", "CREATED_DT" };
   var cols = identityCols.Concat(stockCols).Concat(paramCols).Concat(mbqCols).Concat(reqCols).Concat(resultCols).ToArray();

   var sortable = new HashSet<string> { "ST", "MJ", "GEN_ART", "ART_CLASS", "TTL_ST_STK_Q", "MSA_QTY", "ART_ALC_Q", "ART_HOLD_Q", "ST_MJ_MBQ", "ST_ART_REQ", "TAGGED_RDC", "ART_AUTO_SALE_PD", "RUN_ID", "CREATED_DT", "REM_MSA" };
   string sc = ViewBag.SortCol; string sd = ViewBag.SortDir;
   string NextDir(string c) => c == sc && sd == "ASC" ? "DESC" : "ASC";
   string Arrow(string c) => c == sc ? (sd == "ASC" ? " ▲" : " ▼") : "";

   // Group color bands for header
   var groupColors = new Dictionary<string, string>();
   foreach (var c in identityCols) groupColors[c] = "";
   foreach (var c in stockCols)    groupColors[c] = "background:#1a3a5c;";
   foreach (var c in paramCols)    groupColors[c] = "background:#4a2060;";
   foreach (var c in mbqCols)      groupColors[c] = "background:#0d4f3c;";
   foreach (var c in reqCols)      groupColors[c] = "background:#7c4a00;";
   foreach (var c in resultCols)   groupColors[c] = "background:#1B5E20;";

   var numericCols = new HashSet<string>(stockCols.Concat(paramCols).Concat(mbqCols).Concat(reqCols).Concat(resultCols));
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h3 class="mb-0"><i class="bi bi-table me-2" style="color:#E67E22;"></i>Allocation Output</h3>
        <small class="text-muted">ARS_ALLOCATION_OUTPUT — Store x Article allocation results (all reference columns for validation)</small>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a id="csvExportBtn" asp-action="ExportCsv" asp-route-st="@ViewBag.St" asp-route-mj="@ViewBag.Mj" asp-route-artClass="@ViewBag.ArtClass" class="btn btn-success btn-sm">
            <i class="bi bi-download me-1"></i>CSV
            @if (!string.IsNullOrEmpty(ViewBag.St as string) || !string.IsNullOrEmpty(ViewBag.Mj as string) || !string.IsNullOrEmpty(ViewBag.ArtClass as string))
            { <span class="badge bg-light text-success ms-1" style="font-size:0.6rem;">Filtered</span> }
            else
            { <span class="badge bg-light text-success ms-1" style="font-size:0.6rem;">All</span> }
        </a>
        <a asp-action="Info" class="btn btn-info btn-sm text-white"><i class="bi bi-info-circle me-1"></i>Algorithm Info</a>
        <a asp-action="Execute" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<!-- KPIs -->
<div class="row g-2 mb-3">
    <div class="col-6 col-sm-4 col-lg"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #2980b9 !important;"><div class="fw-bold fs-5" style="color:#2980b9;">@(((int)(ViewBag.TotalCount ?? 0)).ToString("N0"))</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">Total Rows</div></div></div>
    <div class="col-6 col-sm-4 col-lg"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #27ae60 !important;"><div class="fw-bold fs-5" style="color:#27ae60;">@ViewBag.TotalStores</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">Stores</div></div></div>
    <div class="col-6 col-sm-4 col-lg"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #8e44ad !important;"><div class="fw-bold fs-5" style="color:#8e44ad;">@ViewBag.TotalArticles</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">Articles</div></div></div>
    <div class="col-6 col-sm-4 col-lg"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #1B5E20 !important;"><div class="fw-bold fs-5" style="color:#1B5E20;">@(((decimal)(ViewBag.TotalAlcQty ?? 0m)).ToString("N0"))</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">ALC Qty</div></div></div>
    <div class="col-6 col-sm-4 col-lg"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #E67E22 !important;"><div class="fw-bold fs-5" style="color:#E67E22;">@(((decimal)(ViewBag.TotalHoldQty ?? 0m)).ToString("N0"))</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">HOLD Qty</div></div></div>
    <div class="col-6 col-sm-4 col-lg"><div class="card border-0 shadow-sm text-center py-2" style="border-top:3px solid #c0392b !important;"><div class="fw-bold fs-6" style="color:#059669;">L:@ViewBag.LCount MX:@ViewBag.MixCount OD:@ViewBag.OldCount NL:@ViewBag.NewLCount</div><div class="text-muted" style="font-size:0.6rem;text-transform:uppercase;font-weight:700;">Classification</div></div></div>
</div>

<!-- Column legend -->
<div class="mb-2 d-flex gap-2 flex-wrap small">
    <span class="badge" style="background:#334155;">Identity (10)</span>
    <span class="badge" style="background:#1a3a5c;">Stock (10)</span>
    <span class="badge" style="background:#4a2060;">Parameters (5)</span>
    <span class="badge" style="background:#0d4f3c;">Display & MBQ (7)</span>
    <span class="badge" style="background:#7c4a00;">Requirement (5)</span>
    <span class="badge" style="background:#1B5E20;">Result (4)</span>
</div>

<!-- Filters -->
<div class="card shadow-sm border-0 mb-2"><div class="card-body py-2">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Store</label>
            <select name="st" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var s in (ViewBag.Stores as List<string> ?? new())) { <option value="@s" selected="@(s == ViewBag.St?.ToString())">@s</option> }
            </select></div>
        <div class="col-md-3"><label class="form-label small fw-semibold mb-0">Major Category</label>
            <select name="mj" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var m in (ViewBag.MajCats as List<string> ?? new())) { <option value="@m" selected="@(m == ViewBag.Mj?.ToString())">@m</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Classification</label>
            <select name="artClass" class="form-select form-select-sm"><option value="">-- All --</option>
                @foreach (var c in (ViewBag.ArtClasses as List<string> ?? new())) { <option value="@c" selected="@(c == ViewBag.ArtClass?.ToString())">@c</option> }
            </select></div>
        <div class="col-md-2"><label class="form-label small fw-semibold mb-0">Page Size</label>
            <select name="pageSize" class="form-select form-select-sm">
                @foreach (var ps in new[] { 50, 100, 250, 500 }) { <option value="@ps" selected="@(ViewBag.PageSize?.ToString() == ps.ToString())">@ps</option> }
            </select></div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
            <a href="@Url.Action("Output")" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Clear</a>
            <a asp-action="ExportCsv" asp-route-st="@ViewBag.St" asp-route-mj="@ViewBag.Mj" asp-route-artClass="@ViewBag.ArtClass" class="btn btn-success btn-sm"><i class="bi bi-download me-1"></i>Download CSV</a>
        </div>
    </form>
</div></div>

@{ var total = (int)(ViewBag.TotalCount ?? 0); var pg = (int)(ViewBag.Page ?? 1); var ps2 = (int)(ViewBag.PageSize ?? 100); }
<div class="alert alert-info py-1 small mb-2"><i class="bi bi-info-circle me-1"></i>Showing <strong>@rows.Count</strong> of <strong>@total.ToString("N0")</strong> (Page @pg) — @cols.Length columns</div>

<div class="card shadow-sm border-0"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-hover table-bordered table-sm mb-0" style="font-size:0.7rem;">
        <!-- Group header row -->
        <thead>
            <tr style="font-size:0.6rem;text-transform:uppercase;">
                <th colspan="@identityCols.Length" class="text-center text-white" style="background:#334155;">Identity</th>
                <th colspan="@stockCols.Length" class="text-center text-white" style="background:#1a3a5c;">Stock Reference</th>
                <th colspan="@paramCols.Length" class="text-center text-white" style="background:#4a2060;">Parameters</th>
                <th colspan="@mbqCols.Length" class="text-center text-white" style="background:#0d4f3c;">Display & MBQ</th>
                <th colspan="@reqCols.Length" class="text-center text-white" style="background:#7c4a00;">Requirement</th>
                <th colspan="@resultCols.Length" class="text-center text-white" style="background:#1B5E20;">Result</th>
            </tr>
            <tr class="table-dark">
            @foreach (var c in cols)
            {
                var display = c.Replace("_", " ");
                var colStyle = groupColors.GetValueOrDefault(c, "");
                var isResult = resultCols.Contains(c);
                var isNum = numericCols.Contains(c);
                var cls = isNum ? "text-end" : "";
                if (sortable.Contains(c))
                {
                    <th class="@cls text-nowrap" style="@colStyle"><a href="@Url.Action("Output", new { st = ViewBag.St, mj = ViewBag.Mj, artClass = ViewBag.ArtClass, sortCol = c, sortDir = NextDir(c), page = 1, pageSize = ps2 })" class="text-white text-decoration-none">@display@Arrow(c)</a></th>
                }
                else
                {
                    <th class="@cls text-nowrap" style="@colStyle">@display</th>
                }
            }
            </tr>
        </thead>
        <tbody>
            @foreach (var row in rows)
            {
                <tr>
                    @foreach (var c in cols)
                    {
                        var v = row.GetValueOrDefault(c);
                        if (c == "ST") { <td class="fw-semibold text-primary text-nowrap">@v</td> }
                        else if (c == "ART_CLASS") {
                            var clsName = v?.ToString() ?? "";
                            var badge = clsName == "L-ART" ? "bg-success" : clsName == "MIX-ART" ? "bg-secondary" : clsName == "OLD-ART" ? "bg-warning text-dark" : clsName == "NEW-L" ? "bg-info" : "bg-light text-dark";
                            <td><span class="badge @badge">@clsName</span></td>
                        }
                        else if (resultCols.Contains(c)) { <td class="text-end fw-bold" style="color:#1B5E20;">@(v is decimal d ? d.ToString("N2") : "0")</td> }
                        else if (v is decimal dec) { <td class="text-end">@dec.ToString("N2")</td> }
                        else { <td class="text-nowrap">@v</td> }
                    }
                </tr>
            }
            @if (!rows.Any()) { <tr><td colspan="@cols.Length" class="text-center text-muted py-3">No data. Run allocation first.</td></tr> }
        </tbody>
    </table>
</div></div></div>

@{ var totalPages = total > 0 ? (int)Math.Ceiling((double)total / ps2) : 1; }
@if (totalPages > 1) {
<nav class="mt-2"><ul class="pagination pagination-sm justify-content-center flex-wrap">
    @for (int p = Math.Max(1, pg - 4); p <= Math.Min(totalPages, pg + 4); p++)
    { <li class="page-item @(p == pg ? "active" : "")"><a class="page-link" href="@Url.Action("Output", new { st = ViewBag.St, mj = ViewBag.Mj, artClass = ViewBag.ArtClass, sortCol = sc, sortDir = sd, page = p, pageSize = ps2 })">@p</a></li> }
</ul></nav> }
